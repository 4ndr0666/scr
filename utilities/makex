#!/usr/bin/env bash
# Author: 4ndr0666
# Re-Architected by: Ψ-4ndr0666 (Superset Batch Optimization)
# Version: 2.1.0
# shellcheck disable=SC2016   # expressions in single quotes (log messages)
set -euo pipefail

# ==============================================================================
# 4NDR0SCRIPT UI LIBRARY
# ==============================================================================
CYAN='\033[38;5;51m'
GLOW='\033[1;36m'
RED='\033[38;5;196m'
ORANGE='\033[38;5;208m'
RESET='\033[0m'
FRAME_TOP="┌────────────────────────────────────────────────────────────┐"
FRAME_BTM="└────────────────────────────────────────────────────────────┘"

log_header() {
    echo -e "${CYAN}${FRAME_TOP}${RESET}"
    echo -e "${CYAN}│${RESET}       ${GLOW}💀 Ψ • - ⦑ ${1:-MAKEX : PERMISSION MATRIX} ⦒ - • Ψ 💀${RESET}        ${CYAN}│${RESET}"
    echo -e "${CYAN}${FRAME_BTM}${RESET}"
}
log_op()   { echo -e " ${CYAN}Ψ${RESET} [${GLOW}SYSTEM${RESET}] :: $1"; }
log_ok()   { echo -e " ${CYAN}Ψ${RESET} [${GLOW}ACTIVE${RESET}] :: $1"; }
log_warn() { echo -e " ${CYAN}!${RESET} [${ORANGE}CAUTION${RESET}] :: $1"; }
log_err()  { echo -e " ${RED}✘${RESET} [${RED}FATAL${RESET}]  :: $1" >&2; }

log_banner() {
    local banner
    banner="███╗   ███╗ █████╗ ██╗  ██╗███████╗██╗  ██╗\n"
    banner+="████╗ ████║██╔══██╗██║ ██╔╝██╔════╝╚██╗██╔╝\n"
    banner+="██╔████╔██║███████║█████╔╝ ██████╗   ╚███╔╝\n"
    banner+="██║╚██╔╝██║██╔══██║██╔═██╗ ██╔══╝   ██╔██╗\n"
    banner+="██║ ╚═╝ ██║██║  ██║██║  ██╗███████╗██╔╝ ██╗\n"
    banner+="╚═╝     ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═╝"
    echo -e "${CYAN}${banner}${RESET}\n"
}

# ==============================================================================
# CONFIGURATION ENGINE
# ==============================================================================
DEFAULT_DIR="."
BATCH_LIMIT=1000    # Prevents "Argument list too long" OS-level errors

# Shebang pattern — handles: bash sh zsh dash ksh ash + env-wrapped + env -S forms
SHEBANG_PATTERN='^#![[:space:]]*/([^ ]*/env[[:space:]]+-S[[:space:]]+)?(bash|sh|zsh|dash|ksh|ash)'

# Single source-of-truth for patterns that must never receive the exec bit.
# Used in both EXEC_EXCLUSION_PATTERNS (phase 1) and NON_EXEC_PATTERNS (phase 2).
SAFE_NOEXEC_PATTERNS=(
    "*.md" "*.MD" "*.markdown"
    "*.txt" "*.TXT"
    "*.pdf" "*.PDF"
    "*.jpg" "*.jpeg" "*.png" "*.gif" "*.svg"
    "*.json" "*.yml" "*.yaml"
    "*.csv" "*.html" "*.css" "*.rst"
    "README" "README.md" "README.MD"
)

# ==============================================================================
# ARGUMENT PARSING
# ==============================================================================
REVERSE_MODE=0
HIDDEN_MODE=0
TARGETS=()

usage() {
    log_header "MAKEX : HELP"
    echo -e " Usage: makex [-r] [--hidden] [-h|--help] [DIR]\n"
    echo -e "  -r        : Reverse Mode — strip exec from scripts, add to non-scripts"
    echo -e "  --hidden  : Include hidden files/directories (default: skip dotfiles)"
    echo -e "  -h|--help : Show this help message"
    echo -e "  [DIR]     : Target directory (default: .)\n"
    exit 0
}

for arg in "$@"; do
    case "$arg" in
        -h|--help)      usage ;;
        --hidden)       HIDDEN_MODE=1 ;;
        -r)             REVERSE_MODE=1 ;;
        # Support combined short flags: -rh / -hr
        -rh|-hr)        REVERSE_MODE=1; HIDDEN_MODE=1 ;;
        -*)
            log_err "Unknown flag: '$arg'. Use -h for help."
            exit 1
            ;;
        *)              TARGETS+=("$arg") ;;
    esac
done

DIR="${TARGETS[0]:-$DEFAULT_DIR}"

if [[ ! -d "$DIR" ]]; then
    log_err "Directory parameter '$DIR' does not map to a valid filesystem entity."
    exit 1
fi

# ==============================================================================
# PRIVILEGE CHECK
# ==============================================================================
if ! command -v sudo >/dev/null 2>&1; then
    log_err "sudo is not available. Cannot apply chmod operations. Aborting."
    exit 1
fi

# ==============================================================================
# MODE CALIBRATION
# ==============================================================================
declare MODE_NAME
declare SCRIPT_CHMOD_OP SCRIPT_ACTION_VERB SCRIPT_PAST_TENSE_VERB
declare NON_SCRIPT_CHMOD_OP NON_SCRIPT_ACTION_VERB NON_SCRIPT_PAST_TENSE_VERB
declare -a SCRIPT_PERM_CHECK_ARGS NON_SCRIPT_PERM_CHECK_ARGS

if [[ "$REVERSE_MODE" -eq 1 ]]; then
    MODE_NAME="Reverse"

    SCRIPT_PERM_CHECK_ARGS=("-perm" "/u=x")
    SCRIPT_CHMOD_OP="u-x"
    SCRIPT_ACTION_VERB="non-executable"
    SCRIPT_PAST_TENSE_VERB="Removed executable bit from"

    NON_SCRIPT_PERM_CHECK_ARGS=("!" "-perm" "-u=x")
    NON_SCRIPT_CHMOD_OP="u+x"
    NON_SCRIPT_ACTION_VERB="executable"
    NON_SCRIPT_PAST_TENSE_VERB="Injected executable bit to"
else
    MODE_NAME="Default"

    SCRIPT_PERM_CHECK_ARGS=("!" "-perm" "-u=x")
    SCRIPT_CHMOD_OP="u+x"
    SCRIPT_ACTION_VERB="executable"
    SCRIPT_PAST_TENSE_VERB="Injected executable bit to"

    NON_SCRIPT_PERM_CHECK_ARGS=("-perm" "/a=x")
    NON_SCRIPT_CHMOD_OP="a-x"
    NON_SCRIPT_ACTION_VERB="non-executable"
    NON_SCRIPT_PAST_TENSE_VERB="Removed executable bit from"
fi

# ==============================================================================
# PRUNE ARGS — prevent dotfile traversal or .git pollution
# ==============================================================================
declare -a prune_args=()
if [[ "$HIDDEN_MODE" -eq 0 ]]; then
    # -mindepth 1 prevents pruning "." itself on some find implementations
    prune_args=("-mindepth" "1" "(" "-name" ".*" "-prune" ")" "-o")
else
    prune_args=("(" "-path" "*/.git" "-prune" ")" "-o")
fi

# ==============================================================================
# TELEMETRY
# ==============================================================================
files_changed_phase1=0
files_changed_phase2=0
total_failures=0

# ==============================================================================
# UI BOOTSTRAP
# ==============================================================================
command -v clear >/dev/null 2>&1 && clear
log_banner
log_header "MAKEX PERMISSION MATRIX"
log_op "Mode -> Tactical Profile: [$MODE_NAME] | Hidden Processing: [$HIDDEN_MODE]"
log_op "Target Directory -> '$DIR'"

# ==============================================================================
# HELPERS
# ==============================================================================

# check_is_script FILE
# Returns 0 if FILE is a shell script (by extension or shebang), 1 otherwise.
# Uses head -c 256 for a bounded, binary-safe shebang read.
check_is_script() {
    local target="$1"
    # Fast path: .sh extension
    [[ "${target##*/}" == *.sh ]] && return 0
    # Bounded shebang read — LC_ALL=C prevents multibyte decode panics on binary files
    local first_line
    first_line=$(LC_ALL=C head -c 256 "$target" 2>/dev/null | head -n 1) || return 1
    [[ "$first_line" =~ $SHEBANG_PATTERN ]] && return 0
    return 1
}

# build_name_filter ARRAY_NAME_VAR
# Emits find -name predicates joined by -o, wrapped in a group.
# e.g. ( -name "*.md" -o -name "*.txt" -o ... )
build_name_filter() {
    local -n _patterns="$1"    # nameref — bash 4.3+
    local -a result=()
    if [[ ${#_patterns[@]} -gt 0 ]]; then
        result+=("(" "-name" "${_patterns[0]}")
        for (( i=1; i<${#_patterns[@]}; i++ )); do
            result+=("-o" "-name" "${_patterns[$i]}")
        done
        result+=(")")
    fi
    printf '%s\0' "${result[@]}"
}

# flush_batch CHMOD_OP PHASE FILE [FILE ...]
# Applies chmod in a single syscall across the batch. Updates telemetry counters.
# FIX: Previously consumed first two elements of target array as chmod/phase params.
flush_batch() {
    local chmod_op="$1"
    local phase="$2"
    shift 2
    local -a files=("$@")

    [[ ${#files[@]} -eq 0 ]] && return 0

    if sudo chmod "$chmod_op" "${files[@]}"; then
        for f in "${files[@]}"; do
            if [[ "$phase" == "1" ]]; then
                log_ok "$SCRIPT_PAST_TENSE_VERB '${CYAN}${f}${RESET}'."
            else
                log_ok "$NON_SCRIPT_PAST_TENSE_VERB '${CYAN}${f}${RESET}'."
            fi
        done
        # FIX: use || true to prevent set -e from triggering when counter is 0
        if [[ "$phase" == "1" ]]; then
            (( files_changed_phase1 += ${#files[@]} )) || true
        else
            (( files_changed_phase2 += ${#files[@]} )) || true
        fi
    else
        log_err "chmod $chmod_op failed on batch of ${#files[@]} file(s) (phase $phase)."
        (( total_failures += ${#files[@]} )) || true
    fi
}

# ==============================================================================
# PHASE 1: NATIVE SCRIPT HEURISTICS (Batch Optimization)
# ==============================================================================
log_op "PHASE 1: Engaging $SCRIPT_ACTION_VERB script directives..."

# Build exclusion args from the shared SAFE_NOEXEC_PATTERNS array
declare -a find_exclusion_args=()
for pattern in "${SAFE_NOEXEC_PATTERNS[@]}"; do
    find_exclusion_args+=("!" "-name" "$pattern")
done

declare -a target_batch=()

while IFS= read -r -d '' file; do
    if check_is_script "$file"; then
        target_batch+=("$file")
        if [[ ${#target_batch[@]} -ge $BATCH_LIMIT ]]; then
            flush_batch "$SCRIPT_CHMOD_OP" "1" "${target_batch[@]}"
            target_batch=()
        fi
    fi
done < <(
    find "$DIR" \
        "${prune_args[@]}" \
        "(" -type f \
            "${find_exclusion_args[@]}" \
            "${SCRIPT_PERM_CHECK_ARGS[@]}" \
        ")" -print0
)

# Flush remaining
if [[ ${#target_batch[@]} -gt 0 ]]; then
    flush_batch "$SCRIPT_CHMOD_OP" "1" "${target_batch[@]}"
fi
target_batch=()

echo -e "${CYAN}------------------------------------------------------------${RESET}"

# ==============================================================================
# PHASE 2: NON-SCRIPT HARDENING (Batch Optimization)
# ==============================================================================
log_op "PHASE 2: Engaging $NON_SCRIPT_ACTION_VERB non-script directives..."

# Build ( -name "*.md" -o -name "*.txt" -o ... ) predicate group
# FIX: Previously the OR chain lacked outer grouping relative to -type and -perm,
#      causing find operator-precedence bugs that could match unintended files.
declare -a find_non_exec_args=()
if [[ ${#SAFE_NOEXEC_PATTERNS[@]} -gt 0 ]]; then
    find_non_exec_args+=("(")
    find_non_exec_args+=("-name" "${SAFE_NOEXEC_PATTERNS[0]}")
    for (( i=1; i<${#SAFE_NOEXEC_PATTERNS[@]}; i++ )); do
        find_non_exec_args+=("-o" "-name" "${SAFE_NOEXEC_PATTERNS[$i]}")
    done
    find_non_exec_args+=(")")
fi

while IFS= read -r -d '' file; do
    target_batch+=("$file")
    if [[ ${#target_batch[@]} -ge $BATCH_LIMIT ]]; then
        flush_batch "$NON_SCRIPT_CHMOD_OP" "2" "${target_batch[@]}"
        target_batch=()
    fi
done < <(
    find "$DIR" \
        "${prune_args[@]}" \
        "(" -type f \
            "${NON_SCRIPT_PERM_CHECK_ARGS[@]}" \
            "${find_non_exec_args[@]}" \
        ")" -print0
)

# Flush remaining
if [[ ${#target_batch[@]} -gt 0 ]]; then
    flush_batch "$NON_SCRIPT_CHMOD_OP" "2" "${target_batch[@]}"
fi

echo -e "${CYAN}------------------------------------------------------------${RESET}"

# ==============================================================================
# TELEMETRY SUMMARY
# ==============================================================================
total_changed=$(( files_changed_phase1 + files_changed_phase2 ))

if [[ "$total_failures" -gt 0 ]]; then
    log_err "EXECUTION CONCLUDED WITH CRITICAL FAULTS: $total_failures file(s) unmodified."
    log_warn "Phase 1 Matrix Alterations: $files_changed_phase1"
    log_warn "Phase 2 Matrix Alterations: $files_changed_phase2"
    exit 1
else
    echo -e "\n      ${CYAN}─── [ SYSTEM READY : MATRIX SECURED ] ───${RESET}\n"
    log_op "Phase 1 Executable Alterations  : $files_changed_phase1"
    log_op "Phase 2 Non-Executable Alterations: $files_changed_phase2"
    log_op "Total Files Modified            : $total_changed"
    exit 0
fi
