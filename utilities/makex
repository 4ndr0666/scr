set -euo pipefail

# --- 4NDR0SCRIPT UI LIBRARY (VERBATIM) ---
CYAN='\033[38;5;51m'
GLOW='\033[1;36m'
RED='\033[38;5;196m'
ORANGE='\033[38;5;208m'
RESET='\033[0m'
FRAME_TOP="в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ"
FRAME_BTM="в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ"

log_header() {
	echo -e "${CYAN}${FRAME_TOP}${RESET}"
	echo -e "${CYAN}в”Ӯ${RESET}       ${GLOW}рҹ’Җ ОЁ вҖў - вҰ‘ ${1:-MAKEX : PERMISSION MATRIX} вҰ’ - вҖў ОЁ рҹ’Җ${RESET}        ${CYAN}в”Ӯ${RESET}"
	echo -e "${CYAN}${FRAME_BTM}${RESET}"
}
log_op() { echo -e " ${CYAN}ОЁ${RESET} [${GLOW}SYSTEM${RESET}] :: $1"; }
log_ok() { echo -e " ${CYAN}ОЁ${RESET} [${GLOW}ACTIVE${RESET}] :: $1"; }
log_warn() { echo -e " ${CYAN}!${RESET} [${ORANGE}CAUTION${RESET}] :: $1"; }
log_err() { echo -e " ${RED}вңҳ${RESET} [${RED}FATAL${RESET}]  :: $1"; }
log_banner() {
	local banner="в–Ҳв–Ҳв–Ҳв•—   в–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•—  в–Ҳв–Ҳв•—\nв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘ в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•”в•җв•җв•җв•җв•қв•ҡв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қ\nв–Ҳв–Ҳв•”в–Ҳв–Ҳв–Ҳв–Ҳв•”в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—   в•ҡв–Ҳв–Ҳв–Ҳв•”в•қ\nв–Ҳв–Ҳв•‘в•ҡв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•җв•җв•қ   в–Ҳв–Ҳв•”в–Ҳв–Ҳв•—\nв–Ҳв–Ҳв•‘ в•ҡв•җв•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•—\nв•ҡв•җв•қ     в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ"
	echo -e "${CYAN}${banner}${RESET}\n"
}

# --- Configuration Engine ---
DEFAULT_DIR="."
SHEBANG_PATTERN='^#!.*(bash|sh|zsh|dash|ksh|ash|env bash|env sh)'
BATCH_LIMIT=1000 # Prevents "Argument list too long" OS-level errors

EXEC_EXCLUSION_PATTERNS=(
	"*.md" "*.MD" "*.markdown" "*.txt" "*.TXT" "README" "README.md" "README.MD" "*.rst"
)

NON_EXEC_PATTERNS=(
	"*.md" "*.MD" "*.markdown" "*.txt" "*.TXT" "*.pdf" "*.PDF"
	"*.jpg" "*.jpeg" "*.png" "*.gif" "*.svg" "*.json" "*.yml" "*.yaml"
	"*.csv" "*.html" "*.css" "*.rst" "README"
)

# --- Parameter Extraction Matrix ---
REVERSE_MODE=0
HIDDEN_MODE=0
TARGETS=()

for arg in "$@"; do
	if [[ "$arg" == -* ]]; then
		[[ "$arg" == *r* ]] && REVERSE_MODE=1
		[[ "$arg" == *h* ]] && HIDDEN_MODE=1

		# Help interception
		if [[ "$arg" == *help* || "$arg" == "--help" ]]; then
			log_header "MAKEX : HELP"
			echo -e " Usage: makex [-r] [-h] [-rh] [DIR]\n\n -r : Reverse Mode (Strip scripts, execute non-scripts)\n -h : Include hidden files/directories\n [DIR] : Target directory (Default: .)"
			exit 0
		fi
	else
		TARGETS+=("$arg")
	fi
done

DIR="${TARGETS[0]:-$DEFAULT_DIR}"

if [[ ! -d "$DIR" ]]; then
	log_err "Directory parameter '$DIR' does not map to a valid filesystem entity."
	exit 1
fi

# --- Mode Calibration ---
declare MODE_NAME
declare -a SCRIPT_PERM_CHECK_ARGS SCRIPT_CHMOD_OP SCRIPT_ACTION_VERB SCRIPT_PAST_TENSE_VERB
declare -a NON_SCRIPT_PERM_CHECK_ARGS NON_SCRIPT_CHMOD_OP NON_SCRIPT_ACTION_VERB NON_SCRIPT_PAST_TENSE_VERB

if [[ "$REVERSE_MODE" -eq 1 ]]; then
	MODE_NAME="Reverse"
	SCRIPT_PERM_CHECK_ARGS=("-perm" "/u=x")
	SCRIPT_CHMOD_OP="u-x"
	SCRIPT_ACTION_VERB="non-executable"
	SCRIPT_PAST_TENSE_VERB="Removed executable bit from"

	NON_SCRIPT_PERM_CHECK_ARGS=("!" "-perm" "-u=x")
	NON_SCRIPT_CHMOD_OP="u+x"
	NON_SCRIPT_ACTION_VERB="executable"
	NON_SCRIPT_PAST_TENSE_VERB="Injected executable bit to"
else
	MODE_NAME="Default"
	SCRIPT_PERM_CHECK_ARGS=("!" "-perm" "-u=x")
	SCRIPT_CHMOD_OP="u+x"
	SCRIPT_ACTION_VERB="executable"
	SCRIPT_PAST_TENSE_VERB="Injected executable bit to"

	NON_SCRIPT_PERM_CHECK_ARGS=("-perm" "/a=x")
	NON_SCRIPT_CHMOD_OP="a-x"
	NON_SCRIPT_ACTION_VERB="non-executable"
	NON_SCRIPT_PAST_TENSE_VERB="Removed executable bit from"
fi

# Determine Pruning constraints with explicit boolean grouping
declare -a prune_args=()
if [[ "$HIDDEN_MODE" -eq 0 ]]; then
	prune_args=("(" "-name" ".*" "-prune" ")" "-o")
else
	prune_args=("(" "-path" "*/.git" "-prune" ")" "-o")
fi

# Initialize telemetry
files_changed_phase1=0
files_changed_phase2=0
total_failures=0

command -v clear >/dev/null 2>&1 && clear
log_banner
log_header "MAKEX PERMISSION MATRIX"
log_op "Mode -> Tactical Profile: [$MODE_NAME] | Hidden Processing: [$HIDDEN_MODE]"
log_op "Target Directory -> '$DIR'"

# ==============================================================================
# PHASE 1: NATIVE SCRIPT HEURISTICS (Batch Optimization)
# ==============================================================================
log_op "PHASE 1: Engaging $SCRIPT_ACTION_VERB script directives..."

declare -a find_exclusion_args=()
for pattern in "${EXEC_EXCLUSION_PATTERNS[@]}"; do
	find_exclusion_args+=("!" "-name" "$pattern")
done

check_is_script() {
	local target="$1"
	[[ "${target##*/}" == *.sh ]] && return 0
	local first_line
	# LC_ALL=C ensures safe handling of null-bytes in binary binaries without shell panics
	LC_ALL=C IFS= read -r -d '' -n 100 first_line <"$target" 2>/dev/null || true
	[[ "$first_line" =~ $SHEBANG_PATTERN ]] && return 0
	return 1
}

# Batch Processing Array
declare -a target_batch=()

flush_batch() {
	local batch_ref=("$@")
	local chmod_op="$1"
	local phase="$2"
	shift 2
	local files=("$@")

	if [[ ${#files[@]} -gt 0 ]]; then
		if sudo chmod "$chmod_op" "${files[@]}"; then
			for f in "${files[@]}"; do
				log_ok "$SCRIPT_PAST_TENSE_VERB '${CYAN}$f${RESET}'."
			done
			if [[ "$phase" == "1" ]]; then
				((files_changed_phase1 += ${#files[@]}))
			else
				((files_changed_phase2 += ${#files[@]}))
			fi
		else
			log_err "Execution halted on batch payload execution."
			((total_failures += ${#files[@]}))
		fi
	fi
}

while IFS= read -r -d '' file; do
	if check_is_script "$file"; then
		target_batch+=("$file")
		if [[ ${#target_batch[@]} -ge $BATCH_LIMIT ]]; then
			flush_batch "$SCRIPT_CHMOD_OP" "1" "${target_batch[@]}"
			target_batch=()
		fi
	fi
done < <(find "$DIR" "${prune_args[@]}" "(" -type f "${find_exclusion_args[@]}" "${SCRIPT_PERM_CHECK_ARGS[@]}" ")" -print0)

# Flush remaining
flush_batch "$SCRIPT_CHMOD_OP" "1" "${target_batch[@]}"
target_batch=()

echo -e "${CYAN}------------------------------------------------------------${RESET}"

# ==============================================================================
# PHASE 2: NON-SCRIPT HARDENING (Batch Optimization)
# ==============================================================================
log_op "PHASE 2: Engaging $NON_SCRIPT_ACTION_VERB non-script directives..."

declare -a find_non_exec_args=()
if [[ ${#NON_EXEC_PATTERNS[@]} -gt 0 ]]; then
	find_non_exec_args+=("-name" "${NON_EXEC_PATTERNS[0]}")
	for ((i = 1; i < ${#NON_EXEC_PATTERNS[@]}; i++)); do
		find_non_exec_args+=("-o" "-name" "${NON_EXEC_PATTERNS[i]}")
	done
fi

while IFS= read -r -d '' file; do
	target_batch+=("$file")
	if [[ ${#target_batch[@]} -ge $BATCH_LIMIT ]]; then
		flush_batch "$NON_SCRIPT_CHMOD_OP" "2" "${target_batch[@]}"
		target_batch=()
	fi
done < <(find "$DIR" "${prune_args[@]}" "(" -type f "${NON_SCRIPT_PERM_CHECK_ARGS[@]}" "(" "${find_non_exec_args[@]}" ")" ")" -print0)

# Flush remaining
flush_batch "$NON_SCRIPT_CHMOD_OP" "2" "${target_batch[@]}"

echo -e "${CYAN}------------------------------------------------------------${RESET}"

# ==============================================================================
# TELEMETRY SUMMARY
# ==============================================================================
if [[ "$total_failures" -gt 0 ]]; then
	log_err "EXECUTION CONCLUDED WITH CRITICAL FAULTS: $total_failures"
	log_warn "Phase 1 Matrix Alterations: $files_changed_phase1"
	log_warn "Phase 2 Matrix Alterations: $files_changed_phase2"
	exit 1
else
	echo -e "\n      ${CYAN}в”Җв”Җв”Җ [ SYSTEM READY : MATRIX SECURED ] в”Җв”Җв”Җ${RESET}\n"
	log_op "Phase 1 Executable Alterations: $files_changed_phase1"
	log_op "Phase 2 Non-Executable Alterations: $files_changed_phase2"
	exit 0
fi
