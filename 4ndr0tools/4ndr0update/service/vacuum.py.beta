def run_all_tasks():
    for k in range(1, 32):
        try: menu_options[str(k)]()
        except: pass

menu_options["0"] = run_all_tasks

def main():
    if os.geteuid() != 0:
        try:
            subprocess.check_call(["sudo", sys.executable] + sys.argv)
            sys.exit(0)
        except Exception as e:
            print(f"Escalation failed: {e}")
            sys.exit(1)

    while True:
        print(f"\n{GREEN}=== 💀 VACUUM SUPERSET HARDENED 💀 ==={NC}")
        # Print keys in order
        keys = sorted([k for k in menu_options.keys() if k.isdigit()], key=int)
        
        # Simple column display
        for i in range(0, len(keys), 2):
            k1 = keys[i]
            n1 = menu_options[k1].__name__.replace("_", " ").title()
            s1 = f"{k1}) {n1}"
            
            s2 = ""
            if i+1 < len(keys):
                k2 = keys[i+1]
                n2 = menu_options[k2].__name__.replace("_", " ").title()
                s2 = f"{k2}) {n2}"
            
            print(f"{s1:<40} {s2}")
            
        print("Q) Quit")
        
        c = input("\nChoice: ").strip().upper()
        if c == "Q": break
        if c in menu_options:
            menu_options[c]()
        else:
            print("Invalid.")

if __name__ == "__main__":
    main()
