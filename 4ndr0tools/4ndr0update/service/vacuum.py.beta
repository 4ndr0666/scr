##########################
# 10. clear_trash
##########################

def clear_trash():
    log_and_print(f"{INFO} Clearing trash...", "info")
    trash_dirs = []
    
    # Check current user
    user_trash = os.path.expanduser("~/.local/share/Trash")
    if os.path.exists(user_trash): trash_dirs.append(user_trash)
    
    # Check root if sudo
    if os.geteuid() == 0:
        trash_dirs.append("/root/.local/share/Trash")
        # Check other home dirs
        if os.path.exists("/home"):
             for d in os.listdir("/home"):
                 t = os.path.join("/home", d, ".local/share/Trash")
                 if os.path.exists(t): trash_dirs.append(t)

    if not trash_dirs:
        log_and_print(f"{INFO} No trash found.", "info")
        return

    with spinning_spinner():
        for trash_dir in trash_dirs:
            try:
                if os.path.exists(trash_dir):
                     shutil.rmtree(trash_dir)
                     os.makedirs(trash_dir) # Restore empty dir
                     log_and_print(f"{SUCCESS} Cleared {trash_dir}.", "info")
            except Exception as e:
                log_and_print(f"{FAILURE} Failed to clear {trash_dir}: {e}", "error")


###############################
# 11. optimize_databases
###############################

def optimize_databases(skips=None):
    if not skips: skips = []
    log_and_print(f"{INFO} Optimizing system databases...", "info")

    def run_cmd(cmd, name):
        if name in skips: return
        try:
            subprocess.run(cmd, check=True, capture_output=True, text=True)
            log_and_print(f"{SUCCESS} {name} updated.", "info")
        except subprocess.CalledProcessError:
            log_and_print(f"{FAILURE} {name} failed.", "error")

    with spinning_spinner():
        run_cmd(["sudo", "updatedb"], "mlocate")
        run_cmd(["sudo", "pkgfile", "-u"], "pkgfile")
        run_cmd(["sudo", "pacman-db-upgrade"], "pacman-db")
        run_cmd(["sudo", "pacman", "-Sc", "--noconfirm"], "pacman-cache")
        run_cmd(["sync"], "sync")
        run_cmd(["sudo", "pacman-key", "--refresh-keys"], "refresh-keys")
        run_cmd(["sudo", "pacman-key", "--populate"], "populate-keys")
        # Use -Syy to force DB refresh, but NOT -Sy to install packages (prevents partial upgrade risk when not installing)
        run_cmd(["sudo", "pacman", "-Syy"], "pacman-sync")


############################
# 12. clean_package_cache
############################

def clean_package_cache(retain_versions=2):
    log_and_print(f"{INFO} Cleaning package cache (keep {retain_versions})...", "info")
    
    if is_interactive():
         if prompt_with_timeout("Proceed? [Y/n]: ", default="Y").lower() != "y":
             return

    cache_dir = "/var/cache/pacman/pkg/"
    if os.path.exists(cache_dir):
        for f in os.listdir(cache_dir):
            if f.endswith(".aria2") or f.startswith("download-"):
                try:
                    os.remove(os.path.join(cache_dir, f))
                except: pass

    cmd = ["sudo", "paccache", f"-rk{retain_versions}"]
    res = subprocess.run(cmd, capture_output=True, text=True)
    if res.returncode == 0:
        log_and_print(f"{SUCCESS} Package cache cleaned.", "info")
    else:
        log_and_print(f"{FAILURE} paccache failed: {res.stderr}", "error")


##############################
# 13. clean_aur_dir
##############################

def clean_aur_dir(aur_dir=None):
    log_and_print(f"{INFO} Cleaning AUR directory...", "info")
    if not aur_dir:
        # Check common locations
        candidates = [
            os.path.expanduser("~/.cache/yay"),
            os.path.expanduser("~/.cache/paru"),
            os.path.expanduser("~/.local/cache/yay")
        ]
        for c in candidates:
            if os.path.isdir(c):
                aur_dir = c
                break
    
    if not aur_dir or not os.path.isdir(aur_dir):
        log_and_print(f"{INFO} No AUR dir found.", "info")
        return

    # Use the helper's clean command if available
    helper = detect_aur_helper()
    if helper:
        log_and_print(f"{INFO} Using {helper} to clean cache...", "info")
        subprocess.run([helper, "-Sc", "--noconfirm"])
    else:
        log_and_print(f"{INFO} Manual clean of {aur_dir} (removing old pkgs).", "info")
        # Basic cleanup of .pkg.tar.zst files that are old? 
        # Risky to implement manually without complex logic. 
        # We will just warn or skip to remain safe superset.
        log_and_print(f"{WARNING} Skipping manual deletion to avoid data loss.", "warning")


#####################################
# 14. handle_pacnew_pacsave
#####################################

def handle_pacnew_pacsave():
    log_and_print(f"{INFO} Handling .pacnew/.pacsave...", "info")
    
    # Find files
    pacnew = subprocess.getoutput("sudo find /etc -name '*.pacnew'").splitlines()
    pacsave = subprocess.getoutput("sudo find /etc -name '*.pacsave'").splitlines()
    pacnew = [x for x in pacnew if x.strip()]
    pacsave = [x for x in pacsave if x.strip()]

    if not pacnew and not pacsave:
        log_and_print(f"{SUCCESS} None found.", "info")
        return

    def handle_file(f, ftype):
        action = prompt_with_timeout(
            f"{ftype}: {f}\n(v)iew, (r)eplace, (d)elete, (s)kip? ", persistent=True
        ).lower()
        
        if action == "v":
            # try to use editor
            editor = os.environ.get("EDITOR", "nano")
            subprocess.run(["sudo", editor, f])
        elif action == "r":
            orig = f.replace(ftype, "")
            try:
                shutil.copy2(orig, orig + ".bak") # Backup
                shutil.move(f, orig)
                log_and_print(f"{SUCCESS} Replaced {orig}", "info")
            except Exception as e:
                log_and_print(f"{FAILURE} Error: {e}", "error")
        elif action == "d":
            try:
                os.remove(f)
                log_and_print(f"{SUCCESS} Deleted {f}", "info")
            except: pass

    for f in pacnew: handle_file(f, ".pacnew")
    for f in pacsave: handle_file(f, ".pacsave")


##############################################
# 15. verify_installed_packages
##############################################

def verify_installed_packages():
    log_and_print(f"{INFO} Checking package integrity...", "info")
    
    with spinning_spinner():
        res = subprocess.run(["pacman", "-Qk"], capture_output=True, text=True)
        broken = []
        for line in res.stdout.splitlines():
             if " 0 missing files" not in line:
                 # parse "warning: package: N missing files"
                 parts = line.split(":")
                 if len(parts) >= 2:
                     pkg = parts[1].strip().split()[0] # basic parse
                     broken.append(pkg)
    
    broken = list(set(broken))
    if not broken:
        log_and_print(f"{SUCCESS} Integrity OK.", "info")
        return

    log_and_print(f"{WARNING} Broken packages: {broken}", "warning")
    
    # Save list
    with open(os.path.join(LOG_BASE_DIR, "missing_files.txt"), "w") as f:
        f.write("\n".join(broken))

    if prompt_with_timeout("Reinstall broken packages? [y/N]: ", persistent=True).lower() == "y":
        # Update keyring first
        subprocess.run(["sudo", "pacman", "-Sy", "archlinux-keyring", "--noconfirm"])
        
        official = []
        aur = []
        helper = detect_aur_helper()
        
        for p in broken:
            if is_official_package(p): official.append(p)
            else: aur.append(p)
            
        if official:
            reinstall_packages_pexpect(official)
        if aur and helper:
            reinstall_aur_packages(aur, helper)


def detect_aur_helper():
    if hasattr(detect_aur_helper, "_cached"): return detect_aur_helper._cached
    for h in ["yay", "paru", "trizen"]:
        if shutil.which(h):
            detect_aur_helper._cached = h
            return h
    return None

def is_official_package(pkg):
    res = subprocess.run(["pacman", "-Si", pkg], capture_output=True, text=True)
    return res.returncode == 0 and "Repository" in res.stdout


###########################################
# 16. reinstall_aur_packages / pexpect logic
###########################################

def reinstall_aur_packages(packages, helper):
    if not packages: return
    cmd = f"{helper} -S {' '.join(packages)} --noconfirm"
    log_and_print(f"{INFO} Reinstalling AUR: {packages}", "info")
    # AUR helpers usually interactive, we try pexpect or just run
    try:
        # Simple run for AUR helpers often works with --noconfirm
        subprocess.run(cmd, shell=True) 
    except Exception as e:
        logging.error(f"AUR install failed: {e}")


def reinstall_packages_pexpect(packages, max_retries=3):
    if not packages: return
    # Use -S --needed to prevent partial upgrade of OTHER packages, 
    # but strictly we are reinstalling specific ones.
    # To be safe on Arch: one should update system first. 
    # We will assume user knows risks or we use -S only.
    
    pkg_str = " ".join(packages)
    cmd = f"sudo pacman -S {pkg_str} --noconfirm --needed" 
    
    # Pexpect for advanced handling
    child = pexpect.spawn(cmd, encoding="utf-8", timeout=300)
    child.logfile = open(log_file_path, "a")
    
    try:
        while True:
            idx = child.expect([
                pexpect.EOF,
                r":: Import PGP key .* \[Y/n\]",
                r":: Replace .* \[Y/n\]",
                r":: Proceed with installation\? \[Y/n\]",
                r":: (.*) exists in filesystem",
                r"error: .*"
            ])
            
            if idx == 0: break
            elif idx in [1, 2, 3]: child.sendline("y")
            elif idx == 4: child.sendline("y") # overwrite? usually separate prompt
            elif idx == 5:
                err = child.after.strip()
                handle_pacman_errors(err)
                break
        child.close()
    except Exception as e:
        log_and_print(f"{FAILURE} Pexpect failed: {e}", "error")


def handle_pacman_errors(error_msg):
    if "key could not be looked up" in error_msg:
        subprocess.run(["sudo", "pacman", "-Sy", "archlinux-keyring", "--noconfirm"])
    
    if "exists in filesystem" in error_msg:
        # Extract file and force overwrite
        match = re.search(r"([\S]+) exists in filesystem", error_msg)
        if match:
            f = match.group(1)
            # Find which package owns it? Or just overwrite.
            # We'll try the overwrite flag for the next run (logic simplified here)
            log_and_print(f"{WARNING} File conflict: {f}. Manual intervention recommended.", "warning")


############################
# 17. check_failed_cron_jobs
############################

def check_failed_cron_jobs(days_back=1):
    log_and_print(f"{INFO} Checking failed cron jobs...", "info")
    try:
        out = subprocess.check_output(
            ["journalctl", "-u", "cron", "--since", f"{days_back} days ago"], 
            text=True, stderr=subprocess.DEVNULL
        )
        failed = [l for l in out.splitlines() if "FAILED" in l]
        if failed:
            log_and_print(f"{FAILURE} Found failed jobs:", "error")
            for f in failed: print(f)
            
            if prompt_with_timeout("Repair? [y/n]: ", persistent=True).lower() == "y":
                log_and_print("Please check logs manually.", "info")
        else:
            log_and_print(f"{SUCCESS} No failed jobs.", "info")
    except:
        log_and_print(f"{INFO} No cron logs.", "info")


########################################
# 18. clear_docker_images
########################################

def clear_docker_images(dry_run=False, remove_volumes=False):
    if not shutil.which("docker"):
        log_and_print("Docker not installed.", "info")
        return
    
    cmd = ["sudo", "docker", "system", "prune", "-a", "-f"]
    if remove_volumes: cmd.append("--volumes")
    
    if dry_run:
        print(f"Would run: {' '.join(cmd)}")
    else:
        execute_command(cmd)


##################################
# 19. clear_temp_folder
##################################

def clear_temp_folder(age_days=2, whitelist=None):
    if not whitelist: whitelist = []
    log_and_print(f"{INFO} Clearing /tmp > {age_days} days...", "info")
    
    # Check systemd tmpfiles
    if os.path.exists("/usr/lib/tmpfiles.d/tmp.conf"):
        log_and_print(f"{WARNING} Systemd manages /tmp.", "warning")

    cmd = ["sudo", "find", "/tmp", "-type", "f", "-atime", f"+{age_days}"]
    try:
        res = subprocess.run(cmd, capture_output=True, text=True)
        files = res.stdout.splitlines()
        for f in files:
            if any(w in f for w in whitelist): continue
            try:
                os.remove(f)
            except: pass
        log_and_print(f"{SUCCESS} Cleared.", "info")
    except: pass


####################################
# 20. check_rmshit_script
####################################

def check_rmshit_script(config_path=None):
    log_and_print(f"{INFO} Cleaning unnecessary files...", "info")
    
    if not config_path:
        config_path = os.path.join(LOG_BASE_DIR, "rmshit_paths.txt")
        if not os.path.exists(config_path):
            # Create default
            defaults = ["~/.adobe", "~/.macromedia", "~/.DS_Store", "~/.thumbnails"]
            with open(config_path, "w") as f:
                f.write("\n".join(defaults))
    
    # Read config
    with open(config_path, "r") as f:
        paths = [l.strip() for l in f if l.strip()]

    # Interactive add
    new = input("Add temp path to clean (space sep): ").strip()
    if new: paths.extend(new.split())

    for p in paths:
        exp = os.path.expanduser(p)
        if os.path.exists(exp):
            if prompt_with_timeout(f"Remove {exp}? [y/N]: ", persistent=True).lower() == "y":
                # Safety check
                if exp in [os.path.expanduser("~"), "/etc", "/"]:
                    log_and_print(f"{FAILURE} Skipping critical path {exp}", "error")
                    continue
                try:
                    if os.path.isdir(exp): shutil.rmtree(exp)
                    else: os.remove(exp)
                    log_and_print(f"{SUCCESS} Removed {exp}", "info")
                except Exception as e:
                    print(e)


######################################
# 21. remove_old_ssh_known_hosts
######################################

def is_host_reachable(host):
    # Restore reachability check
    try:
        # DNS
        subprocess.check_call(["getent", "hosts", host], stdout=subprocess.DEVNULL)
        # Ping
        subprocess.check_call(["ping", "-c", "1", "-W", "1", host], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except:
        return False

def remove_old_ssh_known_hosts():
    kh = os.path.expanduser("~/.ssh/known_hosts")
    if not os.path.exists(kh): return
    
    log_and_print(f"{INFO} checking known_hosts connectivity...", "info")
    with open(kh, "r") as f:
        lines = f.readlines()
    
    valid = []
    for line in lines:
        parts = line.split()
        if not parts: continue
        host = parts[0].split(",")[0]
        # Ignore hashed hosts or IP ranges for simple check
        if is_host_reachable(host):
            valid.append(line)
        else:
            logging.info(f"Removing unreachable: {host}")
    
    with open(kh, "w") as f:
        f.writelines(valid)
    log_and_print(f"{SUCCESS} Done.", "info")


###############################
# 22. remove_orphan_vim_undo
###############################

def remove_orphan_vim_undo_files():
    log_and_print(f"{INFO} Removing orphan .un~ files...", "info")
    base = os.path.expanduser("~")
    for root, _, files in os.walk(base):
        for f in files:
            if f.endswith(".un~"):
                # .filename.un~ -> filename
                orig = f.lstrip(".").replace(".un~", "")
                full_orig = os.path.join(root, orig)
                if not os.path.exists(full_orig):
                    try:
                        os.remove(os.path.join(root, f))
                        print(f"Removed {f}")
                    except: pass


