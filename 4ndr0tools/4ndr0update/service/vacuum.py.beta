##########################################
# 24. configure_zram
##########################################

def configure_zram():
    log_and_print(f"{INFO} Configuring ZRam...", "info")
    if os.path.exists("/usr/lib/systemd/system/zram-generator.service"):
        log_and_print("Systemd zram-generator detected. Skipping.", "info")
        return

    if not shutil.which("zramctl"):
        log_and_print("zramctl missing.", "error")
        return

    # Calculate RAM safely without shell injection
    try:
        mem_kb = 0
        with open("/proc/meminfo", "r") as f:
            for l in f:
                if l.startswith("MemTotal:"):
                    mem_kb = int(l.split()[1])
                    break
        if mem_kb == 0: raise ValueError
        
        size = int((mem_kb * 1024) * 0.25)
        
        res = subprocess.run(["sudo", "zramctl", "--find", "--size", str(size)], capture_output=True, text=True, check=True)
        dev = res.stdout.strip()
        subprocess.run(["sudo", "mkswap", dev], check=True)
        subprocess.run(["sudo", "swapon", dev, "-p", "32767"], check=True)
        log_and_print(f"{SUCCESS} ZRam enabled on {dev}", "info")
    except Exception as e:
        log_and_print(f"{FAILURE} ZRam setup failed: {e}", "error")


############################################
# 25. check_zram_configuration
############################################

def check_zram_configuration():
    execute_command(["zramctl"])
    execute_command(["swapon", "--show"])


###################################
# 26. adjust_swappiness
###################################

def adjust_swappiness(val=133, force=False):
    conf = "/etc/sysctl.d/99-swappiness.conf"
    if not force and os.path.exists(conf):
        log_and_print("Swappiness managed by config. Skipping.", "info")
        return
    execute_command(["sudo", "sysctl", f"vm.swappiness={val}"])


################################
# 27. clear_system_cache
################################

def clear_system_cache(confirm=True):
    if confirm:
        if prompt_with_timeout("Clear system cache (performance impact)? [y/N]: ", persistent=True).lower() != "y":
            return
    subprocess.run(["sudo", "sh", "-c", "echo 3 > /proc/sys/vm/drop_caches"])
    log_and_print(f"{SUCCESS} Caches dropped.", "info")


#####################################
# 28. disable_unused_services
#####################################

def disable_unused_services(services=None, reversible=True):
    if not services:
        services = ["cups", "avahi-daemon", "geoclue", "bluetooth"]
    
    log_and_print(f"{INFO} Disabling services: {services}", "info")
    
    backup = None
    if reversible:
        backup = os.path.join(LOG_BASE_DIR, f"services_backup_{int(time.time())}.txt")
        with open(backup, "w") as f: f.write("Enabled services:\n")

    for s in services:
        # check status
        res = subprocess.run(["systemctl", "is-enabled", s], capture_output=True, text=True)
        if "enabled" in res.stdout:
            subprocess.run(["sudo", "systemctl", "disable", "--now", s])
            log_and_print(f"Disabled {s}", "info")
            if backup:
                with open(backup, "a") as f: f.write(s + "\n")


##################################
# 29. check_and_restart_systemd_units
##################################

def check_and_restart_systemd_units():
    log_and_print(f"{INFO} Checking failed units...", "info")
    res = subprocess.run(["systemctl", "--failed"], capture_output=True, text=True)
    print(res.stdout)
    
    subprocess.run(["sudo", "systemctl", "reset-failed"])
    
    # Parse for specific restarts
    lines = res.stdout.splitlines()
    for l in lines:
        if "loaded failed" in l:
            unit = l.split()[0] # basic parse
            if prompt_with_timeout(f"Restart {unit}? [y/N]: ", persistent=True).lower() == "y":
                subprocess.run(["sudo", "systemctl", "restart", unit])


###################################
# 30. security_audit
###################################

def security_audit():
    log_and_print(f"{INFO} Network Audit...", "info")
    
    # 1. Ports
    execute_command(["sudo", "ss", "-tulnp"])
    
    # 2. Tun0 check
    if os.path.exists("/sys/class/net/tun0"):
        log_and_print(f"{SUCCESS} VPN Active.", "info")
    else:
        log_and_print(f"{WARNING} VPN INACTIVE.", "warning")

    # 3. Nmap if available, else python scan
    target = "127.0.0.1"
    if shutil.which("nmap"):
        subprocess.run(["sudo", "nmap", "-sT", "-p-", target])
    else:
        log_and_print(f"{INFO} Nmap missing, using socket scan...", "info")
        for port in [22, 80, 443, 9665, 9666]:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.settimeout(0.5)
                if s.connect_ex((target, port)) == 0:
                    print(f"Port {port} OPEN")


#######################################
# 31. manage_users_and_groups
#######################################

def manage_users_and_groups():
    # Restore full interactive menu
    while True:
        print("\n1) View Groups\n2) Add User to Group\n3) Remove User\n4) Apply Standard\n5) Enable Wheel\n6) Exit")
        c = input("Choice: ").strip()
        
        if c == "6": break
        elif c == "1":
            u = input("User: ").strip()
            subprocess.run(["id", u])
        elif c == "2":
            u = input("User: ").strip()
            subprocess.run(["cat", "/etc/group"])
            g = input("Group: ").strip()
            subprocess.run(["sudo", "usermod", "-aG", g, u])
        elif c == "3":
            u = input("User: ").strip()
            g = input("Group: ").strip()
            subprocess.run(["sudo", "gpasswd", "-d", u, g])
        elif c == "4":
            u = input("User: ").strip()
            # Standard arch groups
            grps = "adm,disk,wheel,audio,video,optical,storage,lp,network,power"
            subprocess.run(["sudo", "usermod", "-aG", grps, u])
        elif c == "5":
            # Enable wheel in sudoers via drop-in
            p = "/etc/sudoers.d/wheel"
            if not os.path.exists(p):
                with open("/tmp/wheel", "w") as f: f.write("%wheel ALL=(ALL) ALL\n")
                subprocess.run(["sudo", "mv", "/tmp/wheel", p])
                subprocess.run(["sudo", "chmod", "440", p])


####################################
# 32. configure_firewall
####################################

def configure_firewall():
    if not shutil.which("ufw"):
        print("Install ufw.")
        return

    if prompt_with_timeout("Reset UFW? [y/N]: ", persistent=True).lower() == "y":
        subprocess.run(["sudo", "ufw", "reset"])
        subprocess.run(["sudo", "ufw", "default", "deny", "incoming"])
        subprocess.run(["sudo", "ufw", "default", "allow", "outgoing"])
        
        if prompt_with_timeout("Allow SSH? [Y/n]: ", default="Y").lower() == "y":
             subprocess.run(["sudo", "ufw", "allow", "ssh"])
             
        subprocess.run(["sudo", "ufw", "enable"])


####################################
# 33. monitor_system_logs
