def monitor_system_logs(priority=3):
    try:
        subprocess.run(["journalctl", f"-p{priority}", "-xb", "-f"])
    except KeyboardInterrupt:
        pass


####################################
# 34. generate_system_report
####################################

def generate_system_report(fmt="json"):
    log_and_print(f"{INFO} Generating Report...", "info")
    data = {}
    data["uname"] = os.uname().release
    
    if shutil.which("lshw"):
        res = subprocess.run(["sudo", "lshw", "-json"], capture_output=True, text=True)
        try: data["lshw"] = json.loads(res.stdout)
        except: data["lshw"] = "error"
        
    if shutil.which("inxi"):
        data["inxi"] = subprocess.getoutput("inxi -Fxxxz")

    out = os.path.join(LOG_BASE_DIR, "system_report.json")
    with open(out, "w") as f:
        json.dump(data, f, indent=2)
    log_and_print(f"{SUCCESS} Saved to {out}", "info")


