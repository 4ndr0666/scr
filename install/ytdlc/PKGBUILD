pkgname=ytdlc-protocol
pkgver=2.2.0
pkgrel=1
pkgdesc="ytdl:// protocol handler — yt-dlp + aria2 + dmenu + cookie-aware Zsh functions"
arch=('any')
url="https://github.com/4ndr0666/ytdlc-protocol"
license=('MIT')
depends=(
    'yt-dlp'
    'aria2'
    'dmenu'
    'fzf'
    'wl-clipboard'
    'xclip'
    'zathura'
    'nsxiv'
    'curl'
    'zsh'
    'python'
)
optdepends=(
    'mpv: media playback via dmenuhandler'
    'swaybg: wallpaper setting via dmenuhandler setbg action'
    'lynx: terminal browser action in dmenuhandler'
)
source=(
    'ytdlc_protocol_installer.sh'
    'configure'
)
sha256sums=(
    'SKIP'
    'SKIP'
)

package() {
    install -Dm755 "$srcdir/ytdlc_protocol_installer.sh" "$pkgdir/usr/bin/ytdlc-install"
    install -Dm755 "$srcdir/configure"                   "$pkgdir/usr/bin/ytdlc-test"
}
