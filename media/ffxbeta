#!/usr/bin/env bash
# shellcheck disable=SC2207,SC2034,SC2155,SC2317
# 4ndr0666
# Version 2.0
set -euo pipefail
IFS=$'\n\t'
#                                 # === FFX === # 
#
# CONSTANTS
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_RUNTIME_DIR:=${TMPDIR:-/tmp}}"

FFX_CONFIG_DIR="$XDG_CONFIG_HOME/ffx"
FFX_LOG_DIR="$XDG_DATA_HOME/ffx"
FFX_CACHE_DIR="$XDG_CACHE_HOME/ffx"
FFX_DEFAULTS="$FFX_CONFIG_DIR/defaults"
FFX_RUN_DIR="$(mktemp -d -p "${XDG_RUNTIME_DIR}" "ffx.XXXXXXXX")"
LOG_FILE="$FFX_LOG_DIR/ffx.log"

mkdir -p "$FFX_CONFIG_DIR" "$FFX_LOG_DIR" "$FFX_CACHE_DIR"

if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
	CYAN="$(tput setaf 6)"
	GREEN="$(tput setaf 2)"
	BOLD="$(tput bold)"
	RED="$(tput setaf 1)"
	YELLOW="$(tput setaf 3)"
	RESET="$(tput sgr0)"
else
	CYAN="" GREEN="" BOLD="" RED="" YELLOW="" RESET=""
fi

say()         { printf '%b[OK] %s%b\n'    "${GREEN}${BOLD}" "$1" "${RESET}";      }
warn()        { printf '%b[!!] %s%b\n'    "${YELLOW}"       "$1" "${RESET}" >&2; }
die()         { printf '%b[XX] Error: %s%b\n' "${RED}"       "$1" "${RESET}" >&2; exit 1; }
verbose_log() { [[ "${VERBOSE_MODE:-false}" == true ]] && printf '[INFO] %s\n' "$1" >&2 || true; }
debug_log()   { [[ "${FFX_DEBUG:-0}" == "1" ]] && printf '[DEBUG] %s\n' "$1" >&2 || true; }

cleanup_all() { [[ -d "${FFX_RUN_DIR:-}" ]] && rm -rf -- "$FFX_RUN_DIR"; }
trap 'cleanup_all' EXIT INT TERM HUP

mktemp_ffx() { mktemp -p "$FFX_RUN_DIR" --suffix="${1:-.tmp}"; }

CANVAS_W=1920
CANVAS_H=1080

default_config() {
	ADVANCED_MODE=false
	VERBOSE_MODE=false
	DRY_RUN=false
	BULK_MODE=false
	REMOVE_AUDIO=false
	COMPOSITE_MODE=false
	MAX_1080=false
	INTERPOLATE=false
	GLOBAL_OUTPUT_FILE=""

	OUTPUT_DIR="$(pwd)"
	SPECIFIC_FPS=""
	PTS_FACTOR=""

	FFX_TIMEOUT="${FFX_TIMEOUT:-300}"

	ADV_CONTAINER="mp4"
	ADV_RES="${CANVAS_W}x${CANVAS_H}"
	ADV_FPS="60"
	ADV_CODEC="libx264"
	ADV_PIX_FMT="yuv420p"
	ADV_CRF="18"
	ADV_BR="10M"
	ADV_MULTIPASS="false"
	ADV_QUALITY_MODE="crf"
}
default_config
REMAINING_ARGS=()

save_defaults() {
	mkdir -p "$FFX_CONFIG_DIR"
	printf '%s\n' \
		"ADV_CONTAINER=$ADV_CONTAINER"       \
		"ADV_RES=$ADV_RES"                   \
		"ADV_FPS=$ADV_FPS"                   \
		"ADV_CODEC=$ADV_CODEC"               \
		"ADV_PIX_FMT=$ADV_PIX_FMT"           \
		"ADV_CRF=$ADV_CRF"                   \
		"ADV_BR=$ADV_BR"                     \
		"ADV_MULTIPASS=$ADV_MULTIPASS"       \
		"ADV_QUALITY_MODE=$ADV_QUALITY_MODE" \
		> "$FFX_DEFAULTS"
}

load_defaults() {
	[[ -f "$FFX_DEFAULTS" ]] || return 0
	local key value
	while IFS='=' read -r key value || [[ -n "$key" ]]; do
		[[ "$key" =~ ^ADV_[A-Z_]+$ && -n "$value" ]] && printf -v "$key" '%s' "$value"
	done < "$FFX_DEFAULTS"
}

command_exists() { command -v "$1" >/dev/null 2>&1; }
is_nonneg_int() { [[ "${1:-}" =~ ^[0-9]+$ ]]; }

_try_install() {
	local pkg="$1"
	if command_exists pacman;   then sudo pacman -S --noconfirm --needed "$pkg" 2>/dev/null && return 0; fi
	if command_exists apt-get;  then sudo apt-get install -y "$pkg" 2>/dev/null && return 0; fi
	if command_exists dnf;      then sudo dnf install -y "$pkg" 2>/dev/null && return 0; fi
	if command_exists zypper;   then sudo zypper install -y "$pkg" 2>/dev/null && return 0; fi
	if command_exists brew;     then brew install "$pkg" 2>/dev/null && return 0; fi
	return 1
}

check_deps() {
	local dep pkg missing_hard=""
	declare -A dep_pkg=(
		[ffmpeg]="ffmpeg"   [ffprobe]="ffmpeg"
		[bc]="bc"           [awk]="gawk"
	)
	for dep in ffmpeg ffprobe bc awk; do
		if ! command_exists "$dep"; then
			pkg="${dep_pkg[$dep]:-$dep}"
			warn "Missing dependency: $dep — attempting install of '$pkg'..."
			if _try_install "$pkg" && command_exists "$dep"; then
				say "Installed: $dep"
			else
				missing_hard+=" $dep"
			fi
		fi
	done
	[[ -z "$missing_hard" ]] \
		|| die "Cannot satisfy required dependencies:${missing_hard}. Install them and retry."
}

absolute_path() {
	readlink -f "$1" 2>/dev/null \
		|| realpath "$1" 2>/dev/null \
		|| ( cd "$(dirname "$1")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$1")" )
}

bytes_to_human() {
	awk -v b="${1:-0}" 'BEGIN{
		split("B KiB MiB GiB",u); i=1
		while(b>=1024 && i<4){b/=1024; i++}
		printf "%.2f %s\n", b, u[i]
	}'
}

get_default_filename() {
	local base="${1:-out}" suffix="${2:-tmp}" ext="${3:-mp4}"
	local candidate="${OUTPUT_DIR}/${base}_${suffix}.${ext}" n=1
	while [[ -e "$candidate" ]]; do
		candidate="${OUTPUT_DIR}/${base}_${suffix}_${n}.${ext}"
		(( n++ )) || true
	done
	printf '%s' "$candidate"
}

fzf_pick() {
	command_exists fzf || die "fzf is not installed. Install it for interactive file selection."
	local -a sel
	mapfile -t sel < <(fzf --multi)
	(( ${#sel[@]} > 0 )) || die "No selection made."
	printf '%s\n' "${sel[@]}"
}

apply_bulk_glob() {
	local dir="$1"
	find "$dir" -maxdepth 1 -type f \( \
		-iname '*.mp4' -o -iname '*.mkv' -o -iname '*.mov' \
		-o -iname '*.avi' -o -iname '*.webm' -o -iname '*.gif' \
		-o -iname '*.ts'  -o -iname '*.m4v' \) -print
}

detect_max_res() {
	local max_w=0 max_h=0
	for _f; do
		local w=0 h=0
		read -r w h < <(ffprobe -v error -select_streams v:0 \
			-show_entries stream=width,height \
			-of default=nw=1:nk=1 "$_f" 2>/dev/null | xargs) || true
		[[ "$w" =~ ^[0-9]+$ ]] || w=0
		[[ "$h" =~ ^[0-9]+$ ]] || h=0
		((w > max_w)) && max_w=$w
		((h > max_h)) && max_h=$h
	done
	printf '%d %d\n' "$max_w" "$max_h"
}

shuffle_files() {
	local -n _sf="$1"
	if command_exists shuf; then
		mapfile -t _sf < <(printf '%s\n' "${_sf[@]}" | shuf)
	else
		local i j tmp n="${#_sf[@]}"
		for (( i=n-1; i>0; i-- )); do
			j=$(( RANDOM % (i+1) ))
			tmp="${_sf[$i]}"; _sf[$i]="${_sf[$j]}"; _sf[$j]="$tmp"
		done
	fi
}

get_audio_opts_array() {
	if [[ "$REMOVE_AUDIO" == true ]]; then
		printf '%s\n' "-an"
	else
		printf '%s\n' "-c:a" "copy"
	fi
}

# run_ffmpeg — CONTRACT: returns 0 on success, 1 on failure (timeout or non-zero exit).
# Every call site MUST check the return value and call die() or handle the error explicitly.
# Example: run_ffmpeg ... || die "description of what failed"
run_ffmpeg() {
	if [[ "$DRY_RUN" == true ]]; then
		printf '[DRY-RUN] ffmpeg'; printf ' %q' "$@"; printf '\n'
		return 0
	fi

	local -a base=("ffmpeg" "-hide_banner")
	local ec=0 use_to=false
	command_exists timeout && [[ "${FFX_TIMEOUT:-0}" -gt 0 ]] && use_to=true

	if [[ "$VERBOSE_MODE" == true ]]; then
		base+=("-v" "info")
		if [[ "$use_to" == true ]]; then
			timeout "$FFX_TIMEOUT" "${base[@]}" "$@" 2>&1 | tee -a "$LOG_FILE"; ec=${PIPESTATUS[0]}
		else
			"${base[@]}" "$@" 2>&1 | tee -a "$LOG_FILE"; ec=${PIPESTATUS[0]}
		fi
	else
		base+=("-v" "error")
		: > "$LOG_FILE"
		if [[ "$use_to" == true ]]; then
			timeout "$FFX_TIMEOUT" "${base[@]}" "$@" >> "$LOG_FILE" 2>&1; ec=$?
		else
			"${base[@]}" "$@" >> "$LOG_FILE" 2>&1; ec=$?
		fi
	fi

	if (( ec == 124 )); then
		warn "FFmpeg timed out after ${FFX_TIMEOUT}s. Use --timeout to extend."
		tail -n 20 "$LOG_FILE" >&2 || true; return 1
	elif (( ec != 0 )); then
		warn "FFmpeg failed (exit ${ec}). Log: $LOG_FILE"
		tail -n 20 "$LOG_FILE" >&2 || true; return 1
	fi
	return 0
}

probe_wh() {
	local _w=0 _h=0
	read -r _w _h < <(
		ffprobe -v error -select_streams v:0 \
			-show_entries stream=width,height \
			-of default=nw=1:nk=1 "$1" 2>/dev/null | xargs
	) || true
	[[ "$_w" =~ ^[0-9]+$ ]] || _w=$CANVAS_W
	[[ "$_h" =~ ^[0-9]+$ && "$_h" -gt 0 ]] || _h=$CANVAS_H
	printf '%d %d' "$_w" "$_h"
}

probe_duration() {
	ffprobe -v error -show_entries format=duration \
		-of default=noprint_wrappers=1:nokey=1 "$1" 2>/dev/null || echo "60"
}

check_container_first() {
	ffprobe -v error -show_entries format=format_name -of default=noprint_wrappers=1:nokey=1 "$1" 2>/dev/null | awk -F, '{print $1}'
}

get_fps() {
	local f="$1" s=""
	s="$(ffprobe -v quiet -select_streams v:0 \
		-show_entries stream=avg_frame_rate \
		-of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null || true)"
	if [[ -z "$s" || "$s" == "0/0" ]]; then
		s="$(ffprobe -v quiet -select_streams v:0 \
			-show_entries stream=r_frame_rate \
			-of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null || true)"
	fi
	if [[ -z "$s" || "$s" == "0/0" ]]; then
		printf '%s' "$ADV_FPS"; return
	fi
	[[ "$s" == *"/"* ]] \
		&& { bc -l <<< "scale=4; $s" 2>/dev/null || printf '%s' "$ADV_FPS"; } \
		|| printf '%s' "$s"
}

is_interlaced() {
	local o
	o="$(ffprobe -v error -select_streams v:0 -show_entries stream=field_order \
		-of default=noprint_wrappers=1:nokey=1 "$1" 2>/dev/null || echo progressive)"
	case "$o" in tt|bb|tb|bt|bt_tb|bt_bt|tb_tb|tb_bt) return 0 ;; *) return 1 ;; esac
}

get_deinterlace_filter() { is_interlaced "$1" && echo "yadif=deint=interlaced" || echo "null"; }

check_moov_atom() {
	ffprobe -v error -show_entries format=duration \
		-of default=noprint_wrappers=1:nokey=1 "$1" >/dev/null 2>&1
}

moov_fallback() {
	local in="$1" out="$2"
	local -a aopts; mapfile -t aopts < <(get_audio_opts_array)
	verbose_log "moov_fallback: re-encoding '$(basename "$in")'"
	local -a enc
	if [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]]; then
		enc=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "medium")
	else
		enc=("-c:v" "$ADV_CODEC" "-crf" "${ADV_CRF:-18}" "-preset" "medium")
	fi
	run_ffmpeg -y -i "$in" "${enc[@]}" "${aopts[@]}" -movflags +faststart "$out" \
		|| die "moov_fallback failed for '$(basename "$in")'"
}

check_dts_for_file() {
	ffprobe -v error -select_streams v \
		-show_entries frame=pkt_dts_time \
		-of csv=p=0 "$1" 2>/dev/null |
	awk 'NR==1{p=$1;next} $1!="" && $1+0 < p+0 {exit 1} $1!=""{p=$1}'
}

fix_dts() {
	local file="$1" tmpf
	tmpf="$(mktemp_ffx .mp4)"
	local -a aopts; mapfile -t aopts < <(get_audio_opts_array)
	if ! run_ffmpeg -y -fflags +genpts -i "$file" \
			-c:v copy "${aopts[@]}" -movflags +faststart "$tmpf"; then
		verbose_log "DTS remux failed; lossless re-encode for '$(basename "$file")'"
		run_ffmpeg -y -fflags +genpts -i "$file" \
			-c:v "$ADV_CODEC" -qp 0 -preset ultrafast \
			"${aopts[@]}" "$tmpf" || return 1
	fi
	printf '%s' "$tmpf"
}

ensure_dts_correct() {
	local file="$1"
	[[ -f "$file" ]] || die "ensure_dts_correct: '$file' not found."
	if ! check_dts_for_file "$file"; then
		verbose_log "DTS issues detected in '$(basename "$file")'. Fixing..."
		local fixed
		fixed="$(fix_dts "$file")" || return 1
		[[ -s "$fixed" ]] || die "DTS fix produced empty output for '$(basename "$file")'."
		printf '%s' "$fixed"
	else
		printf '%s' "$file"
	fi
}

auto_clean() {
	local file="$1"
	[[ -z "$file" || ! -f "$file" ]] && return 0
	local tmpf; tmpf="$(mktemp_ffx .mp4)"
	if run_ffmpeg -y -i "$file" -map_metadata -1 -c copy "$tmpf"; then
		mv "$tmpf" "$file"
		verbose_log "Metadata stripped: '$(basename "$file")'"
	else
		rm -f "$tmpf" 2>/dev/null || true
		verbose_log "Metadata strip skipped — kept original '$(basename "$file")'."
	fi
}

# =============================================================================
# SELF-AUDIT ENGINE 
# =============================================================================
FFX_VERSION="${FFX_VERSION:-6.0.0}"
FFX_SEGMENT_LINES="${FFX_SEGMENT_LINES:-500}"
FFX_MANIFEST_DIR="$FFX_CACHE_DIR/manifests"

hash_file() { sha256sum "$1" | awk '{print $1}'; }

generate_manifest() {
	local src="$1" ts overall tmpdir
	command_exists sha256sum || die "sha256sum required for manifest generation."
	command_exists split    || die "split required for manifest generation."
	ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
	overall="$(hash_file "$src")"
	tmpdir="$(mktemp -d -p "$FFX_RUN_DIR" ffx_manifest.XXXXXX)"
	split -l "$FFX_SEGMENT_LINES" "$src" "$tmpdir/seg_"
	printf '{\n'
	printf '  "version": "%s",\n'        "$FFX_VERSION"
	printf '  "timestamp": "%s",\n'      "$ts"
	printf '  "overall_sha256": "%s",\n' "$overall"
	printf '  "segments": {\n'
	local first=true idx=0
	for seg in "$tmpdir"/seg_*; do
		local h; h="$(hash_file "$seg")"
		[[ "$first" == true ]] || printf ',\n'
		first=false
		printf '    "%d": "%s"' "$idx" "$h"
		idx=$(( idx + 1 ))
	done
	printf '\n  }\n}\n'
	rm -rf "$tmpdir"
}

save_manifest() {
	mkdir -p "$FFX_MANIFEST_DIR"
	local out="$FFX_MANIFEST_DIR/${FFX_VERSION}.json"
	generate_manifest "${BASH_SOURCE[0]}" > "$out"
	say "Manifest saved: $out"
}

verify_superset() {
	local canon="$FFX_MANIFEST_DIR/${FFX_VERSION}.json"
	[[ -f "$canon" ]] || { verbose_log "No manifest found; skipping verify."; return 0; }
	local tmp; tmp="$(mktemp -p "$FFX_RUN_DIR" ffx_verify.XXXXXX)"
	generate_manifest "${BASH_SOURCE[0]}" > "$tmp"
	local old new
	old="$(awk -F'"' '/overall_sha256/{print $4}' "$canon")"
	new="$(awk -F'"' '/overall_sha256/{print $4}' "$tmp")"
	[[ "$old" == "$new" ]] || die "INTEGRITY FAILURE: overall hash regressed. Run 'ffx manifest save' to re-baseline."
	if command_exists jq; then
		local keys; keys="$(jq -r '.segments | keys[]' "$canon" 2>/dev/null || true)"
		for k in $keys; do
			local o n
			o="$(jq -r ".segments[\"$k\"]" "$canon")"
			n="$(jq -r ".segments[\"$k\"]" "$tmp" 2>/dev/null || true)"
			[[ -n "$n" ]] || die "INTEGRITY FAILURE: segment $k missing."
			[[ "$o" == "$n" ]] || die "INTEGRITY FAILURE: segment $k regressed."
		done
	fi
	rm -f "$tmp"
	say "Integrity verified: ${FFX_VERSION}"
}

cmd_manifest() {
	local action="${1:-show}"
	mkdir -p "$FFX_MANIFEST_DIR"
	case "$action" in
		save)   save_manifest ;;
		verify) verify_superset ;;
		show)   generate_manifest "${BASH_SOURCE[0]}" ;;
		*)      die "manifest: unknown action '$action'. Use: save | verify | show" ;;
	esac
}

advanced_prompt() {
	[[ "$ADVANCED_MODE" != true ]] && return 0
	load_defaults
	printf '%b* Advanced Mode%b -- press Enter to keep current value.\n' "${CYAN}${BOLD}" "${RESET}"
	local inp

	read -r -p "Container [mp4/mkv/mov] (${ADV_CONTAINER}): " inp
	[[ -n "$inp" ]] && ADV_CONTAINER="$inp"

	read -r -p "Resolution e.g. 1920x1080 (${ADV_RES}): " inp
	if [[ -n "$inp" ]]; then
		[[ "$inp" =~ ^[0-9]+x[0-9]+$ ]] && ADV_RES="$inp" \
			|| warn "Invalid resolution; keeping ${ADV_RES}."
	fi

	read -r -p "Frame rate [24/30/60/120] (${ADV_FPS}): " inp
	if [[ -n "$inp" ]]; then
		[[ "$inp" =~ ^[0-9]+(\.[0-9]+)?$ ]] && ADV_FPS="$inp" \
			|| warn "Invalid FPS; keeping ${ADV_FPS}."
	fi

	read -r -p "Codec [libx264/libx265] (${ADV_CODEC}): " inp
	[[ -n "$inp" ]] && ADV_CODEC="$inp"

	read -r -p "Pixel format [yuv420p/yuv422p] (${ADV_PIX_FMT}): " inp
	[[ -n "$inp" ]] && ADV_PIX_FMT="$inp"

	read -r -p "Quality mode [crf/qp0] (${ADV_QUALITY_MODE}): " inp
	if [[ -n "$inp" ]]; then
		case "${inp,,}" in
			crf) ADV_QUALITY_MODE="crf" ;;
			qp0) ADV_QUALITY_MODE="qp0" ;;
			*)   warn "Invalid quality mode; keeping ${ADV_QUALITY_MODE}." ;;
		esac
	fi

	if [[ "$ADV_QUALITY_MODE" == "crf" ]]; then
		read -r -p "CRF 0-51 — 18=near-lossless, 23=default (${ADV_CRF}): " inp
		if [[ -n "$inp" ]]; then
			[[ "$inp" =~ ^[0-9]+$ ]] && (( inp >= 0 && inp <= 51 )) \
				&& ADV_CRF="$inp" || warn "CRF must be 0-51; keeping ${ADV_CRF}."
		fi
		read -r -p "Bitrate e.g. 10M (${ADV_BR}): " inp
		if [[ -n "$inp" ]]; then
			[[ "$inp" =~ ^[0-9]+[kKmMgG]?$ ]] && ADV_BR="$inp" \
				|| warn "Invalid bitrate; keeping ${ADV_BR}."
		fi
		read -r -p "Multi-pass? (y/N): " inp
		[[ "${inp,,}" =~ ^y ]] && ADV_MULTIPASS="true" || ADV_MULTIPASS="false"
	else
		ADV_CRF="18"; ADV_BR="10M"; ADV_MULTIPASS="false"
		say "Lossless mode (qp=0): CRF/bitrate/multipass ignored."
	fi

	save_defaults
	printf '%b[config]%b container=%s res=%s fps=%s codec=%s pix=%s quality=%s crf=%s\n' \
		"${CYAN}" "${RESET}" \
		"$ADV_CONTAINER" "$ADV_RES" "$ADV_FPS" \
		"$ADV_CODEC" "$ADV_PIX_FMT" "$ADV_QUALITY_MODE" "$ADV_CRF"
}

cell_vf() {
	local cw="$1" ch="$2"
	printf 'fps=%d,setpts=PTS-STARTPTS,scale=%d:%d:flags=lanczos:force_original_aspect_ratio=decrease,pad=%d:%d:-1:-1:color=black,setsar=1' \
		"${ADV_FPS}" "$cw" "$ch" "$cw" "$ch"
}

ar_score() {
	awk -v vw="$1" -v vh="$2" -v cw="$3" -v ch="$4" '
		BEGIN {
			if (vh<=0||ch<=0) { print 0; exit }
			r = (vw/vh) / (cw/ch)
			if (r<1) r=1/r
			printf "%d", int(100/r)
		}'
}

readonly _AWK_SORT_BY_AR='
	{ idx[NR]=$1; ar[NR]=$2/$3; n=NR }
	END {
		for (i=2;i<=n;i++) {
			ki=idx[i]; ka=ar[i]; j=i-1
			while(j>=1&&ar[j]>ka){idx[j+1]=idx[j];ar[j+1]=ar[j];j--}
			idx[j+1]=ki; ar[j+1]=ka
		}
		for(k=1;k<=n;k++) printf "%d ",idx[k]
	}'

