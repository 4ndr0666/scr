#!/usr/bin/env bash
# shellcheck disable=SC2034
#
# n_m3u8dl_orchestrator.sh
# Ψ-4ndr0666 High-Performance Stream Extraction Matrix (v3.1.1)
#
# AUDIT CHANGELOG (v3.1.0 → v3.1.1):
#   CRITICAL D16 - SAVE_DIR contained a stray '$' before the leading slash:
#                  SAVE_DIR="$/s1/streamdir". Bash does not treat a bare '$'
#                  followed by '/' as an expansion — there is no valid
#                  identifier, '{', '(', or special parameter after it — so
#                  the '$' is passed through LITERALLY as the first character
#                  of the string. The resulting value was the literal text
#                  "$/s1/streamdir", a RELATIVE path beginning with a folder
#                  named "$". Every mkdir -p "$SAVE_DIR" call (via
#                  ensure_writable_dir) therefore created "./$/s1/streamdir"
#                  relative to wherever the script was invoked from — this is
#                  the root cause of the mystery "$" directory. Corrected to
#                  an absolute, unambiguous default: "$HOME/streamdir". Also
#                  restored check_dependencies in the boot sequence, which
#                  this revision had reverted to commented-out (reintroducing
#                  D3/D13), and reverted BIN_M3U8's hardcoded absolute path
#                  back to empty so check_dependencies remains sole authority.
#
# AUDIT CHANGELOG (v3.0.0 → v3.1.0):
#   CRITICAL D1  - BIN_M3U8 hardcoded default removed; check_dependencies is
#                  now the sole authority on BIN_M3U8 assignment.
#   CRITICAL D2  - CONFIG_DIR undefined variable; derived from CONFIG_FILE.
#   CRITICAL D3  - check_dependencies and load_config uncommented at boot.
#   CRITICAL D9  - --skip-merge and --del-after-done corrected to boolean
#                  switch pattern (consistent with --auto-select).
#   CRITICAL D10 - shift 2 guarded with [[ $# -ge 2 ]] to prevent unbound
#                  variable abort under set -u.
#   HIGH     D4  - execute_extraction return 1 replaced with explicit exit-
#                  code capture; callers no longer rely on implicit propagation.
#   HIGH     D13 - Boot sequence guarantees check_dependencies + load_config
#                  execute before any extraction path (CLI or interactive).
#   MEDIUM   D5  - Preset URLs stored separately from display labels;
#                  awk dependency eliminated.
#   MEDIUM   D7  - TMP_DIR default changed to XDG_CACHE_HOME-derived path
#                  with PID-scoped subdirectory for isolation.
#   MEDIUM   D6  - THREAD_COUNT and RETRY_COUNT validated as positive integers
#                  before acceptance.
#   LOW      D8  - SAVE_DIR write-permission verification added post-mkdir.
#   LOW      D11 - SC2154 suppression removed; D1 fix makes it unnecessary.
#   LOW      D15 - configure_advanced wrapped in while loop for UX parity.

set -euo pipefail

# -----------------------------------------------------------------------------
# Global State & XDG Configuration
# -----------------------------------------------------------------------------
# D2 FIX: CONFIG_DIR derived from CONFIG_FILE to eliminate undefined variable.
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/m3u8/m3u8.conf"
CONFIG_DIR="${CONFIG_FILE%/*}"

# Core Defaults
THREAD_COUNT=8
RETRY_COUNT=5
# D7 FIX: TMP_DIR scoped under XDG_CACHE_HOME with PID isolation.
# /s4/tmp/ was a system-specific hardcode with no portability guarantee.
TMP_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/m3u8dl/$$"
# D16 FIX: Stray '$' before the leading slash made this a literal relative
# path "$/s1/streamdir" — bash does not expand a bare '$' with no identifier
# following it, so it passed through as a literal character. mkdir -p then
# created a directory literally named "$" in the CWD. Corrected to an
# absolute, unambiguous default under $HOME.
SAVE_DIR="$HOME/streamdir"
SAVE_NAME=""
PROXY_URL=""

# Boolean Toggles
# D9 NOTE: --skip-merge and --del-after-done are boolean SWITCHES in
# N_m3u8DL-RE — they take no argument. Stored as True/False here for
# conditional emission only, matching the pattern of --auto-select.
AUTO_SELECT="True"
SKIP_MERGE="False"
DEL_AFTER_DONE="True"
USE_FFMPEG_CONCAT="False"
LIVE_REAL_TIME_MERGE="False"
LIVE_PERFORM_AS_VOD="False"

# Execution Target
TARGET_URL=""

# D1 FIX: BIN_M3U8 intentionally unset here. check_dependencies is the
# sole assignment authority and will populate this once the binary is found.
# D16 FIX: this revision had reintroduced a hardcoded absolute path here
# ("/usr/bin/n-m3u8dl-re"), which silently bypasses check_dependencies'
# detection if that exact path doesn't exist on the user's system (e.g.
# installed elsewhere, or named with the canonical "N_m3u8DL-RE" casing).
# Reverted to empty string.
BIN_M3U8=""

# -----------------------------------------------------------------------------
# Theming & Formatting
# -----------------------------------------------------------------------------
C_RED='\033[1;31m'
C_GREEN='\033[1;32m'
C_CYAN='\033[1;36m'
C_YELLOW='\033[1;33m'
C_RESET='\033[0m'

print_info()    { echo -e "${C_CYAN}[Ψ] $1${C_RESET}"; }
print_success() { echo -e "${C_GREEN}[+] $1${C_RESET}"; }
print_warning() { echo -e "${C_YELLOW}[*] $1${C_RESET}"; }
print_error()   { echo -e "${C_RED}[!] $1${C_RESET}"; }

# -----------------------------------------------------------------------------
# Dependency Management
# -----------------------------------------------------------------------------
check_dependencies() {
	local missing=()

	# D1 FIX: This function is the single point of BIN_M3U8 assignment.
	# No global assignment outside this function.
	if command -v N_m3u8DL-RE >/dev/null 2>&1; then
		BIN_M3U8="N_m3u8DL-RE"
	elif command -v n_m3u8dl-re >/dev/null 2>&1; then
		BIN_M3U8="n_m3u8dl-re"
	else
		missing+=("N_m3u8DL-RE")
	fi

	if ! command -v ffmpeg >/dev/null 2>&1; then
		missing+=("ffmpeg")
	fi

	if [[ ${#missing[@]} -gt 0 ]]; then
		print_error "Critical dependencies missing: ${missing[*]}"
		print_info "Please install them to proceed."
		exit 1
	fi
}

# -----------------------------------------------------------------------------
# Input Validation Helpers
# -----------------------------------------------------------------------------
# D6 FIX: Reusable guard for numeric user inputs.
validate_positive_integer() {
	local val="$1"
	local name="$2"
	if ! [[ "$val" =~ ^[1-9][0-9]*$ ]]; then
		print_error "$name must be a positive integer. Got: '$val'"
		return 1
	fi
}

# D8 FIX: Verify directory is writable after creation.
ensure_writable_dir() {
	local dir="$1"
	mkdir -p "$dir" || { print_error "Cannot create directory: $dir"; return 1; }
	if [[ ! -w "$dir" ]]; then
		print_error "Directory not writable: $dir"
		return 1
	fi
}

# -----------------------------------------------------------------------------
# Configuration Matrix
# -----------------------------------------------------------------------------
load_config() {
	if [[ -f "$CONFIG_FILE" ]]; then
		while IFS='=' read -r key val; do
			# Strip surrounding quotes from value.
			val="${val%\"}"
			val="${val#\"}"
			case "$key" in
			THREAD_COUNT) THREAD_COUNT="$val" ;;
			RETRY_COUNT)  RETRY_COUNT="$val"  ;;
			SAVE_DIR)     SAVE_DIR="$val"      ;;
			TMP_DIR)      TMP_DIR="$val"       ;;
			PROXY_URL)    PROXY_URL="$val"     ;;
			esac
		done < <(grep -E '^[A-Z_]+=' "$CONFIG_FILE")
		print_success "Configuration loaded from $CONFIG_FILE"
	fi
}

save_config() {
	# D2 FIX: CONFIG_DIR is now correctly defined at the top of the script.
	ensure_writable_dir "$CONFIG_DIR" || return 1
	cat <<EOF >"$CONFIG_FILE"
# Ψ-4ndr0666 N_m3u8DL-RE Orchestrator Configuration
THREAD_COUNT="$THREAD_COUNT"
RETRY_COUNT="$RETRY_COUNT"
SAVE_DIR="$SAVE_DIR"
TMP_DIR="$TMP_DIR"
PROXY_URL="$PROXY_URL"
EOF
	print_success "Configuration locked at $CONFIG_FILE"
}

# -----------------------------------------------------------------------------
# Execution Engine (Array-Based)
# -----------------------------------------------------------------------------
execute_extraction() {
	# D4 FIX: Return explicitly named; callers check the return value.
	# execute_extraction never relies on implicit set -e propagation from
	# a nested if/else — the extractor's exit code is captured cleanly.
	if [[ -z "$TARGET_URL" ]]; then
		print_error "Extraction matrix requires a valid TARGET_URL."
		return 1
	fi

	if [[ -z "$BIN_M3U8" ]]; then
		print_error "BIN_M3U8 is unset. Run check_dependencies first."
		return 1
	fi

	print_info "Initiating Stream Extraction Sequence..."
	print_info "Target: $TARGET_URL"
	print_info "Threads: $THREAD_COUNT | Retries: $RETRY_COUNT"

	# D8 FIX: Validate writability before passing dirs to the extractor.
	ensure_writable_dir "$SAVE_DIR" || return 1
	ensure_writable_dir "$TMP_DIR"  || return 1

	# Construct the command array safely.
	local cmd=("$BIN_M3U8" "$TARGET_URL")

	cmd+=(--thread-count          "$THREAD_COUNT")
	cmd+=(--download-retry-count  "$RETRY_COUNT")
	cmd+=(--tmp-dir               "$TMP_DIR")
	cmd+=(--save-dir              "$SAVE_DIR")

	# D9 FIX: --skip-merge and --del-after-done are boolean switches in
	# N_m3u8DL-RE — they accept NO argument. Emitting "--skip-merge False"
	# passes the string "False" as the next positional argument, corrupting
	# the command line. Use the same conditional pattern as --auto-select.
	if [[ "$SKIP_MERGE" == "True" ]]; then
		cmd+=(--skip-merge)
	fi

	if [[ "$DEL_AFTER_DONE" == "True" ]]; then
		cmd+=(--del-after-done)
	fi

	if [[ "$AUTO_SELECT" == "True" ]]; then
		cmd+=(--auto-select)
	fi

	if [[ -n "$SAVE_NAME" ]]; then
		cmd+=(--save-name "$SAVE_NAME")
	fi

	if [[ -n "$PROXY_URL" ]]; then
		cmd+=(--custom-proxy "$PROXY_URL")
	fi

	if [[ "$USE_FFMPEG_CONCAT" == "True" ]]; then
		cmd+=(--use-ffmpeg-concat-demuxer)
	fi

	if [[ "$LIVE_REAL_TIME_MERGE" == "True" ]]; then
		cmd+=(--live-real-time-merge)
	fi

	if [[ "$LIVE_PERFORM_AS_VOD" == "True" ]]; then
		cmd+=(--live-perform-as-vod)
	fi

	print_info "Executing: ${cmd[*]}"

	# D4 FIX: Capture exit code explicitly. The if construct suppresses
	# set -e inside the condition, so the else branch is reachable on failure.
	local exit_code
	"${cmd[@]}"
	exit_code=$?

	if [[ "$exit_code" -eq 0 ]]; then
		print_success "Extraction Complete. Payload secured in $SAVE_DIR"
	else
		print_error "Extraction Failed (exit $exit_code). Check logs and stream validity."
		return "$exit_code"
	fi
}

# -----------------------------------------------------------------------------
# Interactive Interfaces
# -----------------------------------------------------------------------------
configure_advanced() {
	# D15 FIX: Wrapped in while loop for UX parity with interactive_menu.
	# Single-shot in v3.0.0 meant every change bounced the user back to main.
	while true; do
		echo -e "\n${C_CYAN}--- Advanced Configuration Matrix ---${C_RESET}"
		echo "1. Set Thread Count (Current: $THREAD_COUNT)"
		echo "2. Set Retry Count (Current: $RETRY_COUNT)"
		echo "3. Toggle Segment Merge (Skip: $SKIP_MERGE)"
		echo "4. Set Output Directory (Current: $SAVE_DIR)"
		echo "5. Return to Main Menu"
		echo -n "> "
		read -r adv_opt

		case "$adv_opt" in
		1)
			echo -n "Enter Thread Count: "
			read -r input
			# D6 FIX: Validate before accepting.
			if validate_positive_integer "$input" "Thread Count"; then
				THREAD_COUNT="$input"
				print_success "Thread Count set to $THREAD_COUNT"
			fi
			;;
		2)
			echo -n "Enter Retry Count: "
			read -r input
			# D6 FIX: Validate before accepting.
			if validate_positive_integer "$input" "Retry Count"; then
				RETRY_COUNT="$input"
				print_success "Retry Count set to $RETRY_COUNT"
			fi
			;;
		3)
			if [[ "$SKIP_MERGE" == "False" ]]; then
				SKIP_MERGE="True"
			else
				SKIP_MERGE="False"
			fi
			print_success "Skip Merge toggled to: $SKIP_MERGE"
			;;
		4)
			echo -n "Enter Absolute Path for Output: "
			read -r input
			if [[ -n "$input" ]]; then
				# D8 FIX: Validate writability before accepting.
				if ensure_writable_dir "$input"; then
					SAVE_DIR="$input"
					print_success "Output directory set to $SAVE_DIR"
				fi
			else
				print_warning "Path cannot be empty."
			fi
			;;
		5)
			return 0
			;;
		*)
			print_warning "Invalid input."
			;;
		esac
	done
}

interactive_menu() {
	# D5 FIX: URLs and display labels stored separately.
	# awk '{print $1}' on a combined string is fragile and introduces an
	# unnecessary dependency on awk for a pure-Bash operation.
	declare -A preset_urls
	declare -A preset_labels
	preset_urls["1"]="https://test-streams.mux.dev/x36xhzz/x36xhzz.m3u8"
	preset_urls["2"]="https://cph-p2p-msl.akamaized.net/hls/live/2000341/test/master.m3u8"
	preset_labels["1"]="Test Stream 1 (mux.dev HLS)"
	preset_labels["2"]="Test Stream 2 (Akamai HLS Live)"

	while true; do
		echo -e "\n${C_CYAN}==== Ψ-4NDR0666 STREAM EXTRACTOR ====${C_RESET}"
		echo "1. Execute Preset 1: ${preset_labels[1]}"
		echo "2. Execute Preset 2: ${preset_labels[2]}"
		echo "3. Input Custom Target URL"
		echo "4. Access Advanced Configuration"
		echo "5. Save Current State to Config"
		echo "6. Terminate Connection"
		echo -n "> "

		read -r choice
		case "$choice" in
		1)
			TARGET_URL="${preset_urls[1]}"
			execute_extraction || true
			;;
		2)
			TARGET_URL="${preset_urls[2]}"
			execute_extraction || true
			;;
		3)
			echo -n "Enter M3U8/MPD URL: "
			read -r TARGET_URL
			if [[ -n "$TARGET_URL" ]]; then
				execute_extraction || true
			else
				print_warning "URL cannot be empty."
			fi
			;;
		4)
			configure_advanced
			;;
		5)
			save_config
			;;
		6)
			print_info "Terminating matrix. Goodbye."
			exit 0
			;;
		*)
			print_warning "Invalid directive."
			;;
		esac
	done
}

# -----------------------------------------------------------------------------
# CLI Argument Parsing
# -----------------------------------------------------------------------------
show_help() {
	echo -e "${C_CYAN}Ψ-4NDR0666 N_m3u8DL-RE Orchestrator${C_RESET}"
	echo "Usage: $0 [options] [URL]"
	echo ""
	echo "Options:"
	echo "  -h, --help            Show this help dialog."
	echo "  -t, --threads NUM     Set thread count (Default: $THREAD_COUNT)."
	echo "  -r, --retries NUM     Set retry count (Default: $RETRY_COUNT)."
	echo "  -d, --save-dir DIR    Set output directory."
	echo "  -o, --output NAME     Set output filename (without extension)."
	echo "  -c, --create-config   Generate default config file and exit."
	echo ""
	echo "If no URL or options are provided, the interactive menu will launch."
}

parse_arguments() {
	while [[ "$#" -gt 0 ]]; do
		case "$1" in
		-h | --help)
			show_help
			exit 0
			;;
		-t | --threads)
			# D10 FIX: Guard shift 2 against insufficient remaining arguments.
			if [[ "$#" -lt 2 ]]; then
				print_error "--threads requires a numeric argument."
				exit 1
			fi
			# D6 FIX: Validate numeric input in CLI path too.
			validate_positive_integer "$2" "Thread Count" || exit 1
			THREAD_COUNT="$2"
			shift 2
			;;
		-r | --retries)
			# D10 FIX: Guard shift 2.
			if [[ "$#" -lt 2 ]]; then
				print_error "--retries requires a numeric argument."
				exit 1
			fi
			validate_positive_integer "$2" "Retry Count" || exit 1
			RETRY_COUNT="$2"
			shift 2
			;;
		-d | --save-dir)
			# D10 FIX: Guard shift 2.
			if [[ "$#" -lt 2 ]]; then
				print_error "--save-dir requires a path argument."
				exit 1
			fi
			SAVE_DIR="$2"
			shift 2
			;;
		-o | --output)
			# D10 FIX: Guard shift 2.
			if [[ "$#" -lt 2 ]]; then
				print_error "--output requires a name argument."
				exit 1
			fi
			SAVE_NAME="$2"
			shift 2
			;;
		-c | --create-config)
			save_config
			exit 0
			;;
		-*)
			print_error "Unknown parameter passed: $1"
			show_help
			exit 1
			;;
		*)
			# Treat any positional argument as the URL.
			TARGET_URL="$1"
			shift
			;;
		esac
	done
}

# -----------------------------------------------------------------------------
# Boot Sequence
# -----------------------------------------------------------------------------
# D3 FIX: check_dependencies and load_config are unconditionally executed.
# D16 FIX: check_dependencies had regressed back to commented-out in the
# source provided for this audit, silently disabling dependency detection
# and leaving BIN_M3U8 to whatever stale value preceded it.
check_dependencies
load_config

if [[ $# -gt 0 ]]; then
	parse_arguments "$@"
	if [[ -n "$TARGET_URL" ]]; then
		execute_extraction
	else
		print_error "CLI mode triggered but no target URL provided."
		exit 1
	fi
else
	interactive_menu
fi
