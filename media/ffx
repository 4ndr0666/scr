# =============================================================================
# CMD: FILTER
# =============================================================================
cmd_filter() {
    advanced_prompt
    local input="" output="" preset="enhance" custom_filter=""
    local -a args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --preset|-P)        preset="$2"; shift 2 ;;
            --filter|-F)        custom_filter="$2"; shift 2 ;;
            -o|--output)        output="$2"; shift 2 ;;
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -v|--verbose)       VERBOSE_MODE=true; shift ;;
            -*)                 warn "filter: ignoring unknown option '$1'"; shift ;;
            *)                  args+=("$1"); shift ;;
        esac
    done

    input="${args[0]:-}"
    [[ -z "$output" ]] && output="${args[1]:-${GLOBAL_OUTPUT_FILE:-}}"

    if [[ -z "$input" ]]; then
        local -a _s; mapfile -t _s < <(fzf_pick); input="${_s[0]}"
    fi
    [[ -f "$input" ]] || die "File not found: $input"
    local bare; bare="$(basename "${input%.*}")"
    [[ -z "$output" ]] && output="$(get_default_filename "$bare" "filtered" "$ADV_CONTAINER")"

    local vfilter
    if [[ -n "$custom_filter" ]]; then
        vfilter="$custom_filter"
    else
        case "$preset" in
        enhance)       vfilter="eq=brightness=0.1:contrast=1.2:saturation=1.2" ;;
        skintone)      vfilter="eq=brightness=0.15:contrast=1.3:saturation=0.9,colorbalance=rs=-0.1:gs=0.05:bs=0.05" ;;
        denoise)       vfilter="hqdn3d=2:1:2:3" ;;
        cross_process) vfilter="curves=preset=cross_process" ;;
        hdr2sdr)       vfilter="zscale=t=linear:npl=100,format=gbrpf32le,zscale=p=bt709,tonemap=tonemap=hable,zscale=t=bt709:m=bt709:r=tv,format=yuv420p" ;;
        smooth)        vfilter="minterpolate=fps=60,tblend=all_mode=average,framestep=2" ;;
        whitecal)      vfilter="colorbalance=rs=-0.05:gs=0.05:bs=0.10" ;;
        *)             die "Unknown filter preset: '$preset'. Valid: enhance skintone denoise cross_process hdr2sdr smooth whitecal" ;;
        esac
    fi

    verbose_log "filter preset='$preset' vfilter='$vfilter'"

    local fixed; fixed="$(ensure_dts_correct "$input")" || die "DTS fix failed: $input"
    local deint; deint="$(get_deinterlace_filter "$fixed")"
    local full_vf
    [[ "$deint" != "null" ]] && full_vf="${deint},${vfilter}" || full_vf="$vfilter"

    local -a aopts; mapfile -t aopts < <(get_audio_opts_array)
    local -a enc
    [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]] \
        && enc=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "$ADV_PRESET") \
        || enc=("-c:v" "$ADV_CODEC" "-crf" "${ADV_CRF:-18}" "-preset" "$ADV_PRESET")

    run_ffmpeg --ffx-output "$output" -y -i "$fixed" \
        -vf "$full_vf" \
        "${enc[@]}" "${aopts[@]}" \
        -pix_fmt "$ADV_PIX_FMT" -movflags +faststart "$output" \
        || die "filter: ffmpeg failed." "$output"

    check_moov_atom "$output" || moov_fallback "$fixed" "$output"
    auto_clean "$output"
    say "Filtered [${preset}]: $output"
}

# =============================================================================
# CMD: CACHE-CLEAN
#
# CHANGED: now also offers to clear stale resume checkpoints, since
# FFX_CHECKPOINT_DIR lives under FFX_CACHE_DIR and the user's existing mental
# model of "cache-clean wipes FFX's scratch state" should cover it without
# introducing a second, separate command to learn.
# =============================================================================
cmd_cache_clean() {
    printf 'This will remove all FFX cache files in: %s\n' "$FFX_CACHE_DIR"
    printf '(includes resumable batch checkpoints in: %s)\n' "$FFX_CHECKPOINT_DIR"
    local ans
    read -r -p "Are you sure? (y/N): " ans
    if [[ "${ans,,}" =~ ^y ]]; then
        rm -rf -- "$FFX_CACHE_DIR"; mkdir -p -- "$FFX_CACHE_DIR" "$FFX_CHECKPOINT_DIR"; say "Cache cleaned."
    else
        printf 'Aborted.\n'
    fi
}
# =============================================================================
# HELP
# =============================================================================
display_usage() {
    printf '%b# === FFX v8.1.0 ===%b\n\n' "${CYAN}${BOLD}" "${RESET}"
    cat <<'HELPEOF'
Usage: ffx [global options] <command> [arguments]

Global Options:
  -A, --advanced             Interactive encoding prompt (persisted to XDG config).
  -v, --verbose              Verbose FFmpeg output + live log.
  --dry-run                  Print FFmpeg commands without executing.
  -b, --bulk                 Auto-glob all video files in output directory (merge).
  -an, --remove-audio        Strip all audio from output.
  -C, --composite            Composite mode for 'merge' (delegates to composite cmd).
  -P, --max-1080             Clamp output height to 1080p for 'process'.
  -i, --interpolate          Motion interpolation for 'slowmo'.
  -o, --output-dir <dir>     Output directory / file path (default: cwd).
  -f, --fps <val>            Force output FPS.
  -p, --pts <val>            PTS slow-motion factor (e.g. 2 = half speed).
  --timeout <sec>            Per-operation FFmpeg timeout for single-file commands
                             (0 = no limit; default 300).
  --timeout-per-file <sec>   Per-input budget used to SCALE the timeout for batch
                             operations whose cost grows with file count — merge
                             and composite concat steps (default 60). A 50-file
                             merge gets 50x this value as its ceiling instead of
                             the flat single-file --timeout, which is what
                             previously caused large batches to be killed by a
                             timeout sized for one file.
  --retry <n>                Automatic retries on a transient (non-timeout)
                             ffmpeg failure before giving up (default 1).
  --no-resume                Ignore any existing resume checkpoint for this job
                             and reprocess every input from scratch.
  --container <ext>          Output container override (mp4/mkv/mov).
  --resolution <WxH>         Override output resolution (e.g. 1920x1080).
  --codec <encoder>          Override video encoder (e.g. libx265).
  --layout-mode <mode>       Composite layout: fixed (default) or random.
  -h, --help                 This message.

Commands:
  probe      [<input>]                    File info. fzf selector if omitted.
  process    <input> [output]             Re-encode/scale; auto-deinterlace; lanczos.
  merge      [files...] [-o <out>]        Concat. -C composites; -b globs directory.
                                           Resumable: a failed large-batch merge can
                                           be re-run identically to continue from
                                           where it left off (see --no-resume).
  composite  [files...] [-o <base>]       Layout composite (fixed or random mode).
                                           Resumable per-batch, same as merge.
  looperang  <input> [output]             Forward+reverse palindrome.
  slowmo     <input> [output] [factor]    Slow motion. -i enables interpolation.
  filter     <input> [output]             Apply colour/enhancement filter preset.
  fix        <input> [output]             Repair DTS/timestamp issues.
  clean      <input> [output]             Strip metadata (stream-copy + reencode fallback).
  clean-fast <input> [output]             Strip metadata (stream-copy only).
  clip       <input> [output]             Interactive trim by start/end time.
  cache-clean                             Remove FFX cache files (incl. resume checkpoints).
  cleanmeta  <input> [output]             Alias for clean.
  manifest   [save|verify|show]           Self-audit SHA-256 manifest.
  help                                    This message.

Filter Presets (cmd filter --preset NAME):
  enhance      General brightness+contrast+saturation boost.
  skintone     Fix dim video with red-hue skin tones.
  denoise      hqdn3d spatial+temporal denoising.
  cross_process Film cross-processing colour look.
  hdr2sdr      HDR->SDR via Hable tone-mapping (requires libzimg).
  smooth       Frame-blending smoothness (minterpolate).
  whitecal     White balance: reduce warm/red cast.

Composite Layouts:
  fixed mode  (default):
    1 file  -> fullscreen (1920x1080)
    2 files -> lossless hstack via composite_pair_lossless
    3 files -> 1 top + 2 bottom
    4 files -> 2x2 grid
    >4      -> auto-batched
  random mode (--layout-mode random):
    AR fitness engine selects optimal layout from 8 candidates.
    Layouts: fullscreen, hstack, vstack, top1_bot2, top2_bot1,
             left1_right2, left2_right1, grid2x2, row4.

Large Batch Jobs (merge / composite):
  Both commands now scale their internal ffmpeg timeouts to the number of
  files involved (--timeout-per-file), instead of applying the same fixed
  --timeout to a 3-file job and a 300-file job alike. If a batch job is
  interrupted or fails partway through, every input successfully processed
  so far is checkpointed under ~/.cache/ffx/checkpoints/; re-running the
  exact same command resumes from the first unprocessed input rather than
  starting over. Pass --no-resume to force a clean restart.

Config:  ~/.config/ffx/defaults
Log:     ~/.local/share/ffx/ffx.log
Checkpoints: ~/.cache/ffx/checkpoints/
HELPEOF
    exit 0
}

# =============================================================================
# ARGUMENT PARSING
#
# CHANGED: adds --timeout-per-file, --retry, --no-resume. All three are
# superset additions — every previously-valid invocation parses identically;
# these are new optional flags with safe defaults (set in default_config),
# not replacements for any existing flag.
# =============================================================================
parse_global_options() {
    REMAINING_ARGS=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -A|--advanced)      ADVANCED_MODE=true;  shift ;;
        -v|--verbose)       VERBOSE_MODE=true;   shift ;;
        --dry-run)          DRY_RUN=true;         shift ;;
        -b|--bulk)          BULK_MODE=true;       shift ;;
        -an|--remove-audio) REMOVE_AUDIO=true;   shift ;;
        -C|--composite)     COMPOSITE_MODE=true; shift ;;
        -P|--max-1080)      MAX_1080=true;        shift ;;
        -i|--interpolate)   INTERPOLATE=true;    shift ;;
        --no-resume)
            NO_RESUME_GLOBAL=true; shift ;;
        -o|--output-dir|--output)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            OUTPUT_DIR="$2"; GLOBAL_OUTPUT_FILE="$2"; shift 2 ;;
        -f|--fps)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            [[ "$2" =~ ^[0-9]+(\.[0-9]+)?$ ]] || die "--fps requires a numeric value."
            SPECIFIC_FPS="$2"; shift 2 ;;
        -p|--pts)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            [[ "$2" =~ ^[0-9]+(\.[0-9]+)?$ ]] || die "--pts requires a numeric value."
            PTS_FACTOR="$2"; shift 2 ;;
        --timeout)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            [[ "$2" =~ ^[0-9]+$ ]] || die "--timeout requires a non-negative integer."
            FFX_TIMEOUT="$2"; shift 2 ;;
        --timeout-per-file)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            [[ "$2" =~ ^[0-9]+$ ]] || die "--timeout-per-file requires a non-negative integer."
            FFX_TIMEOUT_PER_FILE="$2"; shift 2 ;;
        --retry)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            [[ "$2" =~ ^[0-9]+$ ]] || die "--retry requires a non-negative integer."
            FFX_RETRY="$2"; shift 2 ;;
        --container)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            ADV_CONTAINER="$2"; shift 2 ;;
        --resolution)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            [[ "$2" =~ ^[0-9]+x[0-9]+$ ]] || die "--resolution requires WxH format (e.g. 1920x1080)."
            ADV_RES="$2"; shift 2 ;;
        --codec)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            ADV_CODEC="$2"; shift 2 ;;
        --layout-mode)
            [[ -z "${2:-}" ]] && die "Option '$1' requires an argument."
            case "${2,,}" in
                fixed|random) LAYOUT_MODE="${2,,}"; shift 2 ;;
                *) die "--layout-mode requires 'fixed' or 'random'." ;;
            esac ;;
        -h|--help|help) display_usage ;;
        --) shift; REMAINING_ARGS+=("$@"); break ;;
        -*) die "Unknown option: '$1'. Run 'ffx help'." ;;
        *)  REMAINING_ARGS+=("$@"); break ;;
        esac
    done
}

# =============================================================================
# DISPATCH & MAIN
#
# CHANGED: if --no-resume was given as a GLOBAL option (before the command),
# forward it into REMAINING_ARGS as a command-level flag too, so `ffx
# --no-resume merge ...` and `ffx merge --no-resume ...` behave identically —
# cmd_merge/cmd_composite only look for it in their own argv. This keeps the
# new flag's parsing local to the commands that use it (no global state they
# need to reach across), while still accepting it in the conventional
# "global option before the subcommand" position users expect.
# =============================================================================
NO_RESUME_GLOBAL=false

main_dispatch() {
    local cmd="${1:-help}"; shift || true
    if [[ "$NO_RESUME_GLOBAL" == true ]]; then
        case "$cmd" in
            merge|composite) set -- "$@" "--no-resume" ;;
        esac
    fi
    case "$cmd" in
        probe)       cmd_probe       "$@" ;;
        process)     cmd_process     "$@" ;;
        merge)       cmd_merge       "$@" ;;
        composite)   cmd_composite   "$@" ;;
        looperang)   cmd_looperang   "$@" ;;
        slowmo)      cmd_slowmo      "$@" ;;
        filter)      cmd_filter      "$@" ;;
        fix)         cmd_fix         "$@" ;;
        clean)       cmd_cleanmeta   "$@" ;;
        clean-fast)  cmd_clean       "$@" ;;
        cleanmeta)   cmd_cleanmeta   "$@" ;;
        manifest)    cmd_manifest    "$@" ;;
        clip)        cmd_clip        "$@" ;;
        cache-clean) cmd_cache_clean "$@" ;;
        help)        display_usage        ;;
        *)           die "Unrecognized command: '$cmd'. Run 'ffx help'." ;;
    esac
}

main() {
    check_deps
    load_defaults
    parse_global_options "$@"
    mkdir -p -- "$OUTPUT_DIR" || die "Cannot create output directory: $OUTPUT_DIR"
    [[ -w "$OUTPUT_DIR" ]] || die "Output directory not writable: $OUTPUT_DIR"
    (( ${#REMAINING_ARGS[@]} >= 1 )) || display_usage
    main_dispatch "${REMAINING_ARGS[@]}"
}

main "$@"
