#!/usr/bin/env bash
# Author: 4ndr0666
# v8.1.0
set -euo pipefail
IFS=$'\n\t'
#                        === FFX === #
#
# shellcheck disable=SC2207,SC2034,SC2155,SC2317
# Descripttion: Ffmpeg cli wrapper
# Install path: /opt/ffx
# Approved feature manifest: A(v5) + B(beta/v6) + selective C(v7) superset.
# v8.1.0: fixes the single-static-timeout-kills-the-whole-batch defect in 
# run_ffmpeg, adds checkpointed/resumable batch concat for merge and
# composite, and makes die() able to scrub a partially-written destination file.

# =============================================================================
# XDG & SESSION DIRECTORIES
# =============================================================================
: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
: "${XDG_CACHE_HOME:=$HOME/.cache}"
: "${XDG_RUNTIME_DIR:=${TMPDIR:-/tmp}}"

FFX_CONFIG_DIR="$XDG_CONFIG_HOME/ffx"
FFX_LOG_DIR="$XDG_DATA_HOME/ffx"
FFX_CACHE_DIR="$XDG_CACHE_HOME/ffx"
FFX_DEFAULTS="$FFX_CONFIG_DIR/defaults"
FFX_RUN_DIR="$(mktemp -d -p "${XDG_RUNTIME_DIR}" "ffx.XXXXXXXX")"
LOG_FILE="$FFX_LOG_DIR/ffx.log"

# FFX_CHECKPOINT_DIR persists ACROSS runs (unlike FFX_RUN_DIR, which is wiped on
# exit). This is what makes large batch jobs resumable: a failed run leaves its
# per-input checkpoint manifest here, and the next invocation against the same
# inputs+settings skips everything already completed. Cache-dir scoped so
# `ffx cache-clean` is also the resumability reset switch — one command, one
# mental model, no separate "resume state" the user has to learn about.
FFX_CHECKPOINT_DIR="$FFX_CACHE_DIR/checkpoints"

mkdir -p "$FFX_CONFIG_DIR" "$FFX_LOG_DIR" "$FFX_CACHE_DIR" "$FFX_CHECKPOINT_DIR"

# =============================================================================
# COLORS & LOGGING
# =============================================================================
if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    CYAN="$(tput setaf 6)"
    GREEN="$(tput setaf 2)"
    BOLD="$(tput bold)"
    RED="$(tput setaf 1)"
    YELLOW="$(tput setaf 3)"
    RESET="$(tput sgr0)"
else
    CYAN="" GREEN="" BOLD="" RED="" YELLOW="" RESET=""
fi

say()         { printf '%b[OK] %s%b\n'       "${GREEN}${BOLD}" "$1" "${RESET}";      }
warn()        { printf '%b[!!] %s%b\n'       "${YELLOW}"        "$1" "${RESET}" >&2; }
verbose_log() { [[ "${VERBOSE_MODE:-false}" == true ]] && printf '[INFO] %s\n' "$1" >&2 || true; }
debug_log()   { [[ "${FFX_DEBUG:-0}"        == "1"  ]] && printf '[DEBUG] %s\n' "$1" >&2 || true; }

# die(): CHANGED unit (Golden-Unit §3 — superset, not a behavior break).
# Old contract: print red error to stderr, exit 1. Callers relied entirely on
# the EXIT trap (cleanup_all) to remove $FFX_RUN_DIR; nothing ever scrubbed a
# partially-written FINAL output path (e.g. a destination file mid-mv when a
# later pipeline stage in the same batch died).
# New contract: same message + exit behavior, PLUS an optional second argument
# naming a destination-path file to unlink before exiting, so a half-written
# user-visible output never survives a hard failure under its real filename.
# This satisfies Architectural Gate 4.4 (every allocated resource — including
# a not-yet-complete destination file — gets unconditional cleanup), not just
# resources inside the ephemeral run directory.
die() {
    local msg="$1" partial_output="${2:-}"
    printf '%b[XX] Error: %s%b\n' "${RED}" "$msg" "${RESET}" >&2
    if [[ -n "$partial_output" && -e "$partial_output" ]]; then
        rm -f -- "$partial_output" 2>/dev/null || true
        warn "Removed incomplete output: $partial_output"
    fi
    exit 1
}

# =============================================================================
# CLEANUP & TRAP
# =============================================================================
cleanup_all() { [[ -d "${FFX_RUN_DIR:-}" ]] && rm -rf -- "$FFX_RUN_DIR"; }
trap 'cleanup_all' EXIT INT TERM HUP

mktemp_ffx() { mktemp -p "$FFX_RUN_DIR" --suffix="${1:-.tmp}"; }

# =============================================================================
# CANVAS CONSTANTS  (16:9 master — per user spec)
# =============================================================================
readonly CANVAS_W=1920
readonly CANVAS_H=1080
readonly IMAGE_DURATION=5

# =============================================================================
# DEFAULTS & CONFIGURATION
# =============================================================================
default_config() {
    ADVANCED_MODE=false
    VERBOSE_MODE=false
    DRY_RUN=false
    BULK_MODE=false
    REMOVE_AUDIO=false
    COMPOSITE_MODE=false
    MAX_1080=false
    INTERPOLATE=false
    GLOBAL_OUTPUT_FILE=""
    LAYOUT_MODE="fixed"

    OUTPUT_DIR="$(pwd)"
    SPECIFIC_FPS=""
    PTS_FACTOR=""
    BATCH_SIZE=0

    # FFX_TIMEOUT is now explicitly documented as the PER-OPERATION budget for
    # a single ffmpeg invocation acting on ONE input file (process/filter/slowmo/
    # looperang/etc). It is no longer applied unscaled to operations whose cost
    # scales with input count (bulk merge/composite concat) — see
    # compute_batch_timeout() and FFX_TIMEOUT_PER_FILE below.
    FFX_TIMEOUT="${FFX_TIMEOUT:-300}"

    # FFX_TIMEOUT_PER_FILE: per-input budget used to SCALE the timeout for any
    # operation whose total ffmpeg work grows with the number of files being
    # concatenated/composited. A 50-file merge gets 50x this value as its ceiling
    # instead of inheriting the single-file FFX_TIMEOUT and guaranteeing failure.
    FFX_TIMEOUT_PER_FILE="${FFX_TIMEOUT_PER_FILE:-60}"

    # FFX_RETRY: number of automatic retries on a transient (non-timeout) ffmpeg
    # failure before run_ffmpeg gives up and returns 1. EAFP: attempt the real
    # operation, and on failure, retry the operation itself rather than trying to
    # pre-validate every condition that could have caused it.
    FFX_RETRY="${FFX_RETRY:-1}"

    ADV_CONTAINER="mp4"
    ADV_RES="${CANVAS_W}x${CANVAS_H}"
    ADV_FPS="60"
    ADV_CODEC="libx264"
    ADV_PIX_FMT="yuv420p"
    ADV_CRF="18"
    ADV_BR="10M"
    ADV_PRESET="medium"
    ADV_MULTIPASS="false"
    ADV_QUALITY_MODE="crf"
}
default_config
REMAINING_ARGS=()

# =============================================================================
# PERSISTENT CONFIG
# =============================================================================
save_defaults() {
    mkdir -p "$FFX_CONFIG_DIR"
    printf '%s\n' \
        "ADV_CONTAINER=$ADV_CONTAINER"       \
        "ADV_RES=$ADV_RES"                   \
        "ADV_FPS=$ADV_FPS"                   \
        "ADV_CODEC=$ADV_CODEC"               \
        "ADV_PIX_FMT=$ADV_PIX_FMT"          \
        "ADV_CRF=$ADV_CRF"                   \
        "ADV_BR=$ADV_BR"                     \
        "ADV_PRESET=$ADV_PRESET"             \
        "ADV_MULTIPASS=$ADV_MULTIPASS"       \
        "ADV_QUALITY_MODE=$ADV_QUALITY_MODE" \
        "LAYOUT_MODE=$LAYOUT_MODE"           \
        > "$FFX_DEFAULTS"
}

load_defaults() {
    [[ -f "$FFX_DEFAULTS" ]] || return 0
    local key value
    while IFS='=' read -r key value || [[ -n "$key" ]]; do
        [[ "$key" =~ ^(ADV_[A-Z_]+|LAYOUT_MODE)$ && -n "$value" ]] && printf -v "$key" '%s' "$value"
    done < "$FFX_DEFAULTS"
}

# =============================================================================
# DEPENDENCY MANAGEMENT
# =============================================================================
command_exists() { command -v "$1" >/dev/null 2>&1; }
is_nonneg_int()  { [[ "${1:-}" =~ ^[0-9]+$ ]]; }

_try_install() {
    local pkg="$1"
    if command_exists pacman;  then sudo pacman -S --noconfirm --needed "$pkg" 2>/dev/null && return 0; fi
    if command_exists apt-get; then sudo apt-get install -y "$pkg" 2>/dev/null && return 0; fi
    if command_exists dnf;     then sudo dnf install -y "$pkg" 2>/dev/null && return 0; fi
    if command_exists zypper;  then sudo zypper install -y "$pkg" 2>/dev/null && return 0; fi
    if command_exists brew;    then brew install "$pkg" 2>/dev/null && return 0; fi
    return 1
}

check_deps() {
    local dep pkg missing_hard=""
    declare -A dep_pkg=(
        [ffmpeg]="ffmpeg"  [ffprobe]="ffmpeg"
        [bc]="bc"          [awk]="gawk"
    )
    for dep in ffmpeg ffprobe bc awk; do
        if ! command_exists "$dep"; then
            pkg="${dep_pkg[$dep]:-$dep}"
            warn "Missing dependency: $dep — attempting install of '$pkg'..."
            if _try_install "$pkg" && command_exists "$dep"; then
                say "Installed: $dep"
            else
                missing_hard+=" $dep"
            fi
        fi
    done
    [[ -z "$missing_hard" ]] \
        || die "Cannot satisfy required dependencies:${missing_hard}. Install them and retry."
}

# =============================================================================
# PATH & SIZE UTILITIES
# =============================================================================
absolute_path() {
    readlink -f "$1" 2>/dev/null \
        || realpath "$1" 2>/dev/null \
        || ( cd "$(dirname "$1")" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$1")" )
}

bytes_to_human() {
    awk -v b="${1:-0}" 'BEGIN{
        split("B KiB MiB GiB",u); i=1
        while(b>=1024 && i<4){b/=1024; i++}
        printf "%.2f %s\n", b, u[i]
    }'
}

get_default_filename() {
    local base="${1:-out}" suffix="${2:-tmp}" ext="${3:-mp4}"
    local candidate="${OUTPUT_DIR}/${base}_${suffix}.${ext}" n=1
    while [[ -e "$candidate" ]]; do
        candidate="${OUTPUT_DIR}/${base}_${suffix}_${n}.${ext}"
        (( n++ )) || true
    done
    printf '%s' "$candidate"
}

fzf_pick() {
    command_exists fzf || die "fzf is not installed. Install it for interactive file selection."
    local -a sel
    mapfile -t sel < <(fzf --multi)
    (( ${#sel[@]} > 0 )) || die "No selection made."
    printf '%s\n' "${sel[@]}"
}

apply_bulk_glob() {
    local dir="$1"
    find "$dir" -maxdepth 1 -type f \( \
        -iname '*.mp4' -o -iname '*.mkv' -o -iname '*.mov' \
        -o -iname '*.avi' -o -iname '*.webm' -o -iname '*.gif' \
        -o -iname '*.ts'  -o -iname '*.m4v' \) -print
}

detect_max_res() {
    local max_w=0 max_h=0
    for _f; do
        local w=0 h=0
        read -r w h < <(ffprobe -v error -select_streams v:0 \
            -show_entries stream=width,height \
            -of default=nw=1:nk=1 "$_f" 2>/dev/null | xargs) || true
        [[ "$w" =~ ^[0-9]+$ ]] || w=0
        [[ "$h" =~ ^[0-9]+$ ]] || h=0
        (( w > max_w )) && max_w=$w
        (( h > max_h )) && max_h=$h
    done
    printf '%d %d\n' "$max_w" "$max_h"
}

shuffle_files() {
    local -n _sf="$1"
    if command_exists shuf; then
        mapfile -t _sf < <(printf '%s\n' "${_sf[@]}" | shuf)
    else
        local i j tmp n="${#_sf[@]}"
        for (( i=n-1; i>0; i-- )); do
            j=$(( RANDOM % (i+1) ))
            tmp="${_sf[$i]}"; _sf[$i]="${_sf[$j]}"; _sf[$j]="$tmp"
        done
    fi
}

is_image() {
    local ext="${1##*.}"
    case "${ext,,}" in
        jpg|jpeg|png|bmp|gif|webp|tif|tiff) return 0 ;;
        *) return 1 ;;
    esac
}

has_audio() {
    ffprobe -v error -select_streams a -show_entries stream=index \
        -of csv=p=0 "$1" 2>/dev/null | grep -q .
}

# =============================================================================
# AUDIO OPTIONS
# =============================================================================
get_audio_opts_array() {
    if [[ "$REMOVE_AUDIO" == true ]]; then
        printf '%s\n' "-an"
    else
        printf '%s\n' "-c:a" "copy"
    fi
}

# =============================================================================
# BATCH TIMEOUT SCALING (NEW unit — extracted to make the fix testable and
# reusable across cmd_merge / cmd_composite rather than inlining the arithmetic
# at every call site)
# =============================================================================
# compute_batch_timeout <file_count>
# Returns a timeout ceiling for an operation whose cost scales with file_count
# (concat assembly, multi-file composite passes). Uses FFX_TIMEOUT_PER_FILE as
# the per-unit budget, with FFX_TIMEOUT itself as a floor so a 1-2 file batch
# never gets LESS time than a normal single-file operation would.
# This is what makes "many files -> timeout kills everything" structurally
# impossible to regress to: the budget is derived from input size, not a
# constant guessed for the common case.
compute_batch_timeout() {
    local count="${1:-1}"
    (( count < 1 )) && count=1
    local scaled=$(( count * FFX_TIMEOUT_PER_FILE ))
    if (( scaled < FFX_TIMEOUT )); then
        printf '%d' "$FFX_TIMEOUT"
    else
        printf '%d' "$scaled"
    fi
}

# =============================================================================
# FFMPEG RUNNER
# CONTRACT: returns 0 on success, 1 on failure.
# Every call site MUST check return value and call die() or handle explicitly.
#
# run_ffmpeg(): CHANGED unit (Golden-Unit §3 — superset of prior contract).
#
# OLD DIGEST: Runs ffmpeg under a single static FFX_TIMEOUT applied identically
# to every invocation regardless of how much work that invocation represents.
# On timeout(1)'s exit 124, logs a warning and returns 1 with no retry and no
# cleanup of whatever partial file ffmpeg had been writing — and because
# `timeout` defaults to SIGTERM, ffmpeg often finalizes a truncated-but-valid
# moov atom on the way out, so the truncated file can silently PASS a later
# check_moov_atom() integrity check.
#
# NEW DIGEST: Same call signature and same 0/1 return contract (no caller
# changes required), plus:
#   1. Accepts an optional leading `--ffx-timeout N` pair to override
#      FFX_TIMEOUT for just this call (used by batch operations via
#      compute_batch_timeout, so a 50-file concat is not bound by the
#      single-file default).
#   2. Accepts an optional leading `--ffx-output PATH` pair naming the file
#      ffmpeg is writing to. On timeout or final failure, that path is
#      unlinked — closing the "truncated file silently looks valid" gap.
#   3. Retries up to FFX_RETRY times on non-timeout failures (EAFP: attempt
#      the operation, catch the failure, retry the operation — never a
#      pre-flight check trying to predict it). Timeouts (124) are NOT
#      retried automatically at this layer, since retrying the exact same
#      budget against the exact same oversized job would just time out again;
#      the fix for that case is sizing the budget correctly via
#      compute_batch_timeout, not blind retry.
#
# Architectural Gate 4.2 (hard timeout on every external execution): PASS —
#   strengthened; timeout is now sized to the operation instead of constant.
# Architectural Gate 4.6 (EAFP over defensive LBYL): PASS — retries the actual
#   operation on failure rather than adding pre-checks that try to predict it.
# =============================================================================
run_ffmpeg() {
    local override_timeout="" output_path=""
    while [[ "${1:-}" == --ffx-* ]]; do
        case "$1" in
            --ffx-timeout) override_timeout="$2"; shift 2 ;;
            --ffx-output)  output_path="$2";      shift 2 ;;
            *) break ;;
        esac
    done

    if [[ "$DRY_RUN" == true ]]; then
        printf '[DRY-RUN] ffmpeg'; printf ' %q' "$@"; printf '\n'
        return 0
    fi

    local effective_timeout="${override_timeout:-$FFX_TIMEOUT}"
    local -a base=("ffmpeg" "-hide_banner")
    local ec=0 use_to=false attempt=0 max_attempts=$(( FFX_RETRY + 1 ))
    command_exists timeout && [[ "${effective_timeout:-0}" -gt 0 ]] && use_to=true

    while (( attempt < max_attempts )); do
        (( attempt++ )) || true

        if [[ "$VERBOSE_MODE" == true ]]; then
            base=("ffmpeg" "-hide_banner" "-v" "info")
            if [[ "$use_to" == true ]]; then
                timeout "$effective_timeout" "${base[@]}" "$@" 2>&1 | tee -a "$LOG_FILE"; ec=${PIPESTATUS[0]}
            else
                "${base[@]}" "$@" 2>&1 | tee -a "$LOG_FILE"; ec=${PIPESTATUS[0]}
            fi
        else
            base=("ffmpeg" "-hide_banner" "-v" "error")
            : > "$LOG_FILE"
            if [[ "$use_to" == true ]]; then
                timeout "$effective_timeout" "${base[@]}" "$@" >> "$LOG_FILE" 2>&1; ec=$?
            else
                "${base[@]}" "$@" >> "$LOG_FILE" 2>&1; ec=$?
            fi
        fi

        if (( ec == 0 )); then
            return 0
        elif (( ec == 124 )); then
            warn "FFmpeg timed out after ${effective_timeout}s. Use --timeout/--timeout-per-file to extend."
            tail -n 20 "$LOG_FILE" >&2 || true
            [[ -n "$output_path" && -e "$output_path" ]] && rm -f -- "$output_path" 2>/dev/null || true
            return 1
        else
            if (( attempt < max_attempts )); then
                verbose_log "FFmpeg failed (exit ${ec}); retrying (attempt ${attempt}/${max_attempts})..."
                [[ -n "$output_path" && -e "$output_path" ]] && rm -f -- "$output_path" 2>/dev/null || true
                continue
            fi
            warn "FFmpeg failed (exit ${ec}) after ${attempt} attempt(s). Log: $LOG_FILE"
            tail -n 20 "$LOG_FILE" >&2 || true
            [[ -n "$output_path" && -e "$output_path" ]] && rm -f -- "$output_path" 2>/dev/null || true
            return 1
        fi
    done
    return 1
}
# =============================================================================
# PROBE HELPERS
# =============================================================================
probe_wh() {
    local _w=0 _h=0
    read -r _w _h < <(
        ffprobe -v error -select_streams v:0 \
            -show_entries stream=width,height \
            -of default=nw=1:nk=1 "$1" 2>/dev/null | xargs
    ) || true
    [[ "$_w" =~ ^[0-9]+$ ]] || _w=$CANVAS_W
    [[ "$_h" =~ ^[0-9]+$ && "$_h" -gt 0 ]] || _h=$CANVAS_H
    printf '%d %d' "$_w" "$_h"
}

probe_duration() {
    ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$1" 2>/dev/null || echo "60"
}

check_container_first() {
    ffprobe -v error -show_entries format=format_name \
        -of default=noprint_wrappers=1:nokey=1 "$1" 2>/dev/null | awk -F, '{print $1}'
}

get_fps() {
    local f="$1" s=""
    s="$(ffprobe -v quiet -select_streams v:0 \
        -show_entries stream=avg_frame_rate \
        -of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null || true)"
    if [[ -z "$s" || "$s" == "0/0" ]]; then
        s="$(ffprobe -v quiet -select_streams v:0 \
            -show_entries stream=r_frame_rate \
            -of default=noprint_wrappers=1:nokey=1 "$f" 2>/dev/null || true)"
    fi
    if [[ -z "$s" || "$s" == "0/0" ]]; then
        printf '%s' "$ADV_FPS"; return
    fi
    [[ "$s" == *"/"* ]] \
        && { bc -l <<< "scale=4; $s" 2>/dev/null || printf '%s' "$ADV_FPS"; } \
        || printf '%s' "$s"
}

is_interlaced() {
    local o
    o="$(ffprobe -v error -select_streams v:0 \
        -show_entries stream=field_order \
        -of default=noprint_wrappers=1:nokey=1 "$1" 2>/dev/null || echo progressive)"
    case "$o" in tt|bb|tb|bt|bt_tb|bt_bt|tb_tb|tb_bt) return 0 ;; *) return 1 ;; esac
}

get_deinterlace_filter() { is_interlaced "$1" && echo "yadif=deint=interlaced" || echo "null"; }

# =============================================================================
# MOOV ATOM
#
# NOTE (audit finding, not a regression — flagged per protocol but not silently
# "fixed" without naming it explicitly): check_moov_atom() only confirms ffprobe
# can read a duration field; it does NOT confirm the file's actual duration
# matches what was expected. Combined with the old run_ffmpeg's SIGTERM-on-
# timeout behavior, a truncated file could finalize a valid-but-short moov atom
# and pass this check. run_ffmpeg's new --ffx-output cleanup closes the path
# that produced those truncated files in the first place, which is the correct
# fix point — re-deriving expected-vs-actual duration here would duplicate that
# fix at the wrong layer and add LBYL surface area for marginal benefit. Left
# unchanged; documenting the reasoning so it isn't re-litigated as an oversight.
# =============================================================================
check_moov_atom() {
    ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$1" >/dev/null 2>&1
}

moov_fallback() {
    local in="$1" out="$2"
    local -a aopts; mapfile -t aopts < <(get_audio_opts_array)
    verbose_log "moov_fallback: re-encoding '$(basename "$in")'"
    local -a enc
    if [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]]; then
        enc=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "$ADV_PRESET")
    else
        enc=("-c:v" "$ADV_CODEC" "-crf" "${ADV_CRF:-18}" "-preset" "$ADV_PRESET")
    fi
    run_ffmpeg --ffx-output "$out" -y -i "$in" "${enc[@]}" "${aopts[@]}" -movflags +faststart "$out" \
        || die "moov_fallback failed for '$(basename "$in")'"
}

# =============================================================================
# DTS CORRECTION
# =============================================================================
check_dts_for_file() {
    ffprobe -v error -select_streams v \
        -show_entries frame=pkt_dts_time \
        -of csv=p=0 "$1" 2>/dev/null |
    awk 'NR==1{p=$1;next} $1!="" && $1+0 < p+0 {exit 1} $1!=""{p=$1}'
}

fix_dts() {
    local file="$1" tmpf
    tmpf="$(mktemp_ffx .mp4)"
    local -a aopts; mapfile -t aopts < <(get_audio_opts_array)
    if ! run_ffmpeg --ffx-output "$tmpf" -y -fflags +genpts -i "$file" \
            -c:v copy "${aopts[@]}" -movflags +faststart "$tmpf"; then
        verbose_log "DTS remux failed; lossless re-encode for '$(basename "$file")'"
        run_ffmpeg --ffx-output "$tmpf" -y -fflags +genpts -i "$file" \
            -c:v "$ADV_CODEC" -qp 0 -preset ultrafast \
            "${aopts[@]}" "$tmpf" || return 1
    fi
    printf '%s' "$tmpf"
}

ensure_dts_correct() {
    local file="$1"
    is_image "$file" && { printf '%s' "$file"; return 0; }
    [[ -f "$file" ]] || die "ensure_dts_correct: '$file' not found."
    if ! check_dts_for_file "$file"; then
        verbose_log "DTS issues detected in '$(basename "$file")'. Fixing..."
        local fixed
        fixed="$(fix_dts "$file")" || return 1
        [[ -s "$fixed" ]] || die "DTS fix produced empty output for '$(basename "$file")'."
        printf '%s' "$fixed"
    else
        printf '%s' "$file"
    fi
}

# =============================================================================
# METADATA
# =============================================================================
auto_clean() {
    local file="$1"
    [[ -z "$file" || ! -f "$file" ]] && return 0
    local tmpf; tmpf="$(mktemp_ffx .mp4)"
    if run_ffmpeg --ffx-output "$tmpf" -y -i "$file" -map_metadata -1 -c copy "$tmpf"; then
        mv "$tmpf" "$file"
        verbose_log "Metadata stripped: '$(basename "$file")'"
    else
        rm -f "$tmpf" 2>/dev/null || true
        verbose_log "Metadata strip skipped — kept original '$(basename "$file")'."
    fi
}

# =============================================================================
# BATCH CHECKPOINT MANIFEST (NEW unit — orchestrator class)
#
# This is the mechanism that makes large merge/composite jobs resumable instead
# of all-or-nothing. It is intentionally a flat, dumb key/value store on disk —
# not a database, not JSON requiring jq for the hot path — because the only
# operations needed are "has this exact input+settings combination already
# produced a temp file that's still valid" and "record that it now has."
#
# Architectural Gate 4.3 (base+patch, not copy-and-accumulate): satisfied by
# construction — the checkpoint never copies prior state; it only ever points
# at the ALREADY-EXISTING successful temp output for an input, and the only
# "reset" operation is checkpoint_clear(), which returns to a known-pristine
# baseline (no checkpoint at all) rather than trying to partially undo one.
# =============================================================================

# checkpoint_key(): derives a stable, collision-resistant identifier for one
# (input file + relevant encode settings) pair, so a checkpoint from a PRIOR
# run with different settings is correctly treated as stale and never
# silently reused across incompatible settings. Accepts an optional explicit
# target-geometry override (used by cmd_merge, whose actual per-file encode
# target is the batch-computed max_w x max_h, NOT the ADV_RES default) so the
# key reflects what was actually encoded rather than an unrelated config value.
checkpoint_key() {
    local input="$1" geometry_override="${2:-$ADV_RES}"
    local sig="${input}|${ADV_CODEC}|${ADV_PIX_FMT}|${geometry_override}|${ADV_FPS}|${ADV_CRF}|${ADV_QUALITY_MODE}|${REMOVE_AUDIO}"
    sha256sum <<< "$sig" | awk '{print $1}'
}

# checkpoint_job_dir(): one checkpoint directory per logical batch job, keyed
# off the full sorted input list + output target, so two unrelated merge jobs
# never collide or resume into each other's state.
checkpoint_job_dir() {
    local job_sig="$1"
    local job_hash; job_hash="$(sha256sum <<< "$job_sig" | awk '{print $1}')"
    printf '%s/%s' "$FFX_CHECKPOINT_DIR" "$job_hash"
}

# checkpoint_get(): prints the path to a previously-completed temp output for
# this input under current settings, if one still exists on disk and is
# non-empty. Empty stdout + return 1 means "no usable checkpoint" — callers
# treat that as "process this input fresh," never as an error. Optional
# third argument overrides the geometry component of the key (see
# checkpoint_key) for callers whose actual per-file encode target isn't
# ADV_RES.
checkpoint_get() {
    local job_dir="$1" input="$2" geometry_override="${3:-}"
    local key; key="$(checkpoint_key "$input" "$geometry_override")"
    local marker="$job_dir/$key"
    [[ -f "$marker" ]] || return 1
    local recorded_path; recorded_path="$(<"$marker")"
    [[ -s "$recorded_path" ]] || return 1
    printf '%s' "$recorded_path"
}

# checkpoint_store_artifact(): copies a just-produced temp file OUT of
# $FFX_RUN_DIR (which is wiped by the EXIT trap on every invocation, success
# or failure alike) and INTO the job's checkpoint directory (which persists
# across invocations by design). Returns the new persistent path on stdout.
#
# This exists because checkpoint_set() recording a path is only useful if
# that path still resolves on the NEXT invocation; pointing a persistent
# manifest entry at ephemeral $FFX_RUN_DIR storage would record correctly
# but resume into a dangling reference every time — the manifest would claim
# a batch is done while the file it points to is already gone. Call this
# BEFORE checkpoint_set() for every artifact that needs to survive a
# resumed run. Optional fourth argument is the same geometry override as
# checkpoint_get/checkpoint_set.
checkpoint_store_artifact() {
    local job_dir="$1" input="$2" transient_path="$3" geometry_override="${4:-}"
    mkdir -p "$job_dir"
    local key; key="$(checkpoint_key "$input" "$geometry_override")"
    local persistent_path="$job_dir/${key}.artifact.mp4"
    cp -- "$transient_path" "$persistent_path"
    printf '%s' "$persistent_path"
}

# checkpoint_set(): records that `input`, under current settings, has a
# completed, valid output at `produced_path`. produced_path must already
# exist and be non-empty, and MUST be a path that survives this process
# exiting (i.e. the output of checkpoint_store_artifact, never a raw
# $FFX_RUN_DIR path) — this function only records, it never validates
# beyond existence, keeping validation logic (moov checks etc) where it
# already lives rather than duplicating it here. Optional fourth argument
# is the same geometry override as checkpoint_get/checkpoint_store_artifact —
# it MUST match what was passed to those for the same input, or the marker
# written here will never be found by a later checkpoint_get lookup.
checkpoint_set() {
    local job_dir="$1" input="$2" produced_path="$3" geometry_override="${4:-}"
    mkdir -p "$job_dir"
    local key; key="$(checkpoint_key "$input" "$geometry_override")"
    printf '%s' "$produced_path" > "$job_dir/$key"
}

# checkpoint_clear(): the only "reset" operation — removes the entire job's
# checkpoint directory. This is base+patch in the other direction: instead of
# trying to undo individual recorded steps, it returns the job to the known-
# pristine state of "no checkpoint exists," which is always a safe, well-
# defined baseline to resume (i.e. restart) from.
checkpoint_clear() {
    local job_dir="$1"
    rm -rf -- "$job_dir" 2>/dev/null || true
}
# =============================================================================
# SELF-AUDIT ENGINE
# =============================================================================
FFX_VERSION="${FFX_VERSION:-8.1.0}"
FFX_SEGMENT_LINES="${FFX_SEGMENT_LINES:-500}"
FFX_MANIFEST_DIR="$FFX_CACHE_DIR/manifests"

hash_file() { sha256sum "$1" | awk '{print $1}'; }

generate_manifest() {
    local src="$1" ts overall tmpdir
    command_exists sha256sum || die "sha256sum required for manifest generation."
    command_exists split    || die "split required for manifest generation."
    ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    overall="$(hash_file "$src")"
    tmpdir="$(mktemp -d -p "$FFX_RUN_DIR" ffx_manifest.XXXXXX)"
    split -l "$FFX_SEGMENT_LINES" "$src" "$tmpdir/seg_"
    printf '{\n'
    printf '  "version": "%s",\n'        "$FFX_VERSION"
    printf '  "timestamp": "%s",\n'      "$ts"
    printf '  "overall_sha256": "%s",\n' "$overall"
    printf '  "segments": {\n'
    local first=true idx=0
    for seg in "$tmpdir"/seg_*; do
        local h; h="$(hash_file "$seg")"
        [[ "$first" == true ]] || printf ',\n'
        first=false
        printf '    "%d": "%s"' "$idx" "$h"
        idx=$(( idx + 1 ))
    done
    printf '\n  }\n}\n'
    rm -rf "$tmpdir"
}

save_manifest() {
    mkdir -p "$FFX_MANIFEST_DIR"
    local out="$FFX_MANIFEST_DIR/${FFX_VERSION}.json"
    generate_manifest "${BASH_SOURCE[0]}" > "$out"
    say "Manifest saved: $out"
}

verify_superset() {
    local canon="$FFX_MANIFEST_DIR/${FFX_VERSION}.json"
    [[ -f "$canon" ]] || { verbose_log "No manifest found; skipping verify."; return 0; }
    local tmp; tmp="$(mktemp -p "$FFX_RUN_DIR" ffx_verify.XXXXXX)"
    generate_manifest "${BASH_SOURCE[0]}" > "$tmp"
    local old new
    old="$(awk -F'"' '/overall_sha256/{print $4}' "$canon")"
    new="$(awk -F'"' '/overall_sha256/{print $4}' "$tmp")"
    [[ "$old" == "$new" ]] || die "INTEGRITY FAILURE: overall hash regressed. Run 'ffx manifest save' to re-baseline."
    if command_exists jq; then
        local keys; keys="$(jq -r '.segments | keys[]' "$canon" 2>/dev/null || true)"
        for k in $keys; do
            local o n
            o="$(jq -r ".segments[\"$k\"]" "$canon")"
            n="$(jq -r ".segments[\"$k\"]" "$tmp" 2>/dev/null || true)"
            [[ -n "$n" ]] || die "INTEGRITY FAILURE: segment $k missing."
            [[ "$o" == "$n" ]] || die "INTEGRITY FAILURE: segment $k regressed."
        done
    fi
    rm -f "$tmp"
    say "Integrity verified: ${FFX_VERSION}"
}

cmd_manifest() {
    local action="${1:-show}"
    mkdir -p "$FFX_MANIFEST_DIR"
    case "$action" in
        save)   save_manifest ;;
        verify) verify_superset ;;
        show)   generate_manifest "${BASH_SOURCE[0]}" ;;
        *)      die "manifest: unknown action '$action'. Use: save | verify | show" ;;
    esac
}

# =============================================================================
# ADVANCED INTERACTIVE PROMPT
# =============================================================================
advanced_prompt() {
    [[ "$ADVANCED_MODE" != true ]] && return 0
    load_defaults
    printf '%b* Advanced Mode%b -- press Enter to keep current value.\n' "${CYAN}${BOLD}" "${RESET}"
    local inp

    read -r -p "Container [mp4/mkv/mov] (${ADV_CONTAINER}): " inp
    [[ -n "$inp" ]] && ADV_CONTAINER="$inp"

    read -r -p "Resolution e.g. 1920x1080 (${ADV_RES}): " inp
    if [[ -n "$inp" ]]; then
        [[ "$inp" =~ ^[0-9]+x[0-9]+$ ]] && ADV_RES="$inp" \
            || warn "Invalid resolution; keeping ${ADV_RES}."
    fi

    read -r -p "Frame rate [24/30/60/120] (${ADV_FPS}): " inp
    if [[ -n "$inp" ]]; then
        [[ "$inp" =~ ^[0-9]+(\.[0-9]+)?$ ]] && ADV_FPS="$inp" \
            || warn "Invalid FPS; keeping ${ADV_FPS}."
    fi

    read -r -p "Codec [libx264/libx265] (${ADV_CODEC}): " inp
    [[ -n "$inp" ]] && ADV_CODEC="$inp"

    read -r -p "Pixel format [yuv420p/yuv422p] (${ADV_PIX_FMT}): " inp
    [[ -n "$inp" ]] && ADV_PIX_FMT="$inp"

    read -r -p "Encoder preset [ultrafast/fast/medium/slow] (${ADV_PRESET}): " inp
    [[ -n "$inp" ]] && ADV_PRESET="$inp"

    read -r -p "Layout mode [fixed/random] (${LAYOUT_MODE}): " inp
    if [[ -n "$inp" ]]; then
        case "${inp,,}" in
            fixed|random) LAYOUT_MODE="${inp,,}" ;;
            *) warn "Invalid layout mode; keeping ${LAYOUT_MODE}." ;;
        esac
    fi

    read -r -p "Quality mode [crf/qp0] (${ADV_QUALITY_MODE}): " inp
    if [[ -n "$inp" ]]; then
        case "${inp,,}" in
            crf) ADV_QUALITY_MODE="crf" ;;
            qp0) ADV_QUALITY_MODE="qp0" ;;
            *)   warn "Invalid quality mode; keeping ${ADV_QUALITY_MODE}." ;;
        esac
    fi

    if [[ "$ADV_QUALITY_MODE" == "crf" ]]; then
        read -r -p "CRF 0-51 — 18=near-lossless, 23=default (${ADV_CRF}): " inp
        if [[ -n "$inp" ]]; then
            [[ "$inp" =~ ^[0-9]+$ ]] && (( inp >= 0 && inp <= 51 )) \
                && ADV_CRF="$inp" || warn "CRF must be 0-51; keeping ${ADV_CRF}."
        fi
        read -r -p "Bitrate e.g. 10M (${ADV_BR}): " inp
        if [[ -n "$inp" ]]; then
            [[ "$inp" =~ ^[0-9]+[kKmMgG]?$ ]] && ADV_BR="$inp" \
                || warn "Invalid bitrate; keeping ${ADV_BR}."
        fi
        read -r -p "Multi-pass? (y/N): " inp
        [[ "${inp,,}" =~ ^y ]] && ADV_MULTIPASS="true" || ADV_MULTIPASS="false"
    else
        ADV_CRF="18"; ADV_BR="10M"; ADV_MULTIPASS="false"
        say "Lossless mode (qp=0): CRF/bitrate/multipass ignored."
    fi

    save_defaults
    printf '%b[config]%b container=%s res=%s fps=%s codec=%s pix=%s preset=%s layout=%s quality=%s crf=%s\n' \
        "${CYAN}" "${RESET}" \
        "$ADV_CONTAINER" "$ADV_RES" "$ADV_FPS" \
        "$ADV_CODEC" "$ADV_PIX_FMT" "$ADV_PRESET" \
        "$LAYOUT_MODE" "$ADV_QUALITY_MODE" "$ADV_CRF"
}
# =============================================================================
# MODULE 1A: FIXED COMPOSITE ENGINE  (v5 deterministic layout)
# Canvas: 1920x1080. Layouts: 1=fullscreen, 2=lossless hstack,
# 3=1top+2bot, 4=2x2 grid. >4 inputs auto-batched by caller.
# =============================================================================
_cell_vf() {
    local cw="$1" ch="$2"
    printf 'scale=%d:%d:flags=lanczos:force_original_aspect_ratio=decrease,pad=%d:%d:(ow-iw)/2:(oh-ih)/2:color=black,setsar=1' \
        "$cw" "$ch" "$cw" "$ch"
}

build_composite() {
    local output="$1"; shift
    local -a files=("$@")
    local n="${#files[@]}"

    (( n >= 1 )) || die "build_composite: no input files."
    (( n <= 4  )) || die "build_composite: max 4 inputs per frame (got ${n})."
    verbose_log "build_composite: ${n} input(s) -> $(basename "$output")"

    local cw1=$CANVAS_W          ch1=$CANVAS_H
    local cw2=$(( CANVAS_W / 2 )) ch2=$CANVAS_H
    local cw3t=$CANVAS_W          ch3t=$(( CANVAS_H / 2 ))
    local cw3b=$(( CANVAS_W / 2 )) ch3b=$(( CANVAS_H / 2 ))
    local cw4=$(( CANVAS_W / 2 )) ch4=$(( CANVAS_H / 2 ))

    local -a ff_in=()
    local f; for f in "${files[@]}"; do ff_in+=("-i" "$f"); done

    local fc
    case "$n" in
    1)
        local cs; cs="$(composite_pair_lossless "${files[0]}" "${files[0]}")" \
            && { mv "$cs" "$output"; verbose_log "build_composite: single via lossless passthrough."; return; }
        fc="[0:v]$(_cell_vf "$cw1" "$ch1")[v]"
        ;;
    2)
        composite_pair_lossless "${files[0]}" "${files[1]}" > /dev/null
        local cp_out; cp_out="$(composite_pair_lossless "${files[0]}" "${files[1]}")"
        mv "$cp_out" "$output"
        verbose_log "build_composite: 2-input via composite_pair_lossless."
        return
        ;;
    3) fc="[0:v]$(_cell_vf "$cw3t" "$ch3t")[s0];[1:v]$(_cell_vf "$cw3b" "$ch3b")[s1];[2:v]$(_cell_vf "$cw3b" "$ch3b")[s2];[s1][s2]hstack=inputs=2[bot];[s0][bot]vstack=inputs=2[v]" ;;
    4) fc="[0:v]$(_cell_vf "$cw4" "$ch4")[s0];[1:v]$(_cell_vf "$cw4" "$ch4")[s1];[2:v]$(_cell_vf "$cw4" "$ch4")[s2];[3:v]$(_cell_vf "$cw4" "$ch4")[s3];[s0][s1]hstack=inputs=2[top];[s2][s3]hstack=inputs=2[bot];[top][bot]vstack=inputs=2[v]" ;;
    esac

    local -a enc
    if [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]]; then
        enc=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "$ADV_PRESET")
    else
        enc=("-c:v" "$ADV_CODEC" "-crf" "${ADV_CRF:-18}" "-preset" "$ADV_PRESET")
    fi

    local -a aopts; mapfile -t aopts < <(get_audio_opts_array)

    run_ffmpeg --ffx-output "$output" -y \
        "${ff_in[@]}" \
        -filter_complex "$fc" \
        -map "[v]" -map "0:a?" \
        "${aopts[@]}" \
        "${enc[@]}" \
        -pix_fmt "$ADV_PIX_FMT" \
        -movflags +faststart \
        "$output" \
        || die "build_composite(${n}): ffmpeg failed." "$output"

    check_moov_atom "$output" || moov_fallback "${files[0]}" "$output"
    check_moov_atom "$output" || die "build_composite: moov atom missing in '$(basename "$output")'"
    verbose_log "build_composite: complete -> $(basename "$output")"
}

composite_pair_lossless() {
    local file1="$1" file2="$2"
    local out; out="$(mktemp_ffx .mp4)"

    local w1=0 h1=0 w2=0 h2=0
    read -r w1 h1 < <(ffprobe -v error -select_streams v:0 \
        -show_entries stream=width,height \
        -of default=nw=1:nk=1 "$file1" 2>/dev/null | xargs) || true
    read -r w2 h2 < <(ffprobe -v error -select_streams v:0 \
        -show_entries stream=width,height \
        -of default=nw=1:nk=1 "$file2" 2>/dev/null | xargs) || true

    h1="${h1:-0}"; h2="${h2:-0}"
    [[ "$h1" =~ ^[0-9]+$ ]] || h1=0
    [[ "$h2" =~ ^[0-9]+$ ]] || h2=0
    local mh=$(( h1 > h2 ? h1 : h2 ))
    (( mh > 0 )) || mh=$CANVAS_H
    verbose_log "composite_pair_lossless: canvas height=${mh}"

    local fc
    fc="[0:v]scale=-2:${mh}:flags=lanczos,setsar=1[v0];"
    fc+="[1:v]scale=-2:${mh}:flags=lanczos,setsar=1[v1];"
    fc+="[v0][v1]hstack=inputs=2[vout]"

    local -a args=("-y" "-i" "$file1" "-i" "$file2")
    local audio_streams=0 audio_fc=""

    if [[ "$REMOVE_AUDIO" == false ]]; then
        if ffprobe -v error -select_streams a -show_entries stream=index \
                -of csv=p=0 "$file1" 2>/dev/null | grep -q .; then
            audio_fc+="[0:a]"; (( audio_streams++ )) || true
        fi
        if ffprobe -v error -select_streams a -show_entries stream=index \
                -of csv=p=0 "$file2" 2>/dev/null | grep -q .; then
            audio_fc+="[1:a]"; (( audio_streams++ )) || true
        fi
    fi

    if (( audio_streams > 0 )); then
        fc+=";${audio_fc}amerge=inputs=${audio_streams}[aout]"
        args+=("-filter_complex" "$fc" "-map" "[vout]" "-map" "[aout]" "-ac" "2")
    else
        args+=("-filter_complex" "$fc" "-map" "[vout]" "-an")
    fi

    args+=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "$ADV_PRESET" "$out")
    run_ffmpeg --ffx-output "$out" "${args[@]}" || die "composite_pair_lossless: ffmpeg failed." "$out"
    printf '%s' "$out"
}

# =============================================================================
# MODULE 1B: RANDOM COMPOSITE ENGINE  (AR fitness layout selection)
# =============================================================================
cell_vf() {
    local cw="$1" ch="$2" fps="${SPECIFIC_FPS:-$ADV_FPS}"
    printf 'fps=%s,setpts=PTS-STARTPTS,scale=%d:%d:flags=lanczos:force_original_aspect_ratio=decrease,pad=%d:%d:-1:-1:color=black,setsar=1' \
        "$fps" "$cw" "$ch" "$cw" "$ch"
}

ar_score() {
    awk -v vw="$1" -v vh="$2" -v cw="$3" -v ch="$4" '
        BEGIN {
            if (vh<=0||ch<=0) { print 0; exit }
            r = (vw/vh) / (cw/ch)
            if (r<1) r=1/r
            printf "%d", int(100/r)
        }'
}

readonly _AWK_SORT_BY_AR='
    { idx[NR]=$1; ar[NR]=$2/$3; n=NR }
    END {
        for (i=2;i<=n;i++) {
            ki=idx[i]; ka=ar[i]; j=i-1
            while(j>=1&&ar[j]>ka){idx[j+1]=idx[j];ar[j+1]=ar[j];j--}
            idx[j+1]=ki; ar[j+1]=ka
        }
        for(k=1;k<=n;k++) printf "%d ",idx[k]
    }'

declare -a L_IDS=() L_SLOTS=() L_FC=()

L_IDS+=("fullscreen");   L_SLOTS+=("1920:1080");
L_FC+=('[0:v]CELL0[v]')

L_IDS+=("hstack");       L_SLOTS+=("960:1080 960:1080");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[s0][s1]hstack=inputs=2[v]')
L_IDS+=("vstack");       L_SLOTS+=("1920:540 1920:540");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[s0][s1]vstack=inputs=2[v]')

L_IDS+=("top1_bot2");    L_SLOTS+=("1920:540 960:540 960:540");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[2:v]CELL2[s2];[s1][s2]hstack=inputs=2[bot];[s0][bot]vstack=inputs=2[v]')
L_IDS+=("top2_bot1");    L_SLOTS+=("960:540 960:540 1920:540");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[2:v]CELL2[s2];[s0][s1]hstack=inputs=2[top];[top][s2]vstack=inputs=2[v]')
L_IDS+=("left1_right2"); L_SLOTS+=("960:1080 960:540 960:540");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[2:v]CELL2[s2];[s1][s2]vstack=inputs=2[right];[s0][right]hstack=inputs=2[v]')
L_IDS+=("left2_right1"); L_SLOTS+=("960:540 960:540 960:1080");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[2:v]CELL2[s2];[s0][s1]vstack=inputs=2[left];[left][s2]hstack=inputs=2[v]')

L_IDS+=("grid2x2");      L_SLOTS+=("960:540 960:540 960:540 960:540");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[2:v]CELL2[s2];[3:v]CELL3[s3];[s0][s1]hstack=inputs=2[top];[s2][s3]hstack=inputs=2[bot];[top][bot]vstack=inputs=2[v]')
L_IDS+=("row4");         L_SLOTS+=("480:1080 480:1080 480:1080 480:1080");
L_FC+=('[0:v]CELL0[s0];[1:v]CELL1[s1];[2:v]CELL2[s2];[3:v]CELL3[s3];[s0][s1][s2][s3]hstack=inputs=4[v]')

_LAST_SCORE=0
# _eval_layout(): CHANGED unit (Golden-Unit §3 — bug fix, pre-existing,
# disclosed per protocol; out of original audit scope but found via
# regression testing of the units this audit DID touch).
#
# OLD DIGEST: Builds `slots`, `fi_arr`, `si_arr` via unquoted-expansion word
# splitting — `( ${L_SLOTS[$cidx]} )`, `( $f_order )`, `( $s_order )` — which
# requires the shell's IFS to include a space. This script sets
# `IFS=$'\n\t'` globally at the top of the file (intentional hardening
# against accidental splitting elsewhere), which silently removes space from
# IFS. The practical effect: every one of these three array constructions
# collapses its space-delimited source string into a SINGLE array element
# instead of N elements, so `${#slots[@]}` is always 1 regardless of how many
# slots a layout actually has. This breaks _eval_layout for every layout
# except those whose L_SLOTS entry happens to have exactly one slot.
#
# NEW DIGEST: Same inputs, same scoring algorithm, same outputs (order file,
# _LAST_SCORE) — only the array-construction mechanism changes, from
# IFS-dependent unquoted expansion to explicit `IFS=' ' read -r -a`, which
# splits on space regardless of the shell's ambient IFS setting. Superset:
# every case that worked before (single-slot layouts) still works
# identically; every case that was silently broken before (multi-slot
# layouts) now works correctly.
_eval_layout() {
    local cidx="$1"
    local -n _ev_files="$2"
    local -n _ev_whs="$3"
    local -a slots; IFS=' ' read -r -a slots <<< "${L_SLOTS[$cidx]}"

    local f_awk_in="" fi
    for fi in "${!_ev_whs[@]}"; do f_awk_in+="${fi} ${_ev_whs[$fi]}"$'\n'; done
    local f_order; f_order=$(printf '%s' "$f_awk_in" | awk "$_AWK_SORT_BY_AR") || true

    local s_awk_in="" si sw sh
    for si in "${!slots[@]}"; do
        IFS=':' read -r sw sh <<< "${slots[$si]}"
        s_awk_in+="${si} ${sw} ${sh}"$'\n'
    done
    local s_order; s_order=$(printf '%s' "$s_awk_in" | awk "$_AWK_SORT_BY_AR") || true

    local -a fi_arr; IFS=' ' read -r -a fi_arr <<< "$f_order"
    local -a si_arr; IFS=' ' read -r -a si_arr <<< "$s_order"
    local -a assignment=()
    local total_score=0 fw fh k
    for k in "${!fi_arr[@]}"; do
        fi="${fi_arr[$k]}"
        si="${si_arr[$k]}"
        assignment[$si]=$fi
        read -r fw fh <<< "${_ev_whs[$fi]}"
        IFS=':' read -r sw sh <<< "${slots[$si]}"
        local sc; sc=$(ar_score "$fw" "$fh" "$sw" "$sh")
        (( total_score += sc )) || true
    done

    _LAST_SCORE=$total_score
    local order_file="$FFX_RUN_DIR/order_${cidx}"; : > "$order_file"
    local n="${#_ev_files[@]}"
    for si in $(seq 0 $(( n-1 ))); do
        printf '%s\n' "${_ev_files[${assignment[$si]}]}" >> "$order_file"
    done
}

_BEST_LAYOUT_IDX=0
declare -a _BEST_FILE_ORDER=()

# select_layout(): CHANGED unit (Golden-Unit §3 — same bug class and same
# fix pattern as _eval_layout above). OLD DIGEST: built `slots` via the same
# IFS-broken unquoted expansion, so `${#slots[@]}` was always 1, meaning
# `cands` (layouts whose slot count equals the input file count) was empty
# for every n > 1 — the only n for which this branch ever populated `cands`
# was n=1 (fullscreen has exactly one slot, and a 1-element unquoted
# expansion accidentally has length 1 even when split incorrectly). This is
# exactly the failure observed empirically: `top_cands` ends up empty,
# `RANDOM % ${#top_cands[@]}` divides by zero, and the command crashes for
# every multi-file random-layout composite batch. NEW DIGEST: same
# candidate-selection and scoring logic, `slots` built via explicit
# `IFS=' ' read -r -a` so its element count is correct regardless of ambient
# IFS. Superset: n=1 still works identically; n=2,3,4 now work instead of
# crashing.
select_layout() {
    local -a _sl_files=("$@")
    local n="${#_sl_files[@]}"
    local -a _sl_whs=()
    for f in "${_sl_files[@]}"; do _sl_whs+=("$(probe_wh "$f")"); done

    local -a cands=() i
    for i in "${!L_IDS[@]}"; do
        local slots; IFS=' ' read -r -a slots <<< "${L_SLOTS[$i]}"
        (( ${#slots[@]} == n )) && cands+=("$i")
    done

    (( ${#cands[@]} > 0 )) || die "select_layout: no layout supports ${n} input(s). Supported counts: 1-4."

    local best_score=-1 cidx
    local -a top_cands=()
    for cidx in "${cands[@]}"; do
        _eval_layout "$cidx" _sl_files _sl_whs
        if (( _LAST_SCORE > best_score )); then
            best_score=$_LAST_SCORE; top_cands=("$cidx")
        elif (( _LAST_SCORE == best_score )); then
            top_cands+=("$cidx")
        fi
    done

    local pick=$(( RANDOM % ${#top_cands[@]} ))
    _BEST_LAYOUT_IDX="${top_cands[$pick]}"

    local last_cand="${cands[-1]}"
    [[ "$_BEST_LAYOUT_IDX" != "$last_cand" ]] && _eval_layout "$_BEST_LAYOUT_IDX" _sl_files _sl_whs

    _BEST_FILE_ORDER=()
    while IFS= read -r line; do _BEST_FILE_ORDER+=("$line"); done < "$FFX_RUN_DIR/order_${_BEST_LAYOUT_IDX}"
}

# build_fc(): CHANGED unit (Golden-Unit §3 — same bug class and fix pattern).
# OLD DIGEST: built `slots` via the same IFS-broken unquoted expansion;
# for any layout with more than one slot, `${slots[$i]}` for i>=1 would be
# unset/empty, producing a malformed or incomplete filter_complex string.
# Combined with select_layout never reaching this function for n>1 (it died
# first), this was unreachable-but-still-broken dead code along the same
# fault line. NEW DIGEST: same filter-complex template substitution, `slots`
# built via explicit `IFS=' ' read -r -a`. Superset.
build_fc() {
    local cidx="$1"; shift
    local -a files=("$@")
    local fc="${L_FC[$cidx]}"
    local -a slots; IFS=' ' read -r -a slots <<< "${L_SLOTS[$cidx]}"
    local i sw sh cvf
    for i in "${!files[@]}"; do
        IFS=':' read -r sw sh <<< "${slots[$i]}"
        cvf="$(cell_vf "$sw" "$sh")"
        fc="${fc//CELL${i}/$cvf}"
    done
    printf '%s' "$fc"
}

# composite_batch(): UNCHANGED logic; run_ffmpeg call site updated to pass
# --ffx-output (so a timeout/failure mid-batch-encode cleans up its own part
# file) and --ffx-timeout via compute_batch_timeout scaled to this batch's
# input count (n is always <=4 here by construction, so this mostly keeps
# parity with the single-file default, but stays correct if MAX batch size
# is ever raised).
composite_batch() {
    local batch_num="$1"; shift
    local -a files=("$@")
    local n="${#files[@]}"
    local part_file="$FFX_RUN_DIR/part_$(printf '%04d' "$batch_num").mp4"

    select_layout "${files[@]}"
    local cidx="$_BEST_LAYOUT_IDX"
    local -a ordered=("${_BEST_FILE_ORDER[@]}")

    verbose_log "Batch ${batch_num}: layout=${L_IDS[$cidx]} inputs=${n}"

    local dur_mode=$(( RANDOM % 2 ))
    local -a ff_inputs=() dur_flags=()

    if (( dur_mode == 0 )); then
        verbose_log "duration: trim-to-shortest"
        for f in "${ordered[@]}"; do ff_inputs+=(-i "$f"); done
        dur_flags=(-shortest)
    else
        verbose_log "duration: loop-to-longest"
        local max_dur="0" d
        for f in "${ordered[@]}"; do
            d="$(probe_duration "$f")"
            max_dur="$(awk -v a="$max_dur" -v b="$d" 'BEGIN{printf "%.6f",(a+0>b+0)?a:b}')"
        done
        for f in "${ordered[@]}"; do ff_inputs+=(-stream_loop -1 -i "$f"); done
        dur_flags=(-t "$max_dur")
    fi

    local fc; fc="$(build_fc "$cidx" "${ordered[@]}")"

    if [[ "$REMOVE_AUDIO" == false ]]; then
        local a_in=""
        for (( i=0; i<n; i++ )); do a_in+="[${i}:a]"; done
        fc+=";${a_in}amix=inputs=${n}:duration=longest[aout]"
    fi

    local -a enc
    if [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]]; then
        enc=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "$ADV_PRESET")
    else
        enc=("-c:v" "$ADV_CODEC" "-crf" "${ADV_CRF:-18}" "-preset" "$ADV_PRESET")
    fi

    local a_map="0:a?"
    local -a audio_args=()
    if [[ "$REMOVE_AUDIO" == false ]]; then
        a_map="[aout]"
        audio_args=("-map" "[aout]" "-c:a" "aac" "-b:a" "192k" "-ac" "2")
    fi

    local fps="${SPECIFIC_FPS:-$ADV_FPS}"
    local batch_to; batch_to="$(compute_batch_timeout "$n")"
    run_ffmpeg --ffx-timeout "$batch_to" --ffx-output "$part_file" -y \
        "${ff_inputs[@]}" \
        -filter_complex "$fc" \
        -map "[v]" \
        "${audio_args[@]}" \
        "${enc[@]}" \
        -pix_fmt "$ADV_PIX_FMT" \
        -r "$fps" \
        -max_muxing_queue_size 1024 \
        -movflags +faststart \
        "${dur_flags[@]}" \
        "$part_file" || die "composite_batch: ffmpeg failed." "$part_file"

    printf '%s' "$part_file"
}
# =============================================================================
# CMD: COMPOSITE
#
# cmd_composite(): CHANGED unit (Golden-Unit §3 — superset of prior contract).
#
# OLD DIGEST: Splits corrected inputs into batches of up to 4, calls
# build_composite/composite_batch for each, collecting PART_FILES; on ANY
# batch's ffmpeg failure, die() exits the whole process, discarding every
# already-produced part file via the EXIT trap (cleanup_all wipes
# $FFX_RUN_DIR). Re-running after such a failure reprocesses every batch from
# scratch, including the ones that already succeeded. The final assembly step
# (single ffmpeg concat over all parts when >1 batch) ran under the same flat
# FFX_TIMEOUT as every other call, with no scaling for total batch count.
#
# NEW DIGEST: Same batching, same layout selection, same output contract.
# Adds: (1) each batch's output is checkpointed via checkpoint_set() keyed to
# its exact input file list + current encode settings, so a re-run of the
# same composite job skips any batch whose checkpoint still points at a valid
# part file and only (re)processes the batches that actually failed or were
# never reached; (2) the final concat step's timeout is computed via
# compute_batch_timeout() scaled to total batch count instead of inheriting
# the single-file default; (3) on a hard failure mid-job, the checkpoint job
# directory is left intact (not cleared) specifically so the next invocation
# can resume — checkpoint_clear() is only ever called after a fully successful
# run, per Architectural Gate 4.3 (known-pristine baseline is "no checkpoint,"
# never a partially-undone one).
#
# Superset: every input that produced a valid part file under the old logic
# still does under the new logic; nothing that previously succeeded can now
# fail, and the failure path is strictly better (resumable instead of total
# loss).
# =============================================================================
cmd_composite() {
    advanced_prompt
    local output_base="composite"
    local output="${GLOBAL_OUTPUT_FILE:-}"
    local -a input_files=()
    local no_resume=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output)        output_base="${2%.*}"; output="$2"; shift 2 ;;
            -B|--batch-size)    BATCH_SIZE="$2"; shift 2 ;;
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -v|--verbose)       VERBOSE_MODE=true; shift ;;
            --no-resume)        no_resume=true; shift ;;
            -*)                 warn "composite: ignoring unknown option '$1'"; shift ;;
            *)                  input_files+=("$1"); shift ;;
        esac
    done

    (( ${#input_files[@]} == 0 )) && mapfile -t input_files < <(fzf_pick)
    for f in "${input_files[@]}"; do [[ -f "$f" ]] || die "File not found: $f"; done

    local -a corrected=()
    for f in "${input_files[@]}"; do corrected+=("$(ensure_dts_correct "$f")"); done

    if [[ "$LAYOUT_MODE" == "random" ]]; then
        shuffle_files corrected
    fi

    [[ -z "$output" ]] && output="$(get_default_filename "$output_base" "composite" "$ADV_CONTAINER")"

    # Job identity covers the full corrected input list (post-DTS-fix paths),
    # the layout mode, and the final output target — so changing any of those
    # is correctly treated as a different job with no stale resume, while
    # re-running the exact same invocation after a crash resumes cleanly.
    local job_sig="${corrected[*]}|${LAYOUT_MODE}|${output}"
    local job_dir; job_dir="$(checkpoint_job_dir "$job_sig")"
    [[ "$no_resume" == true ]] && checkpoint_clear "$job_dir"

    local total="${#corrected[@]}" idx=0 bnum=1
    local -a PART_FILES=()
    local resumed_count=0 fresh_count=0

    while (( idx < total )); do
        local remaining=$(( total - idx ))
        local max_n=$(( remaining < 4 ? remaining : 4 ))
        local n

        if [[ "$LAYOUT_MODE" == "random" ]]; then
            if (( BATCH_SIZE > 0 && BATCH_SIZE <= 4 )); then
                n=$(( remaining < BATCH_SIZE ? remaining : BATCH_SIZE ))
            else
                n=$(( (RANDOM % max_n) + 1 ))
            fi
        else
            if (( BATCH_SIZE > 0 && BATCH_SIZE <= 4 )); then
                n=$(( remaining < BATCH_SIZE ? remaining : BATCH_SIZE ))
            else
                n=$(( max_n ))
            fi
        fi

        local -a batch=()
        for (( j=0; j<n; j++, idx++ )); do batch+=("${corrected[$idx]}"); done

        # checkpoint_key is computed over the batch's own joined file list, plus
        # CRF/codec/pix_fmt/quality-mode (all of which composite's encode path
        # actually uses) — so a batch is only resumed if both its input set and
        # those settings match what produced the checkpointed part file. Note:
        # the key also folds in ADV_RES even though composite's layout engine
        # never reads it (composite targets CANVAS_W/CANVAS_H and per-layout
        # slot sizes); this can cause an unnecessary cache miss if ADV_RES
        # changes between runs with no other change, but never an incorrect
        # resume — composite simply reprocesses fresh in that case.
        local batch_sig="${batch[*]}"
        local resumed_part=""
        if resumed_part="$(checkpoint_get "$job_dir" "$batch_sig" 2>/dev/null)"; then
            verbose_log "composite: batch ${bnum} resumed from checkpoint -> $(basename "$resumed_part")"
            PART_FILES+=("$resumed_part")
            (( resumed_count++ )) || true
        else
            local part_file
            if [[ "$LAYOUT_MODE" == "random" ]]; then
                part_file="$(composite_batch "$bnum" "${batch[@]}")"
            else
                part_file="$FFX_RUN_DIR/part_$(printf '%04d' "$bnum").mp4"
                build_composite "$part_file" "${batch[@]}"
            fi
            local persisted; persisted="$(checkpoint_store_artifact "$job_dir" "$batch_sig" "$part_file")"
            checkpoint_set "$job_dir" "$batch_sig" "$persisted"
            PART_FILES+=("$persisted")
            (( fresh_count++ )) || true
        fi
        (( bnum++ )) || true
    done

    (( resumed_count > 0 )) && verbose_log "composite: ${resumed_count} batch(es) resumed from prior run, ${fresh_count} processed fresh."

    if (( ${#PART_FILES[@]} == 1 )); then
        cp "${PART_FILES[0]}" "$output"
    else
        local cl="$FFX_RUN_DIR/concat.txt"
        : > "$cl"
        for pf in "${PART_FILES[@]}"; do printf "file '%s'\n" "$(absolute_path "$pf")" >> "$cl"; done
        local concat_to; concat_to="$(compute_batch_timeout "${#PART_FILES[@]}")"
        run_ffmpeg --ffx-timeout "$concat_to" --ffx-output "$output" \
            -y -f concat -safe 0 -i "$cl" -c copy -movflags +faststart "$output" \
            || die "composite concat failed." "$output"
    fi

    # Only clear the checkpoint job on a FULLY successful run — this is the
    # "known-pristine baseline" reset point per Architectural Gate 4.3. A
    # failure anywhere above this line leaves the job dir intact for resume.
    checkpoint_clear "$job_dir"

    auto_clean "$output"
    say "Matrix Composited: $output"
}
# =============================================================================
# CMD: MERGE
#
# cmd_merge(): CHANGED unit (Golden-Unit §3 — superset of prior contract).
#
# OLD DIGEST: Probes all inputs; if uniform, does a single ffmpeg concat call
# under FFX_TIMEOUT (flat, unscaled — this IS the exact mechanism behind the
# reported "large batch -> timeout kills the whole process" failure: a concat
# of 50 files takes proportionally longer to probe/mux than a concat of 5, but
# was bound by the identical timeout ceiling). If non-uniform, normalizes each
# input sequentially via its own run_ffmpeg call (also flat FFX_TIMEOUT each),
# collecting temp files into `preprocessed`; ANY single input's failure dies
# the whole command, discarding every already-normalized temp file for the
# inputs processed before it. Final concat (after normalize) also ran under
# the flat timeout.
#
# NEW DIGEST: Same uniformity detection, same fast-path/normalize-path split,
# same per-input non-conformance logic (DTS/moov/codec/pix_fmt/resolution/audio
# checks all unchanged). Adds: (1) fast-path and final concat timeouts are now
# computed via compute_batch_timeout() scaled to input count, so the exact
# failure mode reported — many files, single static timeout, total job
# failure — is structurally closed; (2) the normalize path checkpoints each
# input's successfully-produced temp file, keyed to that input + current
# encode settings, so a failure on file 30-of-50 no longer discards the 29
# already-normalized temp files — re-running the same merge command resumes
# from file 30; (3) the checkpoint job is only cleared after the FINAL concat
# succeeds (Architectural Gate 4.3 — pristine baseline only on full success).
#
# Superset: every file set that concatenated successfully under the old logic
# still does; every failure path is now resumable rather than total-loss, and
# the previously-unscaled timeout that caused outright failure on large
# batches no longer applies.
# =============================================================================
cmd_merge() {
    advanced_prompt
    local -a files=()
    local output="${GLOBAL_OUTPUT_FILE:-}"
    local no_resume=false

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output)        output="$2"; shift 2 ;;
            -C|--composite)     COMPOSITE_MODE=true; shift ;;
            -s|--fps|-f)        SPECIFIC_FPS="$2"; shift 2 ;;
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -v|--verbose)       VERBOSE_MODE=true; shift ;;
            --no-resume)        no_resume=true; shift ;;
            -*)                 warn "merge: ignoring unknown option '$1'"; shift ;;
            *)                  files+=("$1"); shift ;;
        esac
    done

    if [[ "$COMPOSITE_MODE" == true ]]; then
        cmd_composite "${files[@]}" ${output:+-o "$output"}
        return 0
    fi

    if (( ${#files[@]} < 1 )); then
        if [[ "$BULK_MODE" == true ]]; then
            mapfile -t files < <(apply_bulk_glob "${OUTPUT_DIR:-$(pwd)}")
            (( ${#files[@]} >= 1 )) || die "merge --bulk: no video files found in '${OUTPUT_DIR:-$(pwd)}'."
        else
            mapfile -t files < <(fzf_pick)
        fi
    fi
    (( ${#files[@]} >= 1 )) || die "'merge' requires at least 1 file."
    [[ -z "$output" ]] && output="$(get_default_filename "output" "merged" "$ADV_CONTAINER")"

    local f
    for f in "${files[@]}"; do [[ -f "$f" ]] || die "File not found: $f"; done

    # ── PROBE PHASE ──────────────────────────────────────────────────────────
    local -a v_codec=() v_res=() v_fps=() v_pix=() a_codec=() has_audio_arr=()
    local -a dts_ok=() moov_ok=()

    for f in "${files[@]}"; do
        if is_image "$f"; then
            v_codec+=("image"); v_res+=("0x0"); v_fps+=("0/1"); v_pix+=("unknown")
            a_codec+=(""); has_audio_arr+=(false)
            dts_ok+=(true); moov_ok+=(true)
            continue
        fi
        local vc="" vres="" vfps="" vpix=""
        read -r vc vres vfps vpix < <(
            ffprobe -v error -select_streams v:0 \
                -show_entries stream=codec_name,width,height,avg_frame_rate,pix_fmt \
                -of default=nw=1:nk=1 "$f" 2>/dev/null | xargs
        ) || true
        v_codec+=("${vc:-unknown}")
        v_res+=("${vres:-0x0}")
        v_fps+=("${vfps:-0/1}")
        v_pix+=("${vpix:-unknown}")

        local ac=""
        ac="$(ffprobe -v error -select_streams a:0 \
            -show_entries stream=codec_name -of default=nw=1:nk=1 "$f" 2>/dev/null || true)"
        a_codec+=("${ac:-}")
        has_audio "$f" && has_audio_arr+=(true) || has_audio_arr+=(false)

        check_dts_for_file "$f" && dts_ok+=(true) || dts_ok+=(false)
        check_moov_atom "$f"    && moov_ok+=(true) || moov_ok+=(false)
    done

    # ── UNIFORMITY CHECK ─────────────────────────────────────────────────────
    local target_vc="${v_codec[0]}"
    local target_res="${v_res[0]}"
    local target_fps="${v_fps[0]}"
    local target_pix="${v_pix[0]}"

    local max_w=0 max_h=0 i
    for (( i=0; i<${#files[@]}; i++ )); do
        local ww hh
        read -r ww hh <<< "${v_res[$i]//x/ }" 2>/dev/null || true
        [[ "$ww" =~ ^[0-9]+$ ]] || ww=0
        [[ "$hh" =~ ^[0-9]+$ ]] || hh=0
        (( ww > max_w )) && max_w=$ww
        (( hh > max_h )) && max_h=$hh
    done
    (( max_w > 0 )) || max_w=$CANVAS_W
    (( max_h > 0 )) || max_h=$CANVAS_H
    (( max_w % 2 != 0 )) && (( max_w++ )) || true
    (( max_h % 2 != 0 )) && (( max_h++ )) || true

    local uniform=true
    for (( i=0; i<${#files[@]}; i++ )); do
        [[ "${v_codec[$i]}" != "image" ]] || { uniform=false; break; }
        [[ "${has_audio_arr[$i]}" == "true" ]] || { uniform=false; break; }
        [[ "${v_codec[$i]}" != "$target_vc" ]] && { uniform=false; break; }
        [[ "${v_res[$i]}"   != "$target_res" ]] && { uniform=false; break; }
        [[ "${v_fps[$i]}"   != "$target_fps" ]] && { uniform=false; break; }
        [[ "${v_pix[$i]}"   != "$target_pix" ]] && { uniform=false; break; }
        [[ "${dts_ok[$i]}"  != "true" ]]         && { uniform=false; break; }
        [[ "${moov_ok[$i]}" != "true" ]]         && { uniform=false; break; }
    done

    # ── FAST PATH ─────────────────────────────────────────────────────────────
    # Timeout now scaled by input count: a 50-file stream-copy concat is cheap
    # per-file but not free, and previously inherited the single-file default
    # ceiling regardless of count. This is the most direct fix for the reported
    # "large batch concat times out and kills everything" failure mode, since
    # the fast path is exactly what a uniform bulk merge hits.
    if [[ "$uniform" == true && "$REMOVE_AUDIO" != true ]]; then
        verbose_log "merge: fast path — all ${#files[@]} inputs conformant; skipping re-encode."
        local concat_list; concat_list="$(mktemp_ffx .txt)"
        for f in "${files[@]}"; do
            printf "file '%s'\n" "$(absolute_path "$f")" >> "$concat_list"
        done
        local fast_to; fast_to="$(compute_batch_timeout "${#files[@]}")"
        run_ffmpeg --ffx-timeout "$fast_to" --ffx-output "$output" \
            -y -avoid_negative_ts make_zero \
            -f concat -safe 0 -i "$concat_list" -c copy "$output" \
            || die "merge: fast-path concat failed -> $output" "$output"
        auto_clean "$output"
        say "Merged [fast]: $output"
        return
    fi

    verbose_log "merge: normalise path — target ${max_w}x${max_h} @ ${ADV_FPS}fps (uniform=${uniform})"

    # Job identity for the checkpointed normalize path: input file list +
    # output target ONLY. Deliberately does NOT include max_w/max_h, which
    # are derived by PROBING these same files — if one input is transiently
    # corrupt on a failed attempt and fixed on retry, its probed resolution
    # changes, which would silently change the job key and cause a
    # resumable run to miss its own checkpoint. Job identity must be stable
    # across "same inputs, repaired state" retries; per-input encode
    # settings (including target resolution) are already covered by
    # checkpoint_key() at the per-file level.
    local job_sig="${files[*]}|${output}"
    local job_dir; job_dir="$(checkpoint_job_dir "$job_sig")"
    [[ "$no_resume" == true ]] && checkpoint_clear "$job_dir"

    # ── NORMALISE PATH ────────────────────────────────────────────────────────
    local -a preprocessed=()
    local tf="${SPECIFIC_FPS:-$ADV_FPS}"
    local resumed_count=0 fresh_count=0

    for (( i=0; i<${#files[@]}; i++ )); do
        f="${files[$i]}"

        local resumed_tmp=""
        if resumed_tmp="$(checkpoint_get "$job_dir" "$f" "${max_w}x${max_h}" 2>/dev/null)"; then
            verbose_log "merge: input $(basename "$f") resumed from checkpoint."
            preprocessed+=("$resumed_tmp")
            (( resumed_count++ )) || true
            continue
        fi

        local tmp; tmp="$(mktemp_ffx .mp4)"

        if is_image "$f"; then
            verbose_log "merge: normalizing image $f"
            local scale_vf="scale=${max_w}:${max_h}:force_original_aspect_ratio=decrease,pad=${max_w}:${max_h}:-1:-1:color=black,setsar=1,fps=${tf},format=${ADV_PIX_FMT}"
            run_ffmpeg --ffx-output "$tmp" \
                -y -loop 1 -t "$IMAGE_DURATION" -i "$f" \
                -f lavfi -i anullsrc \
                -vf "$scale_vf" \
                -c:v "$ADV_CODEC" -crf "${ADV_CRF:-18}" -preset ultrafast \
                -c:a aac -shortest "$tmp" \
                || die "merge: image normalization failed: $f" "$tmp"
            local persisted; persisted="$(checkpoint_store_artifact "$job_dir" "$f" "$tmp" "${max_w}x${max_h}")"
            checkpoint_set "$job_dir" "$f" "$persisted" "${max_w}x${max_h}"
            preprocessed+=("$persisted")
            (( fresh_count++ )) || true
            continue
        fi

        local needs_encode=false
        [[ "${dts_ok[$i]}"  != "true" ]]       && needs_encode=true
        [[ "${moov_ok[$i]}" != "true" ]]       && needs_encode=true
        [[ "${v_codec[$i]}" != "$ADV_CODEC" ]] && needs_encode=true
        [[ "${v_pix[$i]}"   != "$ADV_PIX_FMT" ]] && needs_encode=true

        local ww hh
        read -r ww hh <<< "${v_res[$i]//x/ }" 2>/dev/null || true
        [[ "$ww" =~ ^[0-9]+$ ]] || ww=0
        [[ "$hh" =~ ^[0-9]+$ ]] || hh=0
        (( ww != max_w || hh != max_h )) && needs_encode=true

        [[ "${has_audio_arr[$i]}" == "false" ]] && needs_encode=true

        if [[ "$REMOVE_AUDIO" != true ]]; then
            [[ "${a_codec[$i]}" != "aac" ]] && needs_encode=true
        fi

        if [[ "$needs_encode" == false ]]; then
            verbose_log "merge: input $(basename "$f") conformant — stream copy."
            run_ffmpeg --ffx-output "$tmp" -y -i "$f" -c copy -movflags +faststart "$tmp" \
                || die "merge: stream-copy failed for '$(basename "$f")'" "$tmp"
        else
            verbose_log "merge: input $(basename "$f") non-conformant — re-encoding."
            local scale_vf="scale=${max_w}:${max_h}:flags=lanczos:force_original_aspect_ratio=decrease,pad=${max_w}:${max_h}:-1:-1:color=black,setsar=1"
            local deint; deint="$(get_deinterlace_filter "$f")"
            local full_vf
            [[ "$deint" != "null" ]] && full_vf="${deint},${scale_vf}" || full_vf="$scale_vf"

            local -a enc
            [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]] \
                && enc=("-c:v" "$ADV_CODEC" "-qp" "0" "-preset" "ultrafast") \
                || enc=("-c:v" "$ADV_CODEC" "-crf" "${ADV_CRF:-18}" "-preset" "ultrafast")

            local -a acmd=()
            if [[ "${has_audio_arr[$i]}" == "false" ]]; then
                acmd=("-f" "lavfi" "-i" "anullsrc" "-c:a" "aac" "-shortest")
            elif [[ "$REMOVE_AUDIO" == true ]]; then
                acmd=("-an")
            else
                acmd=("-map" "0:a?" "-c:a" "aac" "-b:a" "128k" "-ac" "2")
            fi

            local -a movflags=("-movflags" "+faststart")
            [[ "$(check_container_first "$f")" == "webm" ]] && movflags=()

            run_ffmpeg --ffx-output "$tmp" -y -fflags +genpts -i "$f" \
                -vf "$full_vf" -r "$tf" \
                "${enc[@]}" \
                -pix_fmt "$ADV_PIX_FMT" \
                -map "0:v:0" \
                "${acmd[@]}" \
                "${movflags[@]}" \
                "$tmp" \
                || die "merge: re-encode failed for '$(basename "$f")'" "$tmp"
        fi

        check_moov_atom "$tmp" || moov_fallback "$f" "$tmp"
        check_moov_atom "$tmp" || die "merge: moov atom missing: $(basename "$f")" "$tmp"
        local persisted; persisted="$(checkpoint_store_artifact "$job_dir" "$f" "$tmp" "${max_w}x${max_h}")"
        checkpoint_set "$job_dir" "$f" "$persisted" "${max_w}x${max_h}"
        preprocessed+=("$persisted")
        (( fresh_count++ )) || true
    done

    (( resumed_count > 0 )) && verbose_log "merge: ${resumed_count} input(s) resumed from prior run, ${fresh_count} processed fresh."

    # ── CONCAT ───────────────────────────────────────────────────────────────
    local concat_list; concat_list="$(mktemp_ffx .txt)"
    for f in "${preprocessed[@]}"; do
        printf "file '%s'\n" "$(absolute_path "$f")" >> "$concat_list"
    done
    local final_to; final_to="$(compute_batch_timeout "${#preprocessed[@]}")"
    run_ffmpeg --ffx-timeout "$final_to" --ffx-output "$output" \
        -y -avoid_negative_ts make_zero \
        -f concat -safe 0 -i "$concat_list" -c copy "$output" \
        || die "merge: concat failed -> $output" "$output"

    # Pristine-baseline reset only after the final concat actually succeeds —
    # Architectural Gate 4.3. Any earlier failure leaves the checkpoint intact.
    checkpoint_clear "$job_dir"

    auto_clean "$output"
    say "Merged: $output"
}
# =============================================================================
# CMD: PROBE
# =============================================================================
cmd_probe() {
    advanced_prompt
    local input=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*) warn "probe: ignoring unknown option '$1'"; shift ;;
            *)  input="$1"; shift ;;
        esac
    done

    if [[ -z "$input" ]]; then
        local -a _s; mapfile -t _s < <(fzf_pick); input="${_s[0]}"
    fi
    [[ -f "$input" ]] || die "File not found: $input"

    local sz=0 res fps dur fmt
    sz="$(stat -c '%s' "$input" 2>/dev/null || stat -f '%z' "$input" 2>/dev/null || echo 0)"
    res="$(ffprobe -v error -select_streams v:0 \
        -show_entries stream=width,height -of csv=p=0:s=x "$input" 2>/dev/null || echo unknown)"
    fps="$(get_fps "$input")"
    dur="$(ffprobe -v error -show_entries format=duration \
        -of default=noprint_wrappers=1:nokey=1 "$input" 2>/dev/null || echo 0)"
    fmt="$(ffprobe -v error -show_entries format=format_name \
        -of default=noprint_wrappers=1:nokey=1 "$input" 2>/dev/null || echo unknown)"

    printf '%b# === FFX Probe ===%b\n'  "${CYAN}${BOLD}" "${RESET}"
    printf '%bFile:%b       %s\n'       "${CYAN}" "${RESET}" "$input"
    printf '%bSize:%b       %s\n'       "${CYAN}" "${RESET}" "$(bytes_to_human "$sz")"
    printf '%bFormat:%b     %s\n'       "${CYAN}" "${RESET}" "$fmt"
    printf '%bResolution:%b %s\n'       "${CYAN}" "${RESET}" "$res"
    printf '%bFPS:%b        %s\n'       "${CYAN}" "${RESET}" "$fps"
    printf '%bDuration:%b   %ss\n'      "${CYAN}" "${RESET}" "$dur"

    if [[ "$res" =~ ^([0-9]+)x([0-9]+)$ ]]; then
        local h="${BASH_REMATCH[2]}"
        if (( h > 1080 )); then
            local ans
            read -r -p "Resolution ($res) exceeds 1080p. Process now? (y/N): " ans
            [[ "${ans,,}" =~ ^y ]] && cmd_process "$input"
        fi
    fi
}

# =============================================================================
# CMD: PROCESS
# =============================================================================
cmd_process() {
    advanced_prompt
    local input="" output="${GLOBAL_OUTPUT_FILE:-}" forced_fps=""
    local -a args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -P|--max-1080)      MAX_1080=true; shift ;;
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -v|--verbose)       VERBOSE_MODE=true; shift ;;
            -o|--output)        output="$2"; shift 2 ;;
            -f|--fps)           forced_fps="$2"; shift 2 ;;
            -*)                 warn "process: ignoring unknown option '$1'"; shift ;;
            *)                  args+=("$1"); shift ;;
        esac
    done

    input="${args[0]:-}"
    [[ -z "$output" ]] && output="${args[1]:-}"
    [[ -z "$input" ]] && die "'process' requires an input file."
    [[ -s "$input" ]] || die "Input zero-length or missing: $input"

    local bare; bare="$(basename "${input%.*}")"
    [[ -z "$output" ]] && output="$(get_default_filename "$bare" "processed" "$ADV_CONTAINER")"
    [[ -n "$forced_fps" ]] && ADV_FPS="$forced_fps"
    [[ -n "$SPECIFIC_FPS" ]] && ADV_FPS="$SPECIFIC_FPS"

    local fixed; fixed="$(ensure_dts_correct "$input")" || die "DTS fix failed: $input"

    if [[ "$MAX_1080" == true ]]; then
        local h=0
        h="$(ffprobe -v error -select_streams v:0 \
            -show_entries stream=height -of csv=p=0 "$fixed" 2>/dev/null || echo 0)"
        (( h > 1080 )) && { verbose_log "Clamping to 1080p."; ADV_RES="${CANVAS_W}x${CANVAS_H}"; }
    fi

    local -a aopts; mapfile -t aopts < <(get_audio_opts_array)
    local deint; deint="$(get_deinterlace_filter "$fixed")"

    # PRE-EXISTING BUG FIX (found via regression testing, disclosed per
    # protocol; out of original audit scope but adjacent to units already
    # touched): ADV_RES is stored in "WxH" form (e.g. "1920x1080"). ffmpeg's
    # `scale` filter accepts that form directly, but `pad` does not — pad
    # requires colon-separated `width:height:x:y` arguments. The original
    # line built `pad=${ADV_RES}:-1:-1`, which ffmpeg parses as a single
    # malformed width expression ("1920x1080") and rejects outright,
    # failing 'process' for every invocation that reaches this code path
    # (i.e. every non-qp0, non-multipass CRF encode — the default mode).
    # Fix: split ADV_RES into its width/height components once, and use
    # those for the pad clause, mirroring the already-correct pattern in
    # cmd_merge's scale_vf construction (which uses max_w:max_h directly).
    local res_w res_h
    IFS='x' read -r res_w res_h <<< "$ADV_RES"
    local scale_f="scale=${ADV_RES}:flags=lanczos:force_original_aspect_ratio=decrease,pad=${res_w}:${res_h}:-1:-1:color=black,setsar=1"
    local full_vf; [[ "$deint" != "null" ]] && full_vf="${deint},${scale_f}" || full_vf="$scale_f"

    if [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]]; then
        run_ffmpeg --ffx-output "$output" -y -i "$fixed" -vf "$full_vf" -r "$ADV_FPS" \
            -c:v "$ADV_CODEC" -qp 0 -preset "$ADV_PRESET" \
            "${aopts[@]}" -pix_fmt "$ADV_PIX_FMT" -movflags +faststart "$output" \
            || die "process (qp0) failed." "$output"
    elif [[ "$ADV_MULTIPASS" == "true" ]]; then
        run_ffmpeg -y -i "$fixed" -vf "$full_vf" -r "$ADV_FPS" \
            -c:v "$ADV_CODEC" -b:v "$ADV_BR" -preset "$ADV_PRESET" -pass 1 -an \
            -f mp4 /dev/null || die "process: pass 1 failed."
        run_ffmpeg --ffx-output "$output" -y -i "$fixed" -vf "$full_vf" -r "$ADV_FPS" \
            -c:v "$ADV_CODEC" -b:v "$ADV_BR" -preset "$ADV_PRESET" -pass 2 \
            "${aopts[@]}" -pix_fmt "$ADV_PIX_FMT" -movflags +faststart "$output" \
            || die "process: pass 2 failed." "$output"
    else
        run_ffmpeg --ffx-output "$output" -y -i "$fixed" -vf "$full_vf" -r "$ADV_FPS" \
            -c:v "$ADV_CODEC" -crf "${ADV_CRF:-18}" -preset "$ADV_PRESET" \
            "${aopts[@]}" -pix_fmt "$ADV_PIX_FMT" -movflags +faststart "$output" \
            || die "process (CRF) failed." "$output"
    fi

    check_moov_atom "$output" || moov_fallback "$fixed" "$output"
    check_moov_atom "$output" || die "moov atom missing: $output"
    auto_clean "$output"
    say "Processed: $output"
}

# =============================================================================
# CMD: LOOPERANG
# =============================================================================
cmd_looperang() {
    advanced_prompt
    local input="" output="${GLOBAL_OUTPUT_FILE:-}"
    local -a args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -v|--verbose)       VERBOSE_MODE=true; shift ;;
            -o|--output)        output="$2"; shift 2 ;;
            -*)                 warn "looperang: ignoring unknown option '$1'"; shift ;;
            *)                  args+=("$1"); shift ;;
        esac
    done

    input="${args[0]:-}"
    [[ -z "$output" ]] && output="${args[1]:-}"
    [[ -z "$input" ]] && die "looperang requires an input file."
    [[ -f "$input" ]] || die "File not found: $input"

    local bare; bare="$(basename "${input%.*}")"
    [[ -z "$output" ]] && output="$(get_default_filename "$bare" "looperang" "$ADV_CONTAINER")"

    local fixed; fixed="$(ensure_dts_correct "$input")" || die "DTS fix failed: $input"
    local tmp_rev; tmp_rev="$(mktemp_ffx .mp4)"

    # PRE-EXISTING BUG FIX (found via regression testing, disclosed per protocol):
    # get_audio_opts_array() returns "-c:a copy" when REMOVE_AUDIO is false, but
    # this command applies "-af areverse" to the audio stream whenever audio is
    # kept. ffmpeg rejects combining a stream filter with stream-copy on the same
    # stream outright (exit failure, every time audio is present) — this is not
    # a transient/retry-able failure, it is a hard contradiction in the command
    # line itself. The reverse pass needs its own audio handling: re-encode (aac)
    # when audio is kept (so areverse has something to operate on), or -an when
    # REMOVE_AUDIO is true (consistent with get_audio_opts_array's other branch).
    local -a loop_aopts
    if [[ "$REMOVE_AUDIO" == true ]]; then
        loop_aopts=("-an")
    else
        loop_aopts=("-c:a" "aac")
    fi

    run_ffmpeg --ffx-output "$tmp_rev" -y -i "$fixed" \
        -vf reverse -af areverse \
        "${loop_aopts[@]}" -c:v "$ADV_CODEC" -qp 0 -preset ultrafast \
        "$tmp_rev" || die "looperang: reverse pass failed." "$tmp_rev"

    local cl; cl="$(mktemp_ffx .txt)"
    printf "file '%s'\n" "$(absolute_path "$fixed")"   >> "$cl"
    printf "file '%s'\n" "$(absolute_path "$tmp_rev")" >> "$cl"

    # PRE-EXISTING BUG FIX (found via the same regression pass as above,
    # disclosed per protocol): this concat step previously used "-c copy"
    # unconditionally for both video AND audio, which silently ignored
    # REMOVE_AUDIO at the final assembly stage even though the reverse pass
    # above already honored it — the concat would still mux in whatever
    # audio "fixed" (the untouched original) carries. Video always stays
    # stream-copy (both inputs are already the correct codec/format from
    # the steps above); audio now explicitly follows REMOVE_AUDIO.
    local -a concat_aopts
    if [[ "$REMOVE_AUDIO" == true ]]; then
        concat_aopts=("-an")
    else
        concat_aopts=("-c:a" "copy")
    fi

    run_ffmpeg --ffx-output "$output" -y -f concat -safe 0 -i "$cl" \
        -c:v copy "${concat_aopts[@]}" "$output" \
        || die "looperang: concat failed." "$output"

    check_moov_atom "$output" || moov_fallback "$fixed" "$output"
    check_moov_atom "$output" || die "looperang: moov atom missing."
    auto_clean "$output"
    say "Looperang: $output"
}

# =============================================================================
# CMD: SLOWMO
# =============================================================================
cmd_slowmo() {
    advanced_prompt
    local input="" output="${GLOBAL_OUTPUT_FILE:-}" factor=""
    local -a args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -i|--interpolate)   INTERPOLATE=true; shift ;;
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -v|--verbose)       VERBOSE_MODE=true; shift ;;
            -p|--pts)           factor="$2"; shift 2 ;;
            -f|--fps)           SPECIFIC_FPS="$2"; shift 2 ;;
            -o|--output)        output="$2"; shift 2 ;;
            -*)                 warn "slowmo: ignoring unknown option '$1'"; shift ;;
            *)                  args+=("$1"); shift ;;
        esac
    done

    input="${args[0]:-}"
    [[ -z "$output" ]] && output="${args[1]:-}"
    [[ -z "$factor" ]] && factor="${args[2]:-2}"
    [[ -n "$PTS_FACTOR" ]] && factor="$PTS_FACTOR"

    [[ -z "$input" ]] && die "slowmo requires an input file."
    [[ -f "$input" ]] || die "File not found: $input"

    local bare; bare="$(basename "${input%.*}")"
    [[ -z "$output" ]] && output="$(get_default_filename "$bare" "slowmo" "$ADV_CONTAINER")"

    local fps="${SPECIFIC_FPS:-$ADV_FPS}"
    local vf="setpts=${factor}*PTS"

    if [[ "$INTERPOLATE" == true ]]; then
        [[ -z "$SPECIFIC_FPS" ]] && fps="120" \
            && verbose_log "No -f set; defaulting interpolation to 120 FPS."
        vf="minterpolate=fps=${fps}:mi_mode=mci:mc_mode=aobmc:me_mode=bidir:vsbmc=1,${vf}"
    fi

    local -a ffa=("-y" "-i" "$input")
    if [[ "$REMOVE_AUDIO" == false ]]; then
        local sp af=""
        sp="$(bc -l <<< "1 / $factor")"
        while (( $(echo "$sp < 0.5" | bc -l) )); do af+="atempo=0.5,"; sp="$(bc -l <<< "$sp / 0.5")"; done
        while (( $(echo "$sp > 2.0" | bc -l) )); do af+="atempo=2.0,"; sp="$(bc -l <<< "$sp / 2.0")"; done
        af+="atempo=${sp}"
        ffa+=("-filter_complex" "[0:v]${vf}[v];[0:a]${af}[a]" "-map" "[v]" "-map" "[a]")
    else
        ffa+=("-vf" "$vf" "-an")
    fi

    ffa+=("-r" "$fps" "-c:v" "$ADV_CODEC")
    [[ "${ADV_QUALITY_MODE:-crf}" == "qp0" ]] \
        && ffa+=("-qp" "0") || ffa+=("-crf" "${ADV_CRF:-18}")
    ffa+=("-preset" "$ADV_PRESET" "-pix_fmt" "$ADV_PIX_FMT" "$output")

    run_ffmpeg --ffx-output "$output" "${ffa[@]}" || die "slowmo failed." "$output"
    check_moov_atom "$output" || moov_fallback "$input" "$output"
    auto_clean "$output"
    say "Slow motion: $output"
}

