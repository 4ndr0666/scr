# --- XDG & Directory Setup ---
setup_xdg() {
    : "${XDG_CONFIG_HOME:="$HOME/.config"}"
    : "${XDG_DATA_HOME:="$HOME/.local/share"}"
    : "${XDG_CACHE_HOME:="$HOME/.cache"}"
    : "${XDG_RUNTIME_DIR:="${TMPDIR:-/tmp}"}"

    FFX_CONFIG_DIR="$XDG_CONFIG_HOME/ffx"
    FFX_LOG_DIR="$XDG_DATA_HOME/ffx"
    FFX_CACHE_DIR="$XDG_CACHE_HOME/ffx"

    # Session-scoped runtime dir (ALL ephemeral artifacts live here)
    FFX_RUN_DIR="$(mktemp -d -p "${XDG_RUNTIME_DIR}" "ffx.XXXXXXXX")"
    trap 'rm -rf -- "$FFX_RUN_DIR"' EXIT

    mkdir -p "$FFX_CONFIG_DIR" "$FFX_LOG_DIR" "$FFX_CACHE_DIR"
    LOG_FILE="$FFX_LOG_DIR/ffx.log"
}

# --- Utility Functions ---
command_exists() { command -v "$1" >/dev/null 2>&1; }

bytes_to_human() {
    local b=${1:-0}
    if [ "$b" -lt 1024 ]; then echo "${b}B"
    elif [ "$b" -lt 1048576 ]; then echo "$((b/1024))KB"
    elif [ "$b" -lt 1073741824 ]; then echo "$((b/1048576))MB"
    else echo "$(awk "BEGIN {printf \"%.2fGB\", $b/1073741824}")"
    fi
}

shuffle_array() {
    local -n arr=$1
    local i j tmp
    for ((i=${#arr[@]}-1; i>0; i--)); do
        j=$((RANDOM % (i+1)))
        tmp="${arr[i]}"
        arr[i]="${arr[j]}"
        arr[j]="$tmp"
    done
}

advanced_prompt() {
    # Reserved for future TUI expansion
    :
}

# --- Colors and Logging ---
if command -v tput >/dev/null 2>&1 && [[ -t 1 ]]; then
    CYAN="$(tput setaf 6)"
    GREEN="$(tput setaf 2)"
    YELLOW="$(tput setaf 3)"
    BOLD="$(tput bold)"
    RED="$(tput setaf 1)"
    RESET="$(tput sgr0)"
else
    CYAN="" GREEN="" YELLOW="" BOLD="" RED="" RESET=""
fi

log_info() { printf "%b[Ψ] %s%b\n" "$CYAN" "$*" "$RESET" | tee -a "$LOG_FILE" >&2; }
log_warn() { printf "%b[-] %s%b\n" "$YELLOW" "$*" "$RESET" | tee -a "$LOG_FILE" >&2; }
die()      { printf "%b[!] ERROR: %s%b\n" "$RED" "$*" "$RESET" | tee -a "$LOG_FILE" >&2; exit 1; }
error_exit() { die "$1"; }

# --- Global State ---
VERBOSE_MODE=false
DRY_RUN=false
REMOVE_AUDIO=false
COMPOSITE_MODE=false
MAX_1080=false
OUTPUT_DIR=""
SPECIFIC_FPS=""
PTS_FACTOR=""
INTERPOLATE=false
FFX_TIMEOUT="0"
FFX_TIMEOUT_USER_SET=0
REMAINING_ARGS=()

display_usage() {
    cat <<EOF
Ψ-4NDR0666 FFX Orchestrator
Usage: ${0##*/} [options] <command> [args...]

Global Options:
  -v, --verbose         Enable verbose output
  --dry-run             Print FFmpeg commands without executing
  -an, --remove-audio   Strip audio tracks
  -C, --composite       Composite mode processing (Implicit composite route)
  -P, --max-1080        Downscale to 1080p maximum
  -o, --output-dir DIR  Specify output directory
  -f, --fps FPS         Target FPS
  -p, --pts FACTOR      Adjust PTS (e.g., 0.5 for 2x speed)
  -i, --interpolate     Enable motion interpolation (minterpolate)
  --timeout SECS        Kill FFmpeg after SECS (0 disables)
  -h, --help            Show this help dialog

Commands:
  probe <input>
  process <input> [output]
  merge [files...] [-o output]
  looperang <input> [output]
  slowmo <input> <factor> [output]
  fix <input> [output]
  clean <input> [output]
  clip <input> <start> <end> [output]
  composite <input1> <input2> ... <output>
EOF
    exit 0
}

parse_global_options() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -v|--verbose) VERBOSE_MODE=true; shift ;;
            --dry-run) DRY_RUN=true; shift ;;
            -an|--remove-audio) REMOVE_AUDIO=true; shift ;;
            -C|--composite) COMPOSITE_MODE=true; shift ;;
            -P|--max-1080) MAX_1080=true; shift ;;
            -o|--output-dir) OUTPUT_DIR="$2"; shift 2 ;;
            -f|--fps) SPECIFIC_FPS="$2"; shift 2 ;;
            -p|--pts) PTS_FACTOR="$2"; shift 2 ;;
            -i|--interpolate) INTERPOLATE=true; shift ;;
            --timeout) FFX_TIMEOUT="$2"; FFX_TIMEOUT_USER_SET=1; shift 2 ;;
            -h|--help) display_usage ;;
            -*) die "Unknown option: $1" ;;
            *) REMAINING_ARGS+=("$1"); shift ;;
        esac
    done
}

get_output_path() {
    local input="$1"
    local suffix="$2"
    local manual_out="${3:-}"
    local ext="${input##*.}"
    local base="${input%.*}"
    base="${base##*/}"
    
    if [[ -n "$manual_out" ]]; then echo "$manual_out"
    elif [[ -n "$OUTPUT_DIR" ]]; then echo "$OUTPUT_DIR/${base}_${suffix}.${ext}"
    else echo "${base}_${suffix}.${ext}"; fi
}

build_ffmpeg_options() {
    local -n out_opts=$1
    local -n out_filters=$2
    
    out_opts=(-y -hide_banner)
    [[ "$VERBOSE_MODE" == "false" ]] && out_opts+=(-loglevel error)

    if [[ "$REMOVE_AUDIO" == "true" ]]; then out_opts+=(-an)
    else out_opts+=(-c:a copy); fi

    if [[ "$MAX_1080" == "true" ]]; then
        out_filters+=("scale='if(gt(iw,1920),1920,iw)':'if(gt(ih,1080),1080,ih)':force_original_aspect_ratio=decrease")
    fi
    
    if [[ -n "$SPECIFIC_FPS" ]]; then
        if [[ "$INTERPOLATE" == "true" ]]; then
            out_filters+=("minterpolate='fps=${SPECIFIC_FPS}:mi_mode=mci:me_mode=bidir:me=epzs'")
        else
            out_filters+=("fps=${SPECIFIC_FPS}")
        fi
    fi

    [[ -n "$PTS_FACTOR" ]] && out_filters+=("setpts=${PTS_FACTOR}*PTS")

    out_opts+=(-c:v libx264 -preset medium -crf 18)
}

execute_cmd() {
    local -a exec_arr=("$@")
    if [[ "$FFX_TIMEOUT_USER_SET" -eq 1 && "$FFX_TIMEOUT" -gt 0 ]]; then
        exec_arr=(timeout "$FFX_TIMEOUT" "${exec_arr[@]}")
    fi

    if [[ "$DRY_RUN" == "true" ]]; then log_info "DRY-RUN: ${exec_arr[*]}"
    else log_info "Executing: ${exec_arr[*]}"; "${exec_arr[@]}"; fi
}

# --- // Command Implementations // ---

# RESTORED: Canonical Probe implementation verbatim
cmd_probe() {
	advanced_prompt
	local input="${1:-}"

	if [ -z "$input" ]; then
		# If no file, optionally let user pick from fzf
		if command_exists fzf; then
			echo "➡️ No file provided. Launching fzf..."
			input="$(fzf)"
			[ -z "$input" ] && error_exit "No file selected."
		else
			error_exit "No input provided for probe."
		fi
	fi
	[ ! -f "$input" ] && error_exit "File not found: $input"

	local CYAN="\033[36m"
	local RESET="\033[0m"
	local sz hsz resolution fps duration
	sz="$(stat -c '%s' "$input" 2>/dev/null || echo 0)"
	hsz="$(bytes_to_human "$sz")"

	resolution="$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height \
		-of csv=p=0:s=x "$input" 2>/dev/null || echo 'unknown')"

	fps="$(ffprobe -v error -select_streams v:0 -show_entries stream=avg_frame_rate \
		-of default=noprint_wrappers=1:nokey=1 "$input" 2>/dev/null || echo '0/0')"

	duration="$(ffprobe -v error -show_entries format=duration \
		-of default=noprint_wrappers=1:nokey=1 "$input" 2>/dev/null || echo 0)"

	echo -e "${CYAN}# === // Ffx Probe //${RESET}"
	echo
	echo -e "${CYAN}File:${RESET} $input"
	echo -e "${CYAN}Size:${RESET} $hsz"

	local fps_head
	fps_head="$(cut -d'/' -f1 <<<"$fps")"
	if [[ "$fps_head" =~ ^[0-9]+$ ]] && [ "$fps_head" -gt 60 ]; then
		echo "➡️ High FPS detected; consider processing."
	fi

	echo -e "${CYAN}--------------------------------${RESET}"
	echo -e "${CYAN}Resolution:${RESET}   $resolution"
	echo -e "${CYAN}FPS:${RESET}          $fps"
	echo -e "${CYAN}Duration:${RESET}     ${duration}s"

	# Prompt user if height > 1080
	if [ "$resolution" != "unknown" ]; then
		local width height
		if IFS='x' read -r width height <<<"$resolution"; then
			if [[ "$height" =~ ^[0-9]+$ ]] && [ "$height" -gt 1080 ]; then
				local ans
				read -r -p "Detected resolution ($resolution) is above 1080p. Process this file? (y/N): " ans
				ans="$(echo "$ans" | tr '[:upper:]' '[:lower:]')"
				if [ "$ans" = "y" ] || [ "$ans" = "yes" ]; then
					cmd_process "$input"
					exit 0
				fi
			fi
		else
			echo "❌ Error: Failed to parse resolution format: '$resolution'" >&2
			exit 1
		fi
	fi
}

cmd_process() {
    [[ ${#@} -lt 1 ]] && die "Usage: ffx process <input> [output]"
    local input="$1"
    local manual_out="${2:-}"
    local output; output=$(get_output_path "$input" "processed" "$manual_out")

    local -a opts filters
    build_ffmpeg_options opts filters

    local -a exec_arr=(ffmpeg "${opts[@]}" -i "$input")
    if [[ ${#filters[@]} -gt 0 ]]; then
        local IFS=,
        exec_arr+=(-vf "${filters[*]}")
    fi
    exec_arr+=("$output")
    execute_cmd "${exec_arr[@]}"
}

cmd_merge() {
    [[ ${#@} -lt 2 ]] && die "Usage: ffx merge <file1> <file2> ... [-o output]"
    local files=()
    local output="merged_output.mp4"
    while [[ $# -gt 0 ]]; do
        if [[ "$1" == "-o" ]]; then output="$2"; shift 2; else files+=("$1"); shift; fi
    done
    local list_file="$FFX_RUN_DIR/concat_list.txt"
    for f in "${files[@]}"; do
        [[ ! -f "$f" ]] && die "File not found: $f"
        echo "file '$(realpath "$f")'" >> "$list_file"
    done
    local -a opts filters; build_ffmpeg_options opts filters
    local -a exec_arr=(ffmpeg "${opts[@]}" -f concat -safe 0 -i "$list_file")
    if [[ ${#filters[@]} -gt 0 ]]; then local IFS=,; exec_arr+=(-vf "${filters[*]}"); else exec_arr+=(-c copy); fi
    exec_arr+=("$output"); execute_cmd "${exec_arr[@]}"
}

cmd_looperang() {
    [[ ${#@} -lt 1 ]] && die "Usage: ffx looperang <input> [output]"
    local input="$1"
    local manual_out="${2:-}"
    local output; output=$(get_output_path "$input" "looperang" "$manual_out")
    local -a opts filters; build_ffmpeg_options opts filters
    local filter_graph="[0:v]reverse[r];[0:v][r]concat=n=2:v=1[v]"
    if [[ ${#filters[@]} -gt 0 ]]; then
        local IFS=,; filter_graph="${filter_graph};[v]${filters[*]}[v_out]"
        opts+=(-filter_complex "$filter_graph" -map "[v_out]")
    else opts+=(-filter_complex "$filter_graph" -map "[v]"); fi
    local -a exec_arr=(ffmpeg "${opts[@]}" -i "$input" "$output"); execute_cmd "${exec_arr[@]}"
}

cmd_slowmo() {
    [[ ${#@} -lt 2 ]] && die "Usage: ffx slowmo <input> <factor> [output]"
    local input="$1"
    local factor="$2"
    local manual_out="${3:-}"
    local output; output=$(get_output_path "$input" "slowmo" "$manual_out")
    if ! awk "BEGIN{exit !($factor > 0)}" 2>/dev/null; then die "Invalid slowmo factor."; fi
    local pts_adj; pts_adj=$(awk "BEGIN {print 1.0 / $factor}")
    PTS_FACTOR="$pts_adj"
    local -a opts filters; build_ffmpeg_options opts filters
    local -a exec_arr=(ffmpeg "${opts[@]}" -i "$input")
    if [[ ${#filters[@]} -gt 0 ]]; then local IFS=,; exec_arr+=(-vf "${filters[*]}"); fi
    exec_arr+=("$output"); execute_cmd "${exec_arr[@]}"
}

cmd_fix() {
    [[ ${#@} -lt 1 ]] && die "Usage: ffx fix <input> [output]"
    local input="$1"
    local manual_out="${2:-}"
    local output; output=$(get_output_path "$input" "fixed" "$manual_out")
    local -a exec_arr=(ffmpeg -y -hide_banner -loglevel error -err_detect ignore_err -i "$input" -c copy -map 0 "$output")
    execute_cmd "${exec_arr[@]}"
}

cmd_clean() {
    [[ ${#@} -lt 1 ]] && die "Usage: ffx clean <input> [output]"
    local input="$1"
    local manual_out="${2:-}"
    local output; output=$(get_output_path "$input" "clean" "$manual_out")
    local -a exec_arr=(ffmpeg -y -hide_banner -loglevel error -i "$input" -map_metadata -1 -c copy "$output")
    execute_cmd "${exec_arr[@]}"
}

cmd_clip() {
    [[ ${#@} -lt 3 ]] && die "Usage: ffx clip <input> <start> <end> [output]"
    local input="$1"
    local start="$2"
    local end="$3"
    local manual_out="${4:-}"
    local output; output=$(get_output_path "$input" "clip" "$manual_out")
    local -a opts filters; build_ffmpeg_options opts filters
    local -a exec_arr=(ffmpeg "${opts[@]}" -ss "$start" -to "$end" -i "$input")
    if [[ ${#filters[@]} -gt 0 ]]; then local IFS=,; exec_arr+=(-vf "${filters[*]}"); else exec_arr+=(-c copy); fi
    exec_arr+=("$output"); execute_cmd "${exec_arr[@]}"
}

cmd_composite() {
    [[ ${#@} -lt 2 ]] && die "Usage: ffx composite <input1> <input2> ... <output>"
    
    # HARDENED: Strict positional arg extraction
    local inputs=("${@:1:${#@}-1}")
    local output="${@:${#@}:1}"
    local count=${#inputs[@]}

    log_info "Initializing Randomized Mixed-Geometry Composite Engine for $count inputs..."
    shuffle_array inputs

    # Geometry matrix definition
    local -a cell_w cell_h cell_x cell_y
    if (( count == 1 )); then
        cell_w=(1920) cell_h=(1080) cell_x=(0) cell_y=(0)
    elif (( count == 2 )); then
        cell_w=(960 960) cell_h=(1080 1080) cell_x=(0 960) cell_y=(0 0)
    elif (( count == 3 )); then
        cell_w=(960 960 960) cell_h=(1080 540 540) cell_x=(0 960 960) cell_y=(0 0 540)
    elif (( count == 4 )); then
        cell_w=(960 960 960 960) cell_h=(540 540 540 540) cell_x=(0 960 0 960) cell_y=(0 0 540 540)
    elif (( count == 6 )); then
        # Mixed Geometry 1-Big / 5-Small (Randomized Position logic)
        local indices=(0 1 2 3 4 5)
        shuffle_array indices
        local -a master_w=(1280 640 640 640 640 640)
        local -a master_h=(720 360 360 360 360 360)
        local -a master_x=(0 1280 1280 0 640 1280)
        local -a master_y=(0 0 360 720 720 720)
        for i in {0..5}; do
            local idx=${indices[$i]}
            cell_w[i]=${master_w[$idx]}
            cell_h[i]=${master_h[$idx]}
            cell_x[i]=${master_x[$idx]}
            cell_y[i]=${master_y[$idx]}
        done
    else
        # Dynamic Uniform Fallback
        local cols; cols=$(awk "BEGIN {print int(sqrt($count) + 0.9999)}")
        local rows; rows=$(awk "BEGIN {print int(($count + $cols - 1) / $cols)}")
        local tw=$(( 1920 / cols )) th=$(( 1080 / rows ))
        for ((i=0; i<count; i++)); do
            cell_w[i]=$tw cell_h[i]=$th cell_x[i]=$(( (i % cols) * tw )) cell_y[i]=$(( (i / cols) * th ))
        done
    fi

    log_info "Phase 1: Normalizing $count inputs into assigned geometrical bounds..."
    local norm_files=()
    for (( i=0; i<count; i++ )); do
        local in_file="${inputs[$i]}"
        local norm_file="$FFX_RUN_DIR/norm_$i.mp4"
        local cw="${cell_w[$i]}" ch="${cell_h[$i]}"
        log_info " -> Processing Tile $i ($cw x $ch): $in_file"
        local norm_vf="scale=${cw}:${ch}:force_original_aspect_ratio=decrease,pad=${cw}:${ch}:(ow-iw)/2:(oh-ih)/2:color=black"
        execute_cmd ffmpeg -y -hide_banner -loglevel error -i "$in_file" -vf "$norm_vf" -c:v libx264 -preset veryfast -crf 18 -an "$norm_file"
        norm_files+=("$norm_file")
    done

    log_info "Phase 2: Executing xstack spatial layout assembly..."
    local layout=""; for (( i=0; i<count; i++ )); do layout+="${cell_x[$i]}_${cell_y[$i]}|"; done
    local filter_graph="xstack=inputs=${count}:layout=${layout%|}:fill=black[v]"
    local -a exec_arr=(ffmpeg -y -hide_banner)
    [[ "$VERBOSE_MODE" == "false" ]] && exec_arr+=(-loglevel error)
    for f in "${norm_files[@]}"; do exec_arr+=(-i "$f"); done
    exec_arr+=(-filter_complex "$filter_graph" -map "[v]" -an -c:v libx264 -preset medium -crf 18 "$output")
    execute_cmd "${exec_arr[@]}"
}

main_dispatch() {
    local action="${1:-help}"
    if [[ "$COMPOSITE_MODE" == "true" ]]; then
        if [[ ! "$action" =~ ^(probe|process|merge|looperang|slowmo|fix|clean|clip|composite|help)$ ]]; then action="composite"
        else shift || true; fi
    else shift || true; fi
    
    case "$action" in
        probe) cmd_probe "$@" ;;
        process) cmd_process "$@" ;;
        merge) cmd_merge "$@" ;;
        looperang) cmd_looperang "$@" ;;
        slowmo) cmd_slowmo "$@" ;;
        fix) cmd_fix "$@" ;;
        clean) cmd_clean "$@" ;;
        clip) cmd_clip "$@" ;;
        composite) cmd_composite "$@" ;;
        help) display_usage ;;
        *) die "Unknown command: $action" ;;
    esac
}

main() {
    setup_xdg
    parse_global_options "$@"
    [[ ${#REMAINING_ARGS[@]} -eq 0 ]] && display_usage
    main_dispatch "${REMAINING_ARGS[@]}"
}

main "$@"
